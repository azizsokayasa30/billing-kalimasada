<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Setting RADIUS</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/responsive-admin.css" rel="stylesheet">
  <style>
    body { background: #f5f6fa; }
    .main-content { padding: 32px 24px; }
    .card { border: none; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.04); }
  </style>
</head>
<body>
<div class="container-fluid">
  <div class="row">
    <%- include('partials/admin-responsive-sidebar', { page: 'setting-radius', settings: settings }) %>
    <main class="col-md-10 ms-sm-auto main-content">
      <h3 class="mb-3"><i class="bi bi-gear-wide-connected"></i> Setting RADIUS</h3>
      <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>
      <% if (success) { %>
        <div class="alert alert-success"><%= success %></div>
      <% } %>

      <form method="post" action="/admin/radius" class="card p-3 shadow-sm" style="max-width: 560px;">
        <div class="mb-3">
          <label class="form-label">Mode Autentikasi</label>
          <select name="user_auth_mode" class="form-select">
            <option value="radius" <%= (settings.user_auth_mode||'radius')==='radius'?'selected':'' %>>RADIUS</option>
            <option value="mikrotik" <%= settings.user_auth_mode==='mikrotik'?'selected':'' %>>Mikrotik API</option>
          </select>
        </div>
        <div class="mb-3">
          <label class="form-label">RADIUS Host</label>
          <input type="text" name="radius_host" class="form-control" value="<%= settings.radius_host || 'localhost' %>" placeholder="127.0.0.1">
        </div>
        <div class="mb-3">
          <label class="form-label">RADIUS User</label>
          <input type="text" name="radius_user" class="form-control" value="<%= settings.radius_user || 'billing' %>" placeholder="billing">
          <small class="form-text text-muted">Gunakan 'billing' untuk billing server atau 'radius' untuk FreeRADIUS</small>
        </div>
        <div class="mb-3">
          <label class="form-label">RADIUS Password</label>
          <input type="password" name="radius_password" class="form-control" value="<%= settings.radius_password || 'radius' %>">
        </div>
        <div class="mb-3">
          <label class="form-label">RADIUS Database</label>
          <input type="text" name="radius_database" class="form-control" value="<%= settings.radius_database || 'radius' %>">
        </div>
        <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Simpan</button>
      </form>

      <!-- Test Connection Button -->
      <div class="card p-3 shadow-sm mt-3" style="max-width: 560px;">
        <h5 class="mb-3"><i class="bi bi-plug"></i> Test Koneksi</h5>
        <button type="button" id="testConnectionBtn" class="btn btn-outline-primary">
          <i class="bi bi-arrow-repeat"></i> Test Koneksi ke RADIUS
        </button>
        <div id="testResult" class="mt-3"></div>
      </div>

      <!-- Manage RADIUS Clients Link -->
      <div class="card p-3 shadow-sm mt-3" style="max-width: 560px;">
        <h5 class="mb-3"><i class="bi bi-router"></i> Manage RADIUS Clients (NAS)</h5>
        <p class="text-muted">Kelola router/NAS yang diizinkan mengirim request autentikasi ke FreeRADIUS</p>
        <a href="/admin/radius/clients" class="btn btn-outline-primary">
          <i class="bi bi-gear"></i> Kelola Clients
        </a>
      </div>
    </main>
  </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
$(document).ready(function() {
  $('#testConnectionBtn').on('click', function() {
    const btn = $(this);
    const resultDiv = $('#testResult');
    
    // Disable button dan show loading
    btn.prop('disabled', true);
    btn.html('<span class="spinner-border spinner-border-sm"></span> Testing...');
    resultDiv.html('<div class="alert alert-info">Sedang mengetes koneksi...</div>');
    
    // Test connection
    $.ajax({
      url: '/admin/radius/test',
      method: 'GET',
      success: function(response) {
        btn.prop('disabled', false);
        btn.html('<i class="bi bi-arrow-repeat"></i> Test Koneksi ke RADIUS');
        
        if (response.success) {
          resultDiv.html(`
            <div class="alert alert-success">
              <h6><i class="bi bi-check-circle"></i> Koneksi Berhasil!</h6>
              <hr>
              <p><strong>Connection:</strong></p>
              <ul>
                <li>Host: ${response.connection.host}</li>
                <li>Database: ${response.connection.database}</li>
                <li>User: ${response.connection.user}</li>
                <li>Status: <span class="badge bg-success">${response.connection.status}</span></li>
              </ul>
              <p><strong>Statistics:</strong></p>
              <ul>
                <li>Total Users: <strong>${response.statistics.totalUsers}</strong></li>
                <li>Active Connections: <strong>${response.statistics.activeConnections}</strong></li>
                <li>Offline Users: <strong>${response.statistics.offlineUsers}</strong></li>
              </ul>
            </div>
          `);
        } else {
          resultDiv.html(`
            <div class="alert alert-danger">
              <h6><i class="bi bi-x-circle"></i> Koneksi Gagal!</h6>
              <hr>
              <p><strong>Error:</strong> ${response.message}</p>
              ${response.mode ? `<p><strong>Mode saat ini:</strong> ${response.mode}</p>` : ''}
              ${response.error ? `<p><small class="text-muted">${response.error}</small></p>` : ''}
            </div>
          `);
        }
      },
      error: function(xhr) {
        btn.prop('disabled', false);
        btn.html('<i class="bi bi-arrow-repeat"></i> Test Koneksi ke RADIUS');
        
        const errorMsg = xhr.responseJSON?.message || 'Unknown error';
        resultDiv.html(`
          <div class="alert alert-danger">
            <h6><i class="bi bi-x-circle"></i> Error!</h6>
            <p>${errorMsg}</p>
          </div>
        `);
      }
    });
  });
});
</script>
</body>
</html>

