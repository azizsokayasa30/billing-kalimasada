<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('../../partials/hard-reload') %>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Paket Member - Admin Portal</title>
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link href="/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
    
    <link href="/css/theme.css" rel="stylesheet">
    <link href="/css/admin-mobile.css" rel="stylesheet">
    <link href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" rel="stylesheet">

    <%- include('../../partials/theme-head') %>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <%- include('../../partials/billing-sidebar', { page: page, settings: settings, versionInfo: versionInfo, versionBadge: versionBadge }) %>
            
            <main class="col-md-10 ms-sm-auto col-lg-9 px-md-4 main-content py-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h1 class="h3 mb-0"><i class="bi bi-box-seam me-2"></i>Paket Member</h1>
                    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addPackageModal">
                        <i class="bi bi-plus-circle me-2"></i>Tambah Paket
                    </button>
                </div>

                <% if (success) { %>
                    <div class="alert alert-success alert-dismissible fade show">
                        <i class="bi bi-check-circle me-2"></i><%= success %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                <% } %>
                
                <% if (error) { %>
                    <div class="alert alert-danger alert-dismissible fade show">
                        <i class="bi bi-exclamation-triangle me-2"></i><%= error %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                <% } %>

                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-list-ul me-2"></i>Daftar Paket Member</h5>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table id="packagesTable" class="table table-striped table-hover">
                                <thead>
                                    <tr>
                                        <th>Nama Paket</th>
                                        <th>Kecepatan</th>
                                        <th>Harga</th>
                                        <th>PPN</th>
                                        <th>Hotspot Profile</th>
                                        <th>Status</th>
                                        <th>Aksi</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (packages && packages.length > 0) { %>
                                        <% packages.forEach(function(pkg) { %>
                                            <tr>
                                                <td><strong><%= pkg.name || '-' %></strong></td>
                                                <td><%= pkg.speed || '-' %></td>
                                                <td>Rp <%= parseFloat(pkg.price || 0).toLocaleString('id-ID') %></td>
                                                <td>
                                                    <% if (pkg.tax_rate === 0) { %>
                                                        <span class="badge bg-secondary">0%</span>
                                                    <% } else { %>
                                                        <span class="badge bg-warning"><%= (pkg.tax_rate || 11.00).toFixed(2) %>%</span>
                                                    <% } %>
                                                </td>
                                                <td><span class="badge bg-info"><%= pkg.hotspot_profile || 'default' %></span></td>
                                                <td>
                                                    <% if (pkg.is_active) { %>
                                                        <span class="badge bg-success">Aktif</span>
                                                    <% } else { %>
                                                        <span class="badge bg-secondary">Nonaktif</span>
                                                    <% } %>
                                                </td>
                                                <td>
                                                    <button class="btn btn-sm btn-primary" onclick="editPackage(<%= pkg.id %>)" title="Edit">
                                                        <i class="bi bi-pencil"></i>
                                                    </button>
                                                    <button class="btn btn-sm btn-danger" onclick="deletePackage(<%= pkg.id %>)" title="Hapus">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </td>
                                            </tr>
                                        <% }); %>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <!-- Add Package Modal -->
    <div class="modal fade" id="addPackageModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Tambah Paket Member</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form id="addPackageForm" method="POST" action="/admin/member/packages">
                    <div class="modal-body">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Nama Paket *</label>
                                <input type="text" class="form-control" name="name" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Kecepatan *</label>
                                <input type="text" class="form-control" name="speed" placeholder="Contoh: 10 Mbps" required>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Harga *</label>
                                <input type="number" class="form-control" name="price" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">PPN (%)</label>
                                <input type="number" class="form-control" name="tax_rate" value="11.00" step="0.01" min="0">
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Hotspot Profile</label>
                            <select class="form-select" name="hotspot_profile" id="add_hotspot_profile" required>
                                <option value="default">default</option>
                                <% if (hotspotProfiles && hotspotProfiles.length > 0) { %>
                                    <% hotspotProfiles.forEach(function(profile) { %>
                                        <% 
                                            const profileGroupname = profile.groupname || profile.id || 'default';
                                            const profileDisplayName = profile.name || profileGroupname;
                                        %>
                                        <option value="<%= profileGroupname %>"><%= profileDisplayName %></option>
                                    <% }); %>
                                <% } %>
                            </select>
                            <small class="text-muted">Profile hotspot yang akan digunakan untuk member (sinkron dari /admin/mikrotik/hotspot-profiles)</small>
                            <button type="button" class="btn btn-sm btn-outline-secondary mt-2" onclick="syncHotspotProfiles()">
                                <i class="bi bi-arrow-clockwise"></i> Sync Profile
                            </button>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Deskripsi</label>
                            <textarea class="form-control" name="description" rows="3"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
                        <button type="submit" class="btn btn-primary">Simpan</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Edit Package Modal -->
    <div class="modal fade" id="editPackageModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Edit Paket Member</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form id="editPackageForm" method="POST">
                    <div class="modal-body">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Nama Paket *</label>
                                <input type="text" class="form-control" id="edit_name" name="name" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Kecepatan *</label>
                                <input type="text" class="form-control" id="edit_speed" name="speed" required>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Harga *</label>
                                <input type="number" class="form-control" id="edit_price" name="price" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">PPN (%)</label>
                                <input type="number" class="form-control" id="edit_tax_rate" name="tax_rate" step="0.01" min="0">
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Hotspot Profile</label>
                            <select class="form-select" id="edit_hotspot_profile" name="hotspot_profile" required>
                                <option value="default">default</option>
                                <% if (hotspotProfiles && hotspotProfiles.length > 0) { %>
                                    <% hotspotProfiles.forEach(function(profile) { %>
                                        <% 
                                            const profileGroupname = profile.groupname || profile.id || 'default';
                                            const profileDisplayName = profile.name || profileGroupname;
                                        %>
                                        <option value="<%= profileGroupname %>"><%= profileDisplayName %></option>
                                    <% }); %>
                                <% } %>
                            </select>
                            <small class="text-muted">Profile hotspot yang akan digunakan untuk member (sinkron dari /admin/mikrotik/hotspot-profiles)</small>
                            <button type="button" class="btn btn-sm btn-outline-secondary mt-2" onclick="syncHotspotProfiles()">
                                <i class="bi bi-arrow-clockwise"></i> Sync Profile
                            </button>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Deskripsi</label>
                            <textarea class="form-control" id="edit_description" name="description" rows="3"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
                        <button type="submit" class="btn btn-primary">Update</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script>
        $(document).ready(function() {
            // Pastikan tabel sudah ada sebelum inisialisasi DataTables
            if ($('#packagesTable').length) {
                try {
                    $('#packagesTable').DataTable({
                        language: {
                            url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/id.json',
                            emptyTable: 'Belum ada paket member'
                        },
                        columnDefs: [
                            { orderable: false, targets: 6 } // Disable sorting on Aksi column
                        ],
                        autoWidth: false,
                        responsive: true,
                        paging: true,
                        searching: true,
                        info: true
                    });
                } catch (e) {
                    console.error('Error initializing DataTable:', e);
                }
            }
        });

        const packages = <%- JSON.stringify(packages || []) %>;

        function editPackage(id) {
            const pkg = packages.find(p => p.id == id);
            if (!pkg) return;
            
            $('#edit_name').val(pkg.name);
            $('#edit_speed').val(pkg.speed);
            $('#edit_price').val(pkg.price);
            $('#edit_tax_rate').val(pkg.tax_rate || 11.00);
            
            // Store original value for restore after sync
            const originalProfile = pkg.hotspot_profile || 'default';
            $('#edit_hotspot_profile').data('original-value', originalProfile);
            $('#edit_hotspot_profile').val(originalProfile);
            
            $('#edit_description').val(pkg.description || '');
            $('#editPackageForm').attr('action', '/admin/member/packages/' + id + '/update');
            
            new bootstrap.Modal(document.getElementById('editPackageModal')).show();
        }

        function deletePackage(id) {
            if (confirm('Apakah Anda yakin ingin menghapus paket ini?')) {
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = '/admin/member/packages/' + id + '/delete';
                document.body.appendChild(form);
                form.submit();
            }
        }

        // Fungsi untuk sync hotspot profiles dari RADIUS User Profile
        function syncHotspotProfiles() {
            const addSelect = document.getElementById('add_hotspot_profile');
            const editSelect = document.getElementById('edit_hotspot_profile');
            
            // Show loading
            if (addSelect) {
                addSelect.disabled = true;
                addSelect.innerHTML = '<option value="">Memuat...</option>';
            }
            if (editSelect) {
                editSelect.disabled = true;
                editSelect.innerHTML = '<option value="">Memuat...</option>';
            }
            
            fetch('/admin/member/packages/api/hotspot-profiles')
                .then(response => response.json())
                .then(data => {
                    if (data.success && data.profiles) {
                        // Update Add Package Modal dropdown
                        if (addSelect) {
                            let html = '<option value="default">default</option>';
                            data.profiles.forEach(profile => {
                                const profileGroupname = profile.groupname || profile.id || 'default';
                                const profileDisplayName = profile.name || profileGroupname;
                                html += `<option value="${profileGroupname}">${profileDisplayName}</option>`;
                            });
                            addSelect.innerHTML = html;
                            addSelect.disabled = false;
                        }
                        
                        // Update Edit Package Modal dropdown
                        if (editSelect) {
                            let html = '<option value="default">default</option>';
                            data.profiles.forEach(profile => {
                                const profileGroupname = profile.groupname || profile.id || 'default';
                                const profileDisplayName = profile.name || profileGroupname;
                                html += `<option value="${profileGroupname}">${profileDisplayName}</option>`;
                            });
                            editSelect.innerHTML = html;
                            editSelect.disabled = false;
                            
                            // Restore selected value if modal is open
                            const editModal = bootstrap.Modal.getInstance(document.getElementById('editPackageModal'));
                            if (editModal && editModal._isShown) {
                                const currentValue = $('#edit_hotspot_profile').data('original-value');
                                if (currentValue) {
                                    $('#edit_hotspot_profile').val(currentValue);
                                }
                            }
                        }
                        
                        // Show success message
                        alert('Profile hotspot berhasil di-sync dari RADIUS User Profile!');
                    } else {
                    alert('Gagal mengambil daftar profile dari RADIUS: ' + (data.message || 'Unknown error'));
                    // Restore default
                    if (addSelect) {
                        addSelect.innerHTML = '<option value="default">default</option>';
                        addSelect.disabled = false;
                    }
                    if (editSelect) {
                        editSelect.innerHTML = '<option value="default">default</option>';
                        editSelect.disabled = false;
                    }
                }
            })
            .catch(error => {
                console.error('Error syncing hotspot profiles from RADIUS:', error);
                alert('Gagal sync profile hotspot dari RADIUS: ' + error.message);
                    // Restore default
                    if (addSelect) {
                        addSelect.innerHTML = '<option value="default">default</option>';
                        addSelect.disabled = false;
                    }
                    if (editSelect) {
                        editSelect.innerHTML = '<option value="default">default</option>';
                        editSelect.disabled = false;
                    }
                });
        }

        // Auto-sync saat modal dibuka
        document.addEventListener('DOMContentLoaded', function() {
            const addModal = document.getElementById('addPackageModal');
            const editModal = document.getElementById('editPackageModal');
            
            if (addModal) {
                addModal.addEventListener('show.bs.modal', function() {
                    syncHotspotProfiles();
                });
            }
            
            if (editModal) {
                editModal.addEventListener('show.bs.modal', function() {
                    syncHotspotProfiles();
                });
            }
        });
    </script>
</body>
</html>

