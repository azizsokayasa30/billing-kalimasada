            // Export customers JSON (Desktop & Mobile)
            $('#exportCustomersJsonBtn, #exportCustomersJsonBtnMobile').on('click', function() {
                window.location.href = '/admin/billing/export/customers.json';
            });

            // Export customers XLSX (Desktop & Mobile)
            $('#exportCustomersXlsxBtn, #exportCustomersXlsxBtnMobile').on('click', function() {
                window.location.href = '/admin/billing/export/customers.xlsx';
            });

            const stripHtml = (html) => String(html || '').replace(/<br\s*\/?>/gi, ' ').replace(/<[^>]+>/g, '').replace(/\s+/g, ' ').trim();
            const sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));
            const composeImportDetails = (summary, errors) => {
                const s = summary || {};
                const created = Number(s.created || 0);
                const updated = Number(s.updated || 0);
                const failed = Number(s.failed || 0);
                const success = Number(s.success_count || (created + updated));
                const detailLines = [
                    `Total data: ${s.total || 0}`,
                    `Sukses diproses (create + update): ${success}`,
                    `Pelanggan baru (bertambah): ${created}`,
                    `Pelanggan existing terupdate: ${updated}`,
                    `Gagal: ${failed}`
                ];
                if (updated > 0) {
                    detailLines.push(`<small class="text-muted">Catatan: angka sukses termasuk data update, jadi kenaikan total pelanggan baru mengikuti nilai "Pelanggan baru (bertambah)".</small>`);
                }
                if (s.radius_sync) {
                    const r = s.radius_sync || {};
                    detailLines.push(`<br><strong>Sinkron PPPoE ke RADIUS</strong>`);
                    detailLines.push(`Dicoba sync: ${r.attempted || 0}`);
                    detailLines.push(`Berhasil sync: ${r.success || 0}`);
                    detailLines.push(`Gagal sync: ${r.failed || 0}`);
                    detailLines.push(`Dilewati: ${r.skipped || 0}`);
                }
                if (failed > 0 && errors && errors.length) {
                    const contohError = errors.slice(0, 15).map(e => {
                        const rowInfo = `Baris ${e.row || '-'}`;
                        const nameInfo = e.name ? ` | Nama: ${e.name}` : '';
                        const phoneInfo = e.phone ? ` | HP: ${e.phone}` : '';
                        return `${rowInfo}${nameInfo}${phoneInfo}: ${e.error}`;
                    }).join('<br>');
                    detailLines.push(`<br><strong>Contoh error:</strong><br>${contohError}`);
                }
                return detailLines.join('<br>');
            };
            const recoverImportResult = async ({ sourceType, sinceMs, maxAttempts = 8, intervalMs = 2000 }) => {
                for (let attempt = 0; attempt < maxAttempts; attempt++) {
                    try {
                        const qs = new URLSearchParams({
                            source_type: String(sourceType || '').toLowerCase(),
                            since_ms: String(sinceMs || 0),
                            max_age_sec: '3600'
                        });
                        const resp = await fetch(`/admin/billing/import/customers/last-operation?${qs.toString()}`, { cache: 'no-store' });
                        if (resp.ok) {
                            const payload = await resp.json();
                            if (payload && payload.success && payload.found && payload.operation) {
                                return payload.operation;
                            }
                        }
                    } catch (_) {
                        // keep retrying, likely server still processing
                    }
                    await sleep(intervalMs);
                }
                return null;
            };
            const pollCommitJobStatus = async ({ jobId, maxAttempts = 900, intervalMs = 1000, onProgress }) => {
                let transientErrorCount = 0;
                for (let i = 0; i < maxAttempts; i++) {
                    try {
                        const resp = await fetch(`/admin/billing/import/customers/commit-status/${encodeURIComponent(jobId)}`, {
                            cache: 'no-store'
                        });
                        const raw = await resp.text();
                        let payload = null;
                        try {
                            payload = raw ? JSON.parse(raw) : null;
                        } catch (_) {
                            payload = null;
                        }
                        if (!resp.ok || !payload) {
                            throw new Error((payload && (payload.message || payload.error)) || (raw && raw.slice(0, 300)) || `HTTP ${resp.status}`);
                        }

                        transientErrorCount = 0;
                        if (typeof onProgress === 'function' && payload.progress) {
                            onProgress(payload.progress, payload.status);
                        }
                        if (payload.status === 'finished') {
                            return payload;
                        }
                        if (payload.status === 'failed') {
                            throw new Error(payload.message || 'Job import gagal');
                        }
                    } catch (pollError) {
                        transientErrorCount += 1;
                        // Tolerate temporary network hiccups during long imports.
                        if (transientErrorCount >= 20) {
                            throw new Error(`Koneksi ke server tidak stabil saat membaca status import (${transientErrorCount}x gagal berturut-turut).`);
                        }
                    }
                    await sleep(intervalMs);
                }
                throw new Error('Proses import terlalu lama atau timeout saat polling status');
            };
            const openImportResultDialog = (options) => {
                try {
                    showImportDecisionDialog(options);
                    return true;
                } catch (dialogError) {
                    console.error('Gagal menampilkan dialog hasil import:', dialogError);
                    return false;
                }
            };

            let stagedImportData = null;
            const fileInput = document.getElementById('customersFile');
            const stageSummary = document.getElementById('importStageSummary');
            const stageBtn = document.getElementById('stageCustomersBtn');
            const commitBtn = document.getElementById('commitImportBtn');
            const importProgressWrap = document.getElementById('importProgressWrap');
            const importProgressBar = document.getElementById('importProgressBar');
            const importProgressLabel = document.getElementById('importProgressLabel');
            const importProgressValue = document.getElementById('importProgressValue');
            let importProgressTimer = null;

            const setProgress = (value, label, colorClass = 'bg-success') => {
                const pct = Math.min(100, Math.max(0, Number(value) || 0));
                importProgressWrap.classList.remove('d-none');
                importProgressBar.classList.remove('bg-warning', 'bg-success', 'bg-danger', 'bg-info');
                importProgressBar.classList.add(colorClass);
                importProgressBar.style.width = `${pct}%`;
                const solidColor =
                    colorClass === 'bg-danger' ? '#dc3545' :
                    colorClass === 'bg-info' ? '#0dcaf0' :
                    '#16a34a';
                importProgressBar.style.setProperty('background-color', solidColor, 'important');
                importProgressBar.style.setProperty('background-image', 'none', 'important');
                importProgressBar.style.setProperty('box-shadow', 'none', 'important');
                importProgressBar.setAttribute('aria-valuenow', String(pct));
                importProgressValue.textContent = `${Math.round(pct)}%`;
                if (label) importProgressLabel.textContent = label;
            };
            const startProgress = ({ from = 0, to = 85, step = 4, everyMs = 450, label = 'Memproses...' } = {}) => {
                if (importProgressTimer) clearInterval(importProgressTimer);
                setProgress(from, label, 'bg-success');
                importProgressTimer = setInterval(() => {
                    const current = Number(importProgressBar.getAttribute('aria-valuenow') || 0);
                    const next = Math.min(to, current + step);
                    setProgress(next, label, 'bg-success');
                    if (next >= to) {
                        clearInterval(importProgressTimer);
                        importProgressTimer = null;
                    }
                }, everyMs);
            };
            const finishProgress = (success, label) => {
                if (importProgressTimer) {
                    clearInterval(importProgressTimer);
                    importProgressTimer = null;
                }
                setProgress(100, label || (success ? 'Selesai' : 'Gagal'), success ? 'bg-success' : 'bg-danger');
                importProgressBar.classList.remove('progress-bar-animated');
            };
            const resetProgress = () => {
                if (importProgressTimer) {
                    clearInterval(importProgressTimer);
                    importProgressTimer = null;
                }
                importProgressWrap.classList.add('d-none');
                importProgressBar.classList.add('progress-bar-animated');
                setProgress(0, 'Menunggu proses...', 'bg-success');
                importProgressWrap.classList.add('d-none');
            };

            const resetImportStageState = () => {
                stagedImportData = null;
                commitBtn.disabled = true;
                stageSummary.classList.add('d-none');
                stageSummary.classList.remove('alert-success', 'alert-warning', 'alert-danger');
                stageSummary.classList.add('alert-secondary');
                stageSummary.innerHTML = '';
                resetProgress();
            };

            resetImportStageState();
            fileInput.addEventListener('change', resetImportStageState);
            $('#importCustomersModal').on('hidden.bs.modal', function() {
                resetImportStageState();
            });
            $('#importCustomersForm').on('submit', function(e) {
                e.preventDefault();
            });

            stageBtn.addEventListener('click', async function() {
                if (!fileInput.files || fileInput.files.length === 0) {
                    showToast('error', 'Silakan pilih file JSON/XLSX terlebih dahulu');
                    return;
                }

                const formData = new FormData();
                formData.append('file', fileInput.files[0]);

                const originalText = stageBtn.innerHTML;
                stageBtn.disabled = true;
                commitBtn.disabled = true;
                stageBtn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Uploading...';
                startProgress({ from: 8, to: 70, step: 8, everyMs: 350, label: 'Upload file ke server...' });

                try {
                    const resp = await fetch('/admin/billing/import/customers/stage', {
                        method: 'POST',
                        body: formData
                    });
                    const raw = await resp.text();
                    let data = null;
                    try {
                        data = raw ? JSON.parse(raw) : null;
                    } catch (_) {
                        data = null;
                    }
                    if (!resp.ok || !data || !data.success) {
                        throw new Error((data && (data.message || data.error)) || (raw && raw.slice(0, 400)) || `HTTP ${resp.status}`);
                    }

                    stagedImportData = {
                        stage_id: data.stage_id,
                        source_type: data.source_type,
                        total_rows: Number(data.total_rows || 0)
                    };
                    commitBtn.disabled = false;
                    stageSummary.classList.remove('d-none', 'alert-secondary', 'alert-danger');
                    stageSummary.classList.add('alert-success');
                    stageSummary.innerHTML = `
                        <strong>Upload berhasil.</strong><br>
                        File: ${data.original_name || '-'}<br>
                        Jenis: ${(data.source_type || '-').toUpperCase()}<br>
                        Jumlah data terdeteksi: ${stagedImportData.total_rows}
                    `;
                    finishProgress(true, 'Upload selesai');
                    showToast('success', 'Upload berhasil', `Data terdeteksi: ${stagedImportData.total_rows} pelanggan`);
                } catch (err) {
                    const errMessage = String(err.message || 'Unknown error');
                    stageSummary.classList.remove('d-none', 'alert-secondary', 'alert-success');
                    stageSummary.classList.add('alert-danger');
                    stageSummary.innerHTML = `<strong>Upload gagal.</strong> ${errMessage}`;
                    finishProgress(false, 'Upload gagal');
                    showToast('error', 'Upload gagal', errMessage);
                } finally {
                    stageBtn.disabled = false;
                    stageBtn.innerHTML = originalText;
                }
            });

            commitBtn.addEventListener('click', async function() {
                if (!stagedImportData || !stagedImportData.stage_id) {
                    showToast('warning', 'Silakan upload file dulu sebelum import');
                    return;
                }

                const originalCommitText = commitBtn.innerHTML;
                const importStartedAt = Date.now();
                commitBtn.disabled = true;
                stageBtn.disabled = true;
                commitBtn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Importing...';
                startProgress({ from: 12, to: 92, step: 3, everyMs: 500, label: 'Import data pelanggan...' });

                try {
                    const resp = await fetch(`/admin/billing/import/customers/commit/${encodeURIComponent(stagedImportData.stage_id)}`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({})
                    });
                    const raw = await resp.text();
                    let data = null;
                    try {
                        data = raw ? JSON.parse(raw) : null;
                    } catch (_) {
                        data = null;
                    }
                    if (!resp.ok || !data || !data.success) {
                        throw new Error((data && (data.message || data.error)) || (raw && raw.slice(0, 400)) || `HTTP ${resp.status}`);
                    }
                    if (!data.job_id) {
                        throw new Error('Job import tidak terbentuk. Silakan coba lagi.');
                    }

                    setProgress(96, 'Menunggu proses import di server...', 'bg-success');
                    const finalData = await pollCommitJobStatus({
                        jobId: data.job_id,
                        onProgress: (progress) => {
                            const total = Number(progress.total_rows || 0);
                            const processed = Number(progress.processed_rows || 0);
                            const success = Number(progress.success_rows || 0);
                            const failed = Number(progress.failed_rows || 0);
                            const pct = Number(progress.percentage || 0);
                            const label = total > 0
                                ? `Import pelanggan: ${processed}/${total} diproses, berhasil ${success}, gagal ${failed}`
                                : `Import pelanggan: diproses ${processed}, berhasil ${success}, gagal ${failed}`;
                            setProgress(Math.min(99, Math.max(1, pct)), label, 'bg-success');
                        }
                    });
                    data = finalData;

                    const s = data.summary || {};
                    const hasFailures = (s.failed || 0) > 0;
                    const hasSuccess = ((s.created || 0) + (s.updated || 0)) > 0;
                    const title = hasFailures ? 'Import selesai dengan kegagalan' : 'Import berhasil';
                    const detailsHtml = composeImportDetails(s, data.errors || []);
                    const modalShown = openImportResultDialog({
                        title,
                        detailsHtml,
                        operationId: data.operation_id || null,
                        canRevert: Boolean(stagedImportData.source_type === 'xlsx' && hasFailures && hasSuccess && data.operation_id)
                    });
                    if (!modalShown) {
                        showToast(hasFailures ? 'warning' : 'success', title, stripHtml(detailsHtml));
                    }
                    finishProgress(true, hasFailures ? 'Import selesai (dengan beberapa kegagalan)' : 'Import selesai');
                    $('#importCustomersModal').modal('hide');
                } catch (err) {
                    const errMessage = String(err.message || 'Unknown error');
                    const looksLikeNetworkFailure =
                        /failed to fetch/i.test(errMessage) ||
                        /networkerror/i.test(errMessage) ||
                        /load failed/i.test(errMessage);

                    if (looksLikeNetworkFailure) {
                        startProgress({ from: 92, to: 98, step: 1, everyMs: 600, label: 'Menyinkronkan hasil import...' });
                        const recoveredOp = await recoverImportResult({
                            sourceType: stagedImportData.source_type,
                            sinceMs: importStartedAt
                        });
                        if (recoveredOp && recoveredOp.summary) {
                            const s = recoveredOp.summary;
                            const hasFailures = (s.failed || 0) > 0;
                            const hasSuccess = ((s.created || 0) + (s.updated || 0)) > 0;
                            const title = hasFailures
                                ? 'Import selesai (koneksi sempat terputus)'
                                : 'Import berhasil (koneksi sempat terputus)';
                            const detailsHtml = composeImportDetails(s, []);
                            const modalShown = openImportResultDialog({
                                title,
                                detailsHtml,
                                operationId: recoveredOp.id || null,
                                canRevert: Boolean(stagedImportData.source_type === 'xlsx' && hasFailures && hasSuccess && recoveredOp.id)
                            });
                            if (!modalShown) {
                                showToast(hasFailures ? 'warning' : 'success', title, stripHtml(detailsHtml));
                            }
                            finishProgress(true, 'Sinkronisasi hasil selesai');
                            $('#importCustomersModal').modal('hide');
                            return;
                        }
                    }

                    const fallbackDetails = `Terjadi kesalahan saat import.<br><strong>Detail:</strong> ${errMessage}`;
                    const modalShown = openImportResultDialog({
                        title: 'Import gagal',
                        detailsHtml: fallbackDetails,
                        operationId: null,
                        canRevert: false
                    });
                    if (!modalShown) {
                        showToast('error', 'Import gagal', errMessage);
                    }
                    finishProgress(false, 'Import gagal');
                } finally {
                    commitBtn.innerHTML = originalCommitText;
                    stageBtn.disabled = false;
                    commitBtn.disabled = false;
                }
            });
        });

        function showImportDecisionDialog({ title, detailsHtml, operationId, canRevert }) {
            const existing = document.getElementById('importDecisionModal');
            if (existing) existing.remove();

            const modalHtml = `
                <div class="modal fade" id="importDecisionModal" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">${title}</h5>
                            </div>
                            <div class="modal-body">
                                <div class="alert ${canRevert ? 'alert-warning' : 'alert-success'} mb-0">
                                    ${detailsHtml}
                                </div>
                            </div>
                            <div class="modal-footer">
                                ${canRevert ? '<button type="button" class="btn btn-outline-danger" id="btnRevertImport">Revert</button>' : ''}
                                <button type="button" class="btn btn-primary" id="btnSubmitImport">Submit</button>
                            </div>
                        </div>
                    </div>
                </div>
            `;

            document.body.insertAdjacentHTML('beforeend', modalHtml);
            const el = document.getElementById('importDecisionModal');
            const modal = new bootstrap.Modal(el, { backdrop: 'static', keyboard: false });

            el.querySelector('#btnSubmitImport').addEventListener('click', function () {
                modal.hide();
                location.reload();
            });

            const revertBtn = el.querySelector('#btnRevertImport');
            if (revertBtn) {
                revertBtn.addEventListener('click', async function () {
                    if (!operationId) {
                        showToast('error', 'Operation ID tidak ditemukan, tidak bisa revert.');
                        return;
                    }
                    const original = revertBtn.innerHTML;
                    revertBtn.disabled = true;
                    revertBtn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Reverting...';
                    try {
                        const resp = await fetch(`/admin/billing/import/customers/revert/${encodeURIComponent(operationId)}`, {
                            method: 'POST'
                        });
                        const data = await resp.json();
                        if (!data.success) throw new Error(data.message || 'Gagal revert');
                        const s = data.summary || {};
                        showToast('success', `Revert berhasil. Created dibatalkan: ${s.reverted_created || 0}, Updated dipulihkan: ${s.reverted_updated || 0}`);
                        modal.hide();
                        location.reload();
                    } catch (err) {
                        showToast('error', err.message || 'Terjadi kesalahan saat revert');
                    } finally {
                        revertBtn.disabled = false;
                        revertBtn.innerHTML = original;
                    }
                });
            }

            el.addEventListener('hidden.bs.modal', () => {
                // Prevent modal from disappearing tanpa aksi explicit submit/revert
                // Jika ditutup secara paksa via script/browser, tampilkan lagi.
                if (document.body.contains(el)) {
                    el.remove();
                }
            });

            modal.show();
        }

