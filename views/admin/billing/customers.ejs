        // Add Customer Form
        let addCustomerSubmitMode = 'save_only';
        $('#addCustomerForm button[type="submit"]').on('click', function() {
            addCustomerSubmitMode = $(this).data('submit-mode') || 'save_only';
        });

        $('#addCustomerForm').on('submit', function(e) {
            e.preventDefault();

            const safeValAdd = (sel) => {
                const $el = $(sel);
                if (!$el.length) return '';
                const v = $el.val();
                return v !== null && v !== undefined ? String(v).trim() : '';
            };
            const safeIntAdd = (sel) => {
                const v = safeValAdd(sel);
                return v ? parseInt(v, 10) : '';
            };
            
            // Client-side validation
            const name = $('#addCustomerModal #name').val().trim().toUpperCase();
            const username = $('#username').val().trim();
            const phone = $('#phone').val().trim();
            const package_id = $('#package_id').val();
            const area_id = safeValAdd('#area_id');
            const address = safeValAdd('#address');
            const createPppoe = $('#create_pppoe_user').is(':checked');
            const pppoeUser = $('#pppoe_username').val().trim();
            const addBillingOnlyPkg = $('#package_id option:selected').attr('data-billing-only') === '1';
            
            if (!name || !username || !phone || !package_id) {
                showToast('error', 'Nama, username, telepon, dan paket wajib diisi');
                return;
            }
            if (!area_id || !address) {
                showToast('error', 'Area dan alamat wajib diisi (dipakai untuk job instalasi)');
                return;
            }
            
            // Validate username format
            if (!/^[a-z0-9_]+$/.test(username)) {
                showToast('error', 'Username hanya boleh berisi huruf kecil, angka, dan underscore');
                return;
            }
            if (createPppoe && !addBillingOnlyPkg && !pppoeUser) {
                showToast('error', 'Isi PPPoE Username jika ingin membuat user di Mikrotik');
                return;
            }
            
            // Show loading state
            const submitBtn = $(this).find('button[type="submit"]');
            const originalText = submitBtn.text();
            submitBtn.prop('disabled', true).text('Menyimpan...');
            
            const staticIpEnabled = $('#toggle_static_ip').is(':checked');

            // Create FormData for file upload
            const formData = new FormData();
            formData.append('name', name);
            formData.append('username', username);
            formData.append('phone', phone);
            formData.append('email', safeValAdd('#email'));
            formData.append('password', safeValAdd('#password'));
            formData.append('pppoe_username', pppoeUser);
            formData.append('area_id', safeValAdd('#area_id'));
            formData.append('area', $('#area_id option:selected').text().trim() || safeValAdd('#area'));
            formData.append('address', safeValAdd('#address'));
            formData.append('package_id', package_id);
            formData.append('odp_id', safeValAdd('#odp_id'));
            formData.append('pppoe_profile', addBillingOnlyPkg ? '' : (safeValAdd('#pppoe_profile') || 'default'));
            formData.append('auto_suspension', safeValAdd('#auto_suspension'));
            formData.append('create_pppoe_user', createPppoe ? 1 : 0);
            formData.append('pppoe_password', safeValAdd('#pppoe_password'));
            formData.append('billing_day', (function() {
                const v = parseInt($('#billing_day').val(), 10);
                if (Number.isFinite(v)) return Math.min(Math.max(v, 1), 28);
                return 15;
            })());
            formData.append('renewal_type', safeValAdd('#renewal_type'));
            formData.append('fix_date', safeValAdd('#renewal_type') === 'fix_date' ? (function() {
                const v = parseInt($('#fix_date').val(), 10);
                if (Number.isFinite(v)) return Math.min(Math.max(v, 1), 28);
                return 15;
            })() : '');
            formData.append('latitude', safeValAdd('#latitude'));
            formData.append('longitude', safeValAdd('#longitude'));
