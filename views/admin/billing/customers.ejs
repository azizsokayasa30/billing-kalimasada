        // Load PPPoE users from Mikrotik
        function loadPppoeUsers() {
            const loadBtn = $('#loadPppoeUsers');
            const originalIcon = loadBtn.html();
            
            // Show loading state
            loadBtn.prop('disabled', true).html('<i class="bi bi-arrow-clockwise spin"></i>');
            
            console.log('ðŸ”„ Loading PPPoE users from RADIUS Server...');
            
            fetch('/admin/billing/api/pppoe-users')
                .then(response => {
                    console.log('ðŸ“¡ API Response status:', response.status);
                    return response.json();
                })
                .then(data => {
                    console.log('ðŸ“Š API Response data:', data);

                    if (data.success && Array.isArray(data.data)) {
                        pppoeUsers = data.data;
                        filteredPppoeUsers = [...pppoeUsers];
                        console.log(`ðŸ“ Loaded ${pppoeUsers.length} users to memory`);
                        if (pppoeUsers.length > 0) {
                            showToast('success', `Loaded ${pppoeUsers.length} PPPoE users from RADIUS Server`);
                        } else {
                            showToast('warning', 'Tidak ada user PPPoE di database RADIUS (0 hasil). Periksa Pengaturan RADIUS: nama database harus sama file yang dipakai FreeRADIUS (mis. radius).');
                        }
                    } else {
                        pppoeUsers = [];
                        filteredPppoeUsers = [];
                        console.warn('API PPPoE: respons tidak sukses', data);
                        showToast('error', (data && data.message) ? data.message : 'Gagal memuat daftar PPPoE dari server');
                    }
                })
                .catch(error => {
                    console.error('âŒ Fetch Error:', error);
                    pppoeUsers = [];
                    filteredPppoeUsers = [];
                    showToast('error', 'Gagal menghubungi API PPPoE: ' + (error && error.message ? error.message : 'periksa jaringan atau log server'));
                })
                .finally(() => {
                    // Restore button state
                    loadBtn.prop('disabled', false).html(originalIcon);
                });
        }
        
