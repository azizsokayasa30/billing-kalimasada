        // Add Customer Form
        $('#addCustomerForm').on('submit', function(e) {
            e.preventDefault();
            
            // Client-side validation
            const name = $('#name').val().trim();
            const username = $('#username').val().trim();
            const phone = $('#phone').val().trim();
            const package_id = $('#package_id').val();
            const createPppoe = $('#create_pppoe_user').is(':checked');
            const pppoeUser = $('#pppoe_username').val().trim();
            
            if (!name || !username || !phone || !package_id) {
                showToast('error', 'Nama, username, telepon, dan paket wajib diisi');
                return;
            }
            
            // Validate username format
            if (!/^[a-z0-9_]+$/.test(username)) {
                showToast('error', 'Username hanya boleh berisi huruf kecil, angka, dan underscore');
                return;
            }
            if (createPppoe && !pppoeUser) {
                showToast('error', 'Isi PPPoE Username jika ingin membuat user di Mikrotik');
                return;
            }
            
            // Show loading state
            const submitBtn = $(this).find('button[type="submit"]');
            const originalText = submitBtn.text();
            submitBtn.prop('disabled', true).text('Menyimpan...');
            
            // Create a safe value extractor helper to avoid TypeError on undefined elements
            const safeValAdd = (sel) => {
                const $el = $(sel);
                if (!$el.length) return '';
                const v = $el.val();
                return v !== null && v !== undefined ? String(v).trim() : '';
            };
            const safeIntAdd = (sel) => {
                const v = safeValAdd(sel);
                return v ? parseInt(v, 10) : '';
            };

            // Create FormData for file upload
            const formData = new FormData();
            formData.append('name', name);
            formData.append('username', username);
            formData.append('phone', phone);
            formData.append('email', safeValAdd('#email'));
            formData.append('password', safeValAdd('#password'));
            formData.append('pppoe_username', pppoeUser);
            formData.append('area_id', safeValAdd('#area_id'));
            formData.append('area', $('#area_id option:selected').text().trim() || safeValAdd('#area'));
            formData.append('address', safeValAdd('#address'));
            formData.append('package_id', package_id);
            formData.append('odp_id', safeValAdd('#odp_id'));
            formData.append('pppoe_profile', safeValAdd('#pppoe_profile') || 'default');
            formData.append('auto_suspension', safeValAdd('#auto_suspension'));
            formData.append('create_pppoe_user', createPppoe ? 1 : 0);
            formData.append('pppoe_password', safeValAdd('#pppoe_password'));
            formData.append('billing_day', (function() {
                const v = parseInt($('#billing_day').val(), 10);
                if (Number.isFinite(v)) return Math.min(Math.max(v, 1), 28);
                return 15;
            })());
            formData.append('renewal_type', safeValAdd('#renewal_type'));
            formData.append('fix_date', safeValAdd('#renewal_type') === 'fix_date' ? (function() {
                const v = parseInt($('#fix_date').val(), 10);
                if (Number.isFinite(v)) return Math.min(Math.max(v, 1), 28);
                return 15;
            })() : '');
            formData.append('latitude', safeValAdd('#latitude'));
            formData.append('longitude', safeValAdd('#longitude'));
            formData.append('static_ip', safeValAdd('#static_ip'));
            formData.append('assigned_ip', safeValAdd('#assigned_ip'));
            formData.append('mac_address', safeValAdd('#mac_address'));
            formData.append('cable_type', safeValAdd('#cable_type'));
            formData.append('cable_length', safeIntAdd('#cable_length'));
            formData.append('port_number', safeIntAdd('#port_number'));
            formData.append('cable_status', safeValAdd('#cable_status') || 'connected');
            formData.append('cable_notes', safeValAdd('#cable_notes'));
            formData.append('router_id', safeValAdd('#router_id'));
            
            // Append photo files if selected
            const ktpPhoto = $('#add_ktp_photo')[0].files[0];
            const housePhoto = $('#add_house_photo')[0].files[0];
            if (ktpPhoto) {
                formData.append('ktp_photo', ktpPhoto);
            }
            if (housePhoto) {
                formData.append('house_photo', housePhoto);
            }
            
            fetch('/admin/billing/customers', {
                method: 'POST',
                body: formData
            })
            .then(response => {
                if (!response.ok) {
                    return response.json().then(err => {
                        throw err;
                    });
                }
                return response.json();
            })
            .then(data => {
                if (data.success) {
                    setTimeout(() => {
                        showToast('success', 'Pelanggan berhasil ditambahkan');
                        setTimeout(() => location.reload(), 1000);
                    }, 300);
                } else {
                    // Tampilkan error message dengan details jika ada
                    const errorMsg = data.message || 'Gagal menambahkan pelanggan';
                    const errorDetails = data.details || '';
                    const fullMessage = errorDetails ? `${errorMsg}\n\n${errorDetails}` : errorMsg;
                    showToast('error', errorMsg, errorDetails);
                }
            })
            .catch(error => {
                console.error('Error:', error);
                // Handle error response dengan details
                if (error.details) {
                    showToast('error', error.message || 'Terjadi kesalahan', error.details);
                } else {
                    showToast('error', error.message || 'Terjadi kesalahan saat menambahkan pelanggan');
                }
            })
            .finally(() => {
                submitBtn.prop('disabled', false).text(originalText);
            });
        });

