        // Function to update profile field when package is selected
        function updateProfileField() {
            const packageSelect = document.getElementById('package_id');
            const profileInput = document.getElementById('pppoe_profile');
            if (!packageSelect || !profileInput) return;
            const selectedOption = packageSelect.options[packageSelect.selectedIndex];
            const billingOnly = selectedOption && selectedOption.getAttribute('data-billing-only') === '1';

            const pppoeBlock = document.getElementById('addCustomerPppoeBlock');
            const nasProfBlock = document.getElementById('addCustomerPppoeProfileNasBlock');
            if (pppoeBlock) pppoeBlock.style.display = billingOnly ? 'none' : '';
            if (nasProfBlock) nasProfBlock.style.display = billingOnly ? 'none' : '';

            const createCb = document.getElementById('create_pppoe_user');
            if (createCb) {
                createCb.checked = !billingOnly;
                createCb.disabled = billingOnly;
            }

            if (billingOnly) {
                profileInput.value = '';
                const pu = document.getElementById('pppoe_username');
                if (pu) pu.value = '';
            } else if (selectedOption && selectedOption.dataset.profile) {
                profileInput.value = selectedOption.dataset.profile;
            }
        }

        // Function to update profile field in edit modal
        function updateEditProfileField() {
            const packageSelect = document.getElementById('edit_package_id');
            const profileInput = document.getElementById('edit_pppoe_profile');
            if (!packageSelect || !profileInput) return;
            const selectedOption = packageSelect.options[packageSelect.selectedIndex];
