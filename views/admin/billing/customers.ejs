                                    <% packages.forEach(function(package) { %>
                                        <option value="<%= package.id %>" 
                                                data-profile="<%= (package.pppoe_profile && String(package.pppoe_profile).trim() !== '') ? package.pppoe_profile : '' %>"
                                                data-billing-only="<%= (package.pppoe_profile && String(package.pppoe_profile).trim() !== '') ? '0' : '1' %>"
                                                data-router-id="<%= package.router_id || '' %>"
                                                style="display: none;"><%= package.name %> - Rp <%= parseFloat(package.price).toLocaleString('id-ID') %></option>
