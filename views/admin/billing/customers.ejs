        // Final clean function: username nama+DDMMYY WIB, email compact@gmail.com; hormati edit manual & autofill per huruf
        function generateCredentialsFromName() {
            try {
                const nameField = document.querySelector('#addCustomerModal #name');
                const usernameField = document.querySelector('#addCustomerModal #username');
                const emailField = document.querySelector('#addCustomerModal #email');

                if (nameField && nameField.value) {
                    const fullName = nameField.value;

                    const jakartaParts = new Intl.DateTimeFormat('en-GB', {
                        timeZone: 'Asia/Jakarta',
                        day: '2-digit',
                        month: '2-digit',
                        year: '2-digit'
                    }).formatToParts(new Date());
                    const pickJakarta = (t) => (jakartaParts.find((x) => x.type === t) || {}).value || '00';
                    const dateStr = pickJakarta('day') + pickJakarta('month') + pickJakarta('year');

                    let compact = '';
                    for (let i = 0; i < fullName.length; i++) {
                        const char = fullName[i].toLowerCase();
                        if ((char >= 'a' && char <= 'z') || (char >= '0' && char <= '9')) {
                            compact += char;
                        }
                    }
                    if (!compact) {
                        compact = 'user';
                    }

                    const canAutoUsername =
                        usernameField &&
                        usernameField.dataset.manual !== '1' &&
                        (!String(usernameField.value || '').trim() ||
                            usernameField.dataset.autofillFromName === '1');
                    if (canAutoUsername) {
                        usernameField.value = compact + '_' + dateStr;
                        usernameField.dataset.autofillFromName = '1';
                    }

                    const passwordField = document.getElementById('password');
                    if (passwordField && !String(passwordField.value || '').trim()) {
                        passwordField.value = '123456';
                    }

                    const canAutoEmail =
                        emailField &&
                        emailField.dataset.manual !== '1' &&
                        (!String(emailField.value || '').trim() ||
                            emailField.dataset.autofillFromName === '1');
                    if (canAutoEmail) {
                        emailField.value = compact + '@gmail.com';
                        emailField.dataset.autofillFromName = '1';
                    }
                }
            } catch (error) {
                console.error('Error in generateCredentialsFromName:', error);
            }
        }

        function generateUsernameFromName() {
            generateCredentialsFromName();
        }
        
        function generateEmailFromName() {
            generateCredentialsFromName();
        }

