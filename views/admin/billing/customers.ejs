                customerName: name,
                status: 'unpaid',
                amount: 0,
                dueDate: new Date().toISOString().split('T')[0],
                invoiceNumber: `CUST-${Date.now()}`,
                packageName: 'Paket Internet'
            };
            
            // Show modal
            $('#whatsappModal').modal('show');
