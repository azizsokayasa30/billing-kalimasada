                <script>
                    (function forceSolidSummaryCards() {
                        const gradients = [
                            'linear-gradient(135deg, #6366f1, #4f46e5)',
                            'linear-gradient(135deg, #22c55e, #16a34a)',
                            'linear-gradient(135deg, #ef4444, #dc2626)',
                            'linear-gradient(135deg, #10b981, #059669)',
                            'linear-gradient(135deg, #f59e0b, #d97706)',
                            'linear-gradient(135deg, #06b6d4, #0891b2)'
                        ];

                        function apply() {
                            const cards = document.querySelectorAll('.summary-cards-solid .summary-card');
                            cards.forEach((card, idx) => {
                                const gradient = gradients[idx % gradients.length];
                                card.style.setProperty('background', gradient, 'important');
                                card.style.setProperty('background-image', gradient, 'important');
                                card.style.setProperty('background-color', 'transparent', 'important');
                                card.style.setProperty('border', '0', 'important');
                                card.style.setProperty('border-radius', '12px', 'important');

                                const body = card.querySelector('.card-body');
                                if (body) {
                                    body.style.setProperty('background', gradient, 'important');
                                    body.style.setProperty('background-image', gradient, 'important');
                                    body.style.setProperty('background-color', 'transparent', 'important');
                                    body.style.setProperty('border-radius', '12px', 'important');
                                    body.style.setProperty('color', '#fff', 'important');
                                }

                                card.querySelectorAll('h3, p, i').forEach((el) => {
                                    el.style.setProperty('color', '#fff', 'important');
                                });

                                card.querySelectorAll('.rounded-circle').forEach((bubble) => {
                                    bubble.style.setProperty('background', 'rgba(255,255,255,0.22)', 'important');
                                });
                            });
                        }

                        if (document.readyState === 'loading') {
                            document.addEventListener('DOMContentLoaded', apply);
                        } else {
                            apply();
                        }
                        window.addEventListener('load', apply);
                    })();
                </script>

