        // Confirm send WhatsApp notification
        document.getElementById('confirmSendWA').addEventListener('click', function() {
            if (!currentNotificationData) return;

            const btn = this;
            const originalText = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<i class="bi bi-circle bx-spin"></i> Mengirim...';

            fetch('/admin/billing/invoices/send-whatsapp', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify(currentNotificationData)
            })
            .then(response => {
                return response.json().then(data => ({ response, data }));
            })
            .then(({ response, data }) => {
                if (data.success) {
                    showToast('success', 'Notifikasi Terkirim', 'Notifikasi WhatsApp berhasil dikirim');
                    $('#whatsappModal').modal('hide');
                } else {
                    showToast('error', 'Gagal Mengirim', data.message || 'Gagal mengirim notifikasi WhatsApp');
                }
            })
            .catch(error => {
                console.error('Error sending WhatsApp notification:', error);
                showToast('error', 'Error', 'Terjadi kesalahan saat mengirim notifikasi');
            })
            .finally(() => {
                // Reset button
                btn.disabled = false;
                btn.innerHTML = originalText;
            });
        });
    </script>

