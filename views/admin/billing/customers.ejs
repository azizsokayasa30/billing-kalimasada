                                    <textarea class="form-control form-control-sm" id="edit_cable_notes" name="cable_notes" rows="2" placeholder="Opsional"></textarea>
                                </div>
                                <small class="text-muted"><i class="bi bi-info-circle me-1"></i>Jika ODP dipilih, sistem membuat jalur kabel otomatis (cek kapasitas port).</small>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label for="edit_area_id" class="form-label">Area / wilayah <span class="text-danger">(wajib diisi)</span></label>
                            <select class="form-select" id="edit_area_id" name="area_id" required>
                                <option value="">-- Pilih Area --</option>
