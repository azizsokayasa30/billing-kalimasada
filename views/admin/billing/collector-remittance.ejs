<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('../../partials/hard-reload') %>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Terima Setoran Kolektor - <%= appSettings.companyHeader %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link href="/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
    <link href="/css/admin-mobile.css" rel="stylesheet">
    <link href="/css/finance-modern.css" rel="stylesheet">
    <style>
        .collector-selectable-card {
            cursor: pointer;
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
            border: 1px solid var(--f-border);
            position: relative;
            overflow: hidden;
        }
        .collector-selectable-card:hover {
            transform: translateY(-2px);
            border-color: var(--f-primary);
            box-shadow: var(--f-shadow-md);
        }
        .collector-selectable-card.selected {
            border-color: var(--f-primary);
            background-color: var(--f-accent);
            box-shadow: 0 0 0 2px var(--f-primary);
        }
        .collector-selectable-card.selected::after {
            content: "\F26E";
            font-family: "bootstrap-icons";
            position: absolute;
            top: 0.75rem;
            right: 0.75rem;
            color: var(--f-primary);
            font-size: 1.25rem;
        }
        .status-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            display: inline-block;
            margin-right: 6px;
        }
        .animate-in {
            animation: f-in 0.4s ease-out forwards;
        }
        .form-highlight {
            background: linear-gradient(to bottom, var(--f-accent), var(--f-card));
            border: 1px solid var(--f-border);
            border-radius: var(--f-radius-lg);
        }
    </style>

    <!-- GLOBAL THEME INJECTION -->
    <script>
      (function(){
        if(window.__theme_init) return; window.__theme_init=true;
        var t=localStorage.getItem('kalimasada_theme');
        if(!t) t=window.matchMedia('(prefers-color-scheme: dark)').matches?'dark':'light';
        document.documentElement.setAttribute('data-theme',t);
      })();
    </script>
    <link href="/css/dark-theme-global.css?v=2" rel="stylesheet">
    <link href="/css/theme-system.css?v=2" rel="stylesheet">
    <link href="/css/theme-overrides.css?v=1" rel="stylesheet">
    <!-- END GLOBAL THEME INJECTION -->
</head>
<body class="finance-content-area">
    <div class="f-wrapper">
        <%- include('../../partials/billing-sidebar') %>
        
        <main class="f-main-area main-content">
            <!-- PAGE HEADER (Glass) -->
            <header class="f-header-glass">
                <div>
                    <h1 class="f-page-title f-premium-text"><i class="bi bi-cash-coin me-2"></i>Terima Setoran</h1>
                    <p class="f-page-subtitle">Proses penyetoran uang kolektor ke kasir.</p>
                </div>
                <div class="f-actions">
                    <button class="f-btn f-btn-outline" onclick="window.location.reload()" title="Refresh Content">
                        <i class="bi bi-arrow-clockwise"></i>Refresh
                    </button>
                </div>
            </header>

            <div class="f-container">

                <!-- INFO ALERT -->
                <div class="alert alert-info border-0 shadow-sm mb-4" style="border-radius: var(--f-radius-md);">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-info-circle-fill me-3 fs-5"></i>
                        <div>
                            <strong>Petunjuk:</strong> Pilih salah satu kolektor di bawah ini yang akan menyerahkan setoran, kemudian lengkapi formulir penerimaan yang muncul.
                        </div>
                    </div>
                </div>

                <!-- FILTER SELECTION -->
                <div class="row mb-4">
                    <div class="col-md-3">
                        <label class="f-label">Bulan</label>
                        <select class="f-select" id="monthFilter">
                            <option value="all" <%= typeof filters !== 'undefined' && filters.month === 'all' ? 'selected' : '' %>>Semua Waktu</option>
                            <% const months = ['Januari', 'Februari', 'Maret', 'April', 'Mei', 'Juni', 'Juli', 'Agustus', 'September', 'Oktober', 'November', 'Desember']; %>
                            <% for(let m=1; m<=12; m++) { %>
                                <option value="<%= m %>" <%= typeof filters !== 'undefined' && filters.month == m ? 'selected' : '' %>><%= months[m-1] %></option>
                            <% } %>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="f-label">Tahun</label>
                        <select class="f-select" id="yearFilter">
                            <option value="all" <%= typeof filters !== 'undefined' && filters.year === 'all' ? 'selected' : '' %>>Semua Waktu</option>
                            <% const currY = new Date().getFullYear(); %>
                            <% for(let y=currY-3; y<=currY+1; y++) { %>
                                <option value="<%= y %>" <%= typeof filters !== 'undefined' && filters.year == y ? 'selected' : '' %>><%= y %></option>
                            <% } %>
                        </select>
                    </div>
                    <div class="col-md-3 d-flex align-items-end">
                        <button class="f-btn f-btn-primary w-100" onclick="applyRemittanceFilters()">
                            <i class="bi bi-search me-2"></i>Filter Data
                        </button>
                    </div>
                </div>

                <!-- COLLECTORS SELECTION -->
                <section class="mb-5">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <h2 class="f-card-title" style="font-size: 1.125rem;">Pilih Kolektor</h2>
                        <span class="text-muted small"><%= (typeof collectors !== 'undefined' ? collectors.length : 0) %> Kolektor Tersedia</span>
                    </div>
                    
                    <div class="f-grid f-grid-3">
                        <% if (typeof collectors !== 'undefined') { %>
                        <% collectors.forEach(function(collector, index) { %>
                            <div class="f-card collector-selectable-card" 
                                 onclick="selectCollector(this, <%= collector.id %>, '<%= collector.name %>', <%= collector.pending_amount || 0 %>)">
                                <div class="f-card-body">
                                    <div class="d-flex align-items-center gap-3 mb-3">
                                        <div class="rounded-circle bg-light d-flex align-items-center justify-content-center" style="width: 48px; height: 48px; border: 1px solid var(--f-border);">
                                            <i class="bi bi-person text-muted fs-4"></i>
                                        </div>
                                        <div>
                                            <h3 class="f-card-title mb-0"><%= collector.name %></h3>
                                            <p class="f-card-description mb-0"><%= collector.phone || 'N/A' %></p>
                                        </div>
                                    </div>
                                    
                                    <div class="row g-2 mb-3 mt-1">
                                        <div class="col-12 col-md-6 border-end px-2 text-center" style="border-right-style: dashed !important;">
                                            <span class="f-label mb-1 d-block" style="font-size: 0.65rem;">TOTAL LUNAS</span>
                                            <div class="font-weight-bold text-dark" style="font-size: 0.95rem;">
                                                Rp <%= (collector.total_lunas_gross || 0).toLocaleString('id-ID') %>
                                            </div>
                                        </div>
                                        <div class="col-12 col-md-6 px-2 text-center">
                                            <span class="f-label mb-1 d-block text-success" style="font-size: 0.65rem;">SUDAH SETOR</span>
                                            <div class="font-weight-bold text-success" style="font-size: 0.95rem;">
                                                Rp <%= (collector.sudah_setor || 0).toLocaleString('id-ID') %>
                                            </div>
                                        </div>
                                        <div class="col-12 mt-3 pt-3 border-top px-2 text-center" style="background: rgba(220, 38, 38, 0.04); border-radius: 8px;">
                                            <span class="f-label mb-1 d-block text-danger font-weight-bold" style="font-size: 0.75rem;">BELUM SETOR</span>
                                            <div class="font-weight-bold text-danger pb-1" style="font-size: 1.5rem; text-shadow: 0px 1px 1px rgba(220, 38, 38, 0.1);">
                                                Rp <%= (collector.pending_amount || 0).toLocaleString('id-ID') %>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="d-flex justify-content-between align-items-center small text-muted">
                                        <span><i class="bi bi-percent me-1"></i>Komisi <%= collector.commission_rate !== null && collector.commission_rate !== undefined ? collector.commission_rate : 5 %>%</span>
                                        <span><i class="bi bi-check2-circle me-1"></i>Klik untuk pilih</span>
                                    </div>
                                </div>
                            </div>
                        <% }); %>
                        <% } %>
                    </div>
                </section>

                <!-- REMITTANCE FORM -->
                <section id="remittanceForm" style="display: none;" class="mb-5">
                    <div class="f-card form-highlight">
                        <div class="f-card-header">
                            <div>
                                <h2 class="f-card-title">Formulir Penerimaan Setoran</h2>
                                <p class="f-card-description mb-0">Lengkapi detail penerimaan dana dari kolektor yang dipilih.</p>
                            </div>
                            <button class="f-btn f-btn-ghost f-btn-icon" onclick="cancelRemittance()" title="Batal">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        </div>
                        <div class="f-card-body">
                            <form id="remittanceFormData">
                                <input type="hidden" id="collectorId" name="collector_id">
                                
                                <div class="row g-4 mb-4">
                                    <div class="col-md-4">
                                        <div class="f-form-group">
                                            <label class="f-label" for="collectorName">NAMA KOLEKTOR</label>
                                            <input type="text" class="f-input" id="collectorName" readonly style="background-color: var(--f-muted);">
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="f-form-group">
                                            <label class="f-label" for="remittanceDate">TANGGAL & WAKTU PENERIMAAN</label>
                                            <input type="datetime-local" class="f-input" id="remittanceDate" name="remittance_date" required>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="f-form-group">
                                            <label class="f-label" for="paymentMethod">METODE PENERIMAAN</label>
                                            <select class="f-select" id="paymentMethod" name="payment_method" required>
                                                <option value="">Pilih metode...</option>
                                                <option value="cash">Tunai (Cash)</option>
                                                <option value="transfer">Transfer Bank</option>
                                                <option value="check">Cek / Giro</option>
                                                <option value="other">Lainnya</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="f-form-group mb-0">
                                            <label class="f-label" for="remittanceAmount">JUMLAH SETORAN (RP)</label>
                                            <div class="position-relative">
                                                <span class="position-absolute translate-middle-y top-50 ps-3 text-muted">Rp</span>
                                                <input type="number" class="f-input ps-5" id="remittanceAmount" name="remittance_amount" placeholder="0" required style="font-size: 1.125rem; font-weight: 600;">
                                            </div>
                                            <p class="text-muted mt-2 mb-0" style="font-size: 0.75rem;">
                                                <i class="bi bi-info-circle me-1"></i>Maksimal setoran: <span id="maxAmount" class="fw-bold">Rp 0</span>
                                            </p>
                                        </div>
                                    </div>
                                    <div class="col-md-8">
                                        <div class="f-form-group mb-0">
                                            <label class="f-label" for="notes">CATATAN TAMBAHAN</label>
                                            <input type="text" class="f-input" id="notes" name="notes" placeholder="Contoh: Setoran minggu ke-2, Transfer via BCA, dsb.">
                                        </div>
                                    </div>
                                </div>

                                <div class="p-4 rounded-3 border mb-4 text-center bg-white shadow-sm">
                                    <div class="f-stat-label mb-2">KONFIRMASI JUMLAH</div>
                                    <div class="text-success font-weight-bold" id="displayAmount" style="font-size: 2.5rem; letter-spacing: -0.05em;">Rp 0</div>
                                </div>

                                <div class="d-flex justify-content-end gap-3">
                                    <button type="button" class="f-btn f-btn-outline" onclick="cancelRemittance()">Batal</button>
                                    <button type="submit" class="f-btn f-btn-primary" style="height: 3rem; padding: 0 2rem;">
                                        <i class="bi bi-check2-circle me-2 fs-5"></i>Proses Terima Setoran
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </section>

                <!-- HISTORY SECTION -->
                <section>
                    <div class="f-page-header mb-3">
                        <div>
                            <h2 class="f-card-title"><i class="bi bi-clock-history me-2"></i>Riwayat Setoran Hari Ini</h2>
                            <p class="f-card-description">Daftar penerimaan setoran yang telah diproses hari ini.</p>
                        </div>
                    </div>

                    <div class="f-card overflow-hidden">
                        <div class="f-table-wrapper">
                            <table class="f-table">
                                <thead>
                                    <tr>
                                        <th>Kolektor</th>
                                        <th>Waktu Terima</th>
                                        <th>Metode</th>
                                        <th>Catatan</th>
                                        <th class="text-end">Jumlah</th>
                                        <th class="text-center">Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (typeof remittances !== 'undefined' && remittances.length > 0) { %>
                                        <% remittances.forEach(function(remittance) { %>
                                            <tr>
                                                <td>
                                                    <div class="font-weight-bold text-dark"><%= remittance.collector_name %></div>
                                                </td>
                                                <td>
                                                    <div class="small">
                                                        <%= new Date(remittance.received_at).toLocaleDateString('id-ID') %>
                                                        <span class="text-muted ms-1"><%= new Date(remittance.received_at).toLocaleTimeString('id-ID', {hour: '2-digit', minute:'2-digit'}) %></span>
                                                    </div>
                                                </td>
                                                <td>
                                                    <span class="text-capitalize"><%= remittance.payment_method || 'Tunai' %></span>
                                                </td>
                                                <td>
                                                    <span class="text-muted small"><%= remittance.notes || '-' %></span>
                                                </td>
                                                <td class="text-end font-weight-bold">
                                                    Rp <%= remittance.amount.toLocaleString('id-ID') %>
                                                </td>
                                                <td class="text-center">
                                                    <span class="f-badge f-badge-success">Diterima</span>
                                                </td>
                                            </tr>
                                        <% }); %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="6" class="text-center py-5">
                                                <div class="text-muted">
                                                    <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                                                    Belum ada setoran yang diterima hari ini.
                                                </div>
                                            </td>
                                        </tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </section>
            </div>
        </main>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script>
        let selectedCollector = null;
        
        function applyRemittanceFilters() {
            const month = document.getElementById('monthFilter').value;
            const year = document.getElementById('yearFilter').value;
            
            const params = new URLSearchParams();
            if (month) params.append('month', month);
            if (year) params.append('year', year);
            
            window.location.href = `/admin/billing/collector-remittance?${params.toString()}`;
        }
        
        function selectCollector(element, id, name, pendingAmount) {
            // Remove previous selection
            document.querySelectorAll('.collector-selectable-card').forEach(card => {
                card.classList.remove('selected');
            });
            
            // Add selection to clicked card
            element.classList.add('selected');
            
            // Set form values
            document.getElementById('collectorId').value = id;
            document.getElementById('collectorName').value = name;
            document.getElementById('remittanceAmount').value = pendingAmount;
            document.getElementById('remittanceAmount').max = pendingAmount;
            document.getElementById('maxAmount').textContent = `Rp ${pendingAmount.toLocaleString('id-ID')}`;
            
            // Set current date/time
            const now = new Date();
            const localDateTime = new Date(now.getTime() - now.getTimezoneOffset() * 60000).toISOString().slice(0, 16);
            document.getElementById('remittanceDate').value = localDateTime;
            
            // Show form
            const formSection = document.getElementById('remittanceForm');
            formSection.style.display = 'block';
            formSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
            
            // Update display amount
            updateDisplayAmount();
            
            selectedCollector = { id, name, pendingAmount };
        }
        
        function cancelRemittance() {
            const formSection = document.getElementById('remittanceForm');
            formSection.style.display = 'none';
            document.querySelectorAll('.collector-selectable-card').forEach(card => {
                card.classList.remove('selected');
            });
            selectedCollector = null;
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }
        
        function updateDisplayAmount() {
            const amount = document.getElementById('remittanceAmount').value;
            document.getElementById('displayAmount').textContent = `Rp ${parseInt(amount || 0).toLocaleString('id-ID')}`;
        }
        
        // Add event listener for amount input
        document.getElementById('remittanceAmount').addEventListener('input', updateDisplayAmount);
        
        // Form submission
        document.getElementById('remittanceFormData').addEventListener('submit', async function(e) {
            e.preventDefault();
            
            const formData = new FormData(this);
            const data = Object.fromEntries(formData);
            
            // Basic validation
            if (!data.remittance_amount || data.remittance_amount <= 0) {
                alert('Silakan masukkan jumlah setoran yang valid.');
                return;
            }

            if (confirm(`Konfirmasi penerimaan setoran sebesar Rp ${parseInt(data.remittance_amount).toLocaleString('id-ID')} dari ${document.getElementById('collectorName').value}?`)) {
                try {
                    const response = await fetch('/admin/billing/api/collector-remittance', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify(data)
                    });
                    
                    const result = await response.json();
                    
                    if (result.success) {
                        alert('Setoran berhasil diterima!');
                        location.reload();
                    } else {
                        alert('Gagal: ' + result.message);
                    }
                } catch (error) {
                    alert('Terjadi kesalahan system: ' + error.message);
                }
            }
        });
    </script>
</body>
</html>
