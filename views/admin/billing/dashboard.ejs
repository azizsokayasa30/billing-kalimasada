<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('../../partials/hard-reload') %>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard Billing - Admin Portal</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link href="/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
    <!-- Admin Mobile Optimizations -->
    <link href="/css/admin-mobile.css" rel="stylesheet">
    <link href="/css/dashboard-modern.css" rel="stylesheet">

    <%- include('../../partials/theme-head') %>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <%- include('../../partials/billing-sidebar') %>

            <!-- Main content -->
            <main id="pjax-container" class="col-md-10 ms-sm-auto col-lg-10 px-md-4 main-content">
                <!-- DASHBOARD HEADER -->
                <div class="dashboard-header mt-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="mb-1"><i class="bi bi-speedometer2 me-2"></i>Dashboard Billing</h5>
                            <p class="text-muted small mb-0">Statistik Penagihan & Keuangan Real-time</p>
                        </div>
                        
                        <!-- Desktop Tools -->
                        <div class="d-none d-lg-flex gap-2">
                            <a href="/admin/billing/monthly-summary" class="btn btn-outline-secondary btn-sm">
                                <i class="bi bi-calendar-event me-1"></i>Summary Bulanan
                            </a>
                            <a href="/admin/billing/invoices-by-type" class="btn btn-outline-info btn-sm">
                                <i class="bi bi-receipt-cutoff me-1"></i>Invoice by Type
                            </a>
                            <button id="cleanupDataBtn" class="btn btn-outline-warning btn-sm" onclick="cleanupData()">
                                <i class="bi bi-arrow-repeat me-1"></i>Perbaiki Data
                            </button>
                            <a href="/admin/billing/payment-settings" class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-gear me-1"></i>Settings
                            </a>
                        </div>
                        
                        <!-- Mobile Dropdown -->
                        <div class="dropdown d-lg-none">
                            <button class="btn btn-outline-primary btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                <i class="bi bi-list me-1"></i>Menu
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href="/admin/billing/monthly-summary"><i class="bi bi-calendar-event me-2"></i>Summary Bulanan</a></li>
                                <li><a class="dropdown-item" href="/admin/billing/invoices-by-type"><i class="bi bi-receipt-cutoff me-2"></i>Invoice by Type</a></li>
                                <li><button class="dropdown-item text-warning" onclick="cleanupData()"><i class="bi bi-arrow-repeat me-2"></i>Perbaiki Data</button></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="/admin/billing/payment-settings"><i class="bi bi-gear me-2"></i>Settings</a></li>
                            </ul>
                        </div>
                    </div>
                </div>

                <!-- STATISTIK CARDS -->
                <div class="row mb-4">
                    <div class="col-xl-3 col-md-6 mb-3">
                        <div class="metric-card metric-card-secondary">
                            <div class="metric-card-icon">
                                <i class="bi bi-people"></i>
                            </div>
                            <div class="metric-card-value"><%= stats.total_customers || 0 %></div>
                            <div class="metric-card-label">Total Pelanggan</div>
                            <div class="mt-2 small text-muted">
                                <span class="badge bg-success-subtle text-success"><i class="bi bi-check-circle me-1"></i><%= stats.active_customers || 0 %> Aktif</span>
                            </div>
                        </div>
                    </div>

                    <div class="col-xl-3 col-md-6 mb-3">
                        <div class="metric-card metric-card-success">
                            <div class="metric-card-icon">
                                <i class="bi bi-calendar-check"></i>
                            </div>
                            <div class="metric-card-value text-success">Rp <%= (stats.monthly_revenue || 0).toLocaleString('id-ID') %></div>
                            <div class="metric-card-label">Pendapatan Bulanan</div>
                            <div class="mt-2 small text-muted">
                                <span class="badge bg-info-subtle text-info"><i class="bi bi-receipt-check me-1"></i><%= stats.paid_monthly_invoices || 0 %> Lunas</span>
                            </div>
                        </div>
                    </div>

                    <div class="col-xl-3 col-md-6 mb-3">
                        <div class="metric-card metric-card-info">
                            <div class="metric-card-icon">
                                <i class="bi bi-ticket-perforated"></i>
                            </div>
                            <div class="metric-card-value text-info">Rp <%= (stats.voucher_revenue || 0).toLocaleString('id-ID') %></div>
                            <div class="metric-card-label">Pendapatan Voucher</div>
                            <div class="mt-2 small text-muted">
                                <span class="badge bg-danger-subtle text-danger"><i class="bi bi-exclamation-circle me-1"></i>Rp <%= ((stats.voucher_summary && stats.voucher_summary.pending_revenue) || stats.voucher_unpaid || 0).toLocaleString('id-ID') %> Pending</span>
                            </div>
                        </div>
                    </div>

                    <div class="col-xl-3 col-md-6 mb-3">
                        <div class="metric-card metric-card-pink">
                            <div class="metric-card-icon">
                                <i class="bi bi-cash-stack"></i>
                            </div>
                            <div class="metric-card-value text-primary">Rp <%= (stats.total_revenue || 0).toLocaleString('id-ID') %></div>
                            <div class="metric-card-label">Total Pendapatan</div>
                            <div class="mt-2 small text-muted">
                                <span class="badge bg-primary-subtle text-primary"><i class="bi bi-graph-up me-1"></i><%= stats.paid_invoices || 0 %>/<%= stats.total_invoices || 0 %> Lunas</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- INVOICE BREAKDOWN -->
                <div class="row">
                    <div class="col-xl-6 mb-4">
                        <div class="card h-100">
                            <div class="card-header section-card-header">
                                <div class="fw-bold"><i class="bi bi-calendar2-range me-2"></i>Tagihan Bulanan</div>
                            </div>
                            <div class="card-body">
                                <div class="row text-center mb-4 mt-2">
                                    <div class="col-4">
                                        <h4 class="fw-bold"><%= stats.monthly_invoices || 0 %></h4>
                                        <p class="text-muted small mb-0">Total</p>
                                    </div>
                                    <div class="col-4 border-start">
                                        <h4 class="fw-bold text-success"><%= stats.paid_monthly_invoices || 0 %></h4>
                                        <p class="text-muted small mb-0">Lunas</p>
                                    </div>
                                    <div class="col-4 border-start">
                                        <h4 class="fw-bold text-danger"><%= stats.unpaid_monthly_invoices || 0 %></h4>
                                        <p class="text-muted small mb-0">Unpaid</p>
                                    </div>
                                </div>
                                <div class="p-3 bg-light rounded-3">
                                    <div class="d-flex justify-content-between mb-2">
                                        <span class="text-muted small">Pendapatan:</span>
                                        <span class="fw-bold text-success">Rp <%= (stats.monthly_revenue || 0).toLocaleString('id-ID') %></span>
                                    </div>
                                    <div class="d-flex justify-content-between">
                                        <span class="text-muted small">Unpaid Amount:</span>
                                        <span class="fw-bold text-danger">Rp <%= (stats.monthly_unpaid || 0).toLocaleString('id-ID') %></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-xl-6 mb-4">
                        <div class="card h-100">
                            <div class="card-header section-card-header">
                                <div class="fw-bold"><i class="bi bi-ticket-detailed me-2"></i>Tagihan Voucher</div>
                            </div>
                            <div class="card-body">
                                <div class="row text-center mb-4 mt-2">
                                    <div class="col-4">
                                        <h4 class="fw-bold"><%= stats.voucher_invoices || 0 %></h4>
                                        <p class="text-muted small mb-0">Total</p>
                                    </div>
                                    <div class="col-4 border-start">
                                        <h4 class="fw-bold text-success"><%= stats.paid_voucher_invoices || 0 %></h4>
                                        <p class="text-muted small mb-0">Lunas</p>
                                    </div>
                                    <div class="col-4 border-start">
                                        <h4 class="fw-bold text-danger"><%= stats.unpaid_voucher_invoices || 0 %></h4>
                                        <p class="text-muted small mb-0">Unpaid</p>
                                    </div>
                                </div>
                                <div class="p-3 bg-light rounded-3">
                                    <div class="d-flex justify-content-between mb-2">
                                        <span class="text-muted small">Pendapatan:</span>
                                        <span class="fw-bold text-success">Rp <%= (stats.voucher_revenue || 0).toLocaleString('id-ID') %></span>
                                    </div>
                                    <div class="d-flex justify-content-between">
                                        <span class="text-muted small">Unpaid Amount:</span>
                                        <span class="fw-bold text-danger">Rp <%= (stats.voucher_unpaid || 0).toLocaleString('id-ID') %></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <!-- Tagihan Terbaru -->
                    <div class="col-xl-8 mb-4">
                        <div class="card">
                            <div class="card-header section-card-header d-flex justify-content-between align-items-center">
                                <div class="fw-bold"><i class="bi bi-clock-history me-2"></i>Tagihan Terbaru</div>
                                <a href="/admin/billing/invoices" class="btn btn-sm btn-light py-0 px-2" style="font-size: 0.75rem;">View All</a>
                            </div>
                            <div class="card-body p-0">
                                <div class="table-responsive">
                                    <table class="table table-hover mb-0">
                                        <thead>
                                            <tr>
                                                <th class="ps-3 text-nowrap">No. Tagihan</th>
                                                <th class="text-nowrap">Pelanggan</th>
                                                <th class="text-nowrap">Paket</th>
                                                <th class="text-nowrap">Jumlah</th>
                                                <th class="text-nowrap">Status</th>
                                                <th class="pe-3 text-nowrap">Jatuh Tempo</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% if (recentInvoices && recentInvoices.length > 0) { %>
                                                <% recentInvoices.forEach(function(invoice) { %>
                                                    <tr>
                                                        <td class="ps-3">
                                                            <a href="/admin/billing/invoices/<%= invoice.id %>" class="text-primary fw-bold text-decoration-none">
                                                                <%= invoice.invoice_number %>
                                                            </a>
                                                        </td>
                                                        <td>
                                                            <div class="d-flex flex-column">
                                                                <span class="fw-bold"><%= invoice.display_name || invoice.customer_name || invoice.member_name || 'N/A' %></span>
                                                                <% if (invoice.is_member) { %>
                                                                    <span class="badge bg-info-subtle text-info mt-1" style="width: fit-content; font-size: 0.65rem;">Member</span>
                                                                <% } %>
                                                            </div>
                                                        </td>
                                                        <td>
                                                            <span class="badge bg-primary-subtle text-primary"><%= invoice.display_package_name || invoice.package_name || 'N/A' %></span>
                                                        </td>
                                                        <td class="fw-bold">Rp <%= parseFloat(invoice.amount).toLocaleString('id-ID') %></td>
                                                        <td>
                                                            <% if (invoice.status === 'paid') { %>
                                                                <span class="badge bg-success">Lunas</span>
                                                            <% } else if (invoice.status === 'unpaid') { %>
                                                                <% if (new Date(invoice.due_date) < new Date()) { %>
                                                                    <span class="badge bg-warning text-dark">Terlambat</span>
                                                                <% } else { %>
                                                                    <span class="badge bg-warning text-dark">Belum Lunas</span>
                                                                <% } %>
                                                            <% } %>
                                                        </td>
                                                        <td class="pe-3"><%= new Date(invoice.due_date).toLocaleDateString('id-ID') %></td>
                                                    </tr>
                                                <% }); %>
                                            <% } else { %>
                                                <tr>
                                                    <td colspan="6" class="text-center py-4 text-muted small">Belum ada tagihan terbaru</td>
                                                </tr>
                                            <% } %>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Tagihan Terlambat -->
                    <div class="col-xl-4 mb-4">
                        <div class="card h-100">
                            <div class="card-header section-card-header d-flex justify-content-between align-items-center">
                                <div class="fw-bold"><i class="bi bi-exclamation-triangle me-2"></i>Terlambat</div>
                                <span class="badge bg-danger rounded-pill"><%= overdueInvoices.length %></span>
                            </div>
                            <div class="card-body p-0">
                                <div class="table-responsive">
                                    <table class="table table-hover mb-0">
                                        <thead>
                                            <tr>
                                                <th class="ps-3">Pelanggan</th>
                                                <th class="text-nowrap">Jum/Tempo</th>
                                                <th class="pe-3 text-center">Aksi</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% if (overdueInvoices && overdueInvoices.length > 0) { %>
                                                <% overdueInvoices.forEach(function(invoice) { %>
                                                    <tr>
                                                        <td class="ps-3">
                                                            <div class="d-flex flex-column">
                                                                <span class="fw-bold text-dark small"><%= invoice.customer_name %></span>
                                                                <small class="text-muted" style="font-size: 0.7rem;"><%= invoice.customer_phone %></small>
                                                            </div>
                                                        </td>
                                                        <td>
                                                            <div class="d-flex flex-column">
                                                                <span class="fw-bold small">Rp <%= parseFloat(invoice.amount).toLocaleString('id-ID') %></span>
                                                                <span class="text-danger" style="font-size: 0.7rem;"><%= new Date(invoice.due_date).toLocaleDateString('id-ID') %></span>
                                                            </div>
                                                        </td>
                                                        <td class="pe-3 text-center">
                                                            <div class="dropdown">
                                                                <button class="btn btn-light btn-sm p-1" type="button" data-bs-toggle="dropdown">
                                                                    <i class="bi bi-three-dots-vertical"></i>
                                                                </button>
                                                                <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                                                                    <li><button class="dropdown-item text-danger py-2" onclick="suspendCustomer('<%= invoice.username %>')">
                                                                        <i class="bi bi-slash-circle me-2"></i>Isolir
                                                                    </button></li>
                                                                    <li><button class="dropdown-item text-success py-2" onclick="restoreCustomer('<%= invoice.username %>')">
                                                                        <i class="bi bi-arrow-counterclockwise me-2"></i>Restore
                                                                    </button></li>
                                                                    <li><hr class="dropdown-divider"></li>
                                                                    <li><button class="dropdown-item py-2" 
                                                                        data-phone="<%= invoice.customer_phone || '' %>"
                                                                        data-name="<%= invoice.customer_name || '' %>"
                                                                        data-invoicenumber="<%= invoice.invoice_number || '' %>"
                                                                        data-amount="<%= invoice.amount || 0 %>"
                                                                        onclick="sendWaReminderFromBtn(this)">
                                                                        <i class="bi bi-whatsapp me-2"></i>WhatsApp Reminder
                                                                    </button></li>
                                                                </ul>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                <% }); %>
                                            <% } else { %>
                                                <tr>
                                                    <td colspan="3" class="text-center py-5 text-muted small">
                                                        <i class="bi bi-check2-circle d-block fs-3 mb-2 opacity-25"></i>
                                                        Tidak ada tagihan terlambat
                                                    </td>
                                                </tr>
                                            <% } %>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                </div>
            </main>
        </div>
    </div>

    <!-- Toast Container -->
    <div id="toast-container"></div>

    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script>
    // Fungsi toast notification
    function showToast(type, title, message, duration = 5000) {
        const toastId = 'toast-' + Date.now();
        const iconClass = type === 'success' ? 'bi-check-circle' : type === 'error' ? 'bi-x-circle' : 'bi-info-circle';
        const bgClass = type === 'success' ? 'bg-success' : type === 'error' ? 'bg-danger' : 'bg-primary';
        
        const toastHtml = `
            <div id="${toastId}" class="toast align-items-center text-white ${bgClass} border-0" role="alert" aria-live="assertive" aria-atomic="true">
                <div class="d-flex">
                    <div class="toast-body">
                        <i class="bi ${iconClass} me-2"></i>
                        <strong>${title}</strong><br>
                        <small>${message}</small>
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
            </div>
        `;
        
        const toastContainer = document.getElementById('toast-container');
        if (toastContainer) {
            toastContainer.insertAdjacentHTML('beforeend', toastHtml);
            const toastElement = document.getElementById(toastId);
            if (toastElement) {
                const toast = new bootstrap.Toast(toastElement, { delay: duration });
                toast.show();
                
                // Auto remove after hide
                toastElement.addEventListener('hidden.bs.toast', () => {
                    toastElement.remove();
                });
            }
        }
    }

    // Auto refresh stats setiap 30 detik dengan toast feedback
    setInterval(function() {
        fetch('/admin/billing/api/stats')
            .then(response => response.json())
            .then(data => {
                // Update stats cards dengan null check
                const totalCustomersEl = document.querySelector('[title="Total Customers"]');
                if (totalCustomersEl && totalCustomersEl.nextElementSibling) {
                    totalCustomersEl.nextElementSibling.textContent = data.total_customers || 0;
                }
                
                const totalRevenueEl = document.querySelector('[title="Total Revenue"]');
                if (totalRevenueEl && totalRevenueEl.nextElementSibling) {
                    totalRevenueEl.nextElementSibling.textContent = 'Rp ' + (data.total_revenue || 0).toLocaleString('id-ID');
                }
                
                const unpaidInvoicesEl = document.querySelector('[title="Unpaid Invoices"]');
                if (unpaidInvoicesEl && unpaidInvoicesEl.nextElementSibling) {
                    unpaidInvoicesEl.nextElementSibling.textContent = 'Rp ' + (data.total_unpaid || 0).toLocaleString('id-ID');
                }
                
                const totalInvoicesEl = document.querySelector('[title="Total Invoices"]');
                if (totalInvoicesEl && totalInvoicesEl.nextElementSibling) {
                    totalInvoicesEl.nextElementSibling.textContent = data.total_invoices || 0;
                }
            })
            .catch(error => {
                console.error('Error updating stats:', error);
            });
    }, 30000);

    // ====== Actions: Isolir, Restore, Reminder WA ======
    async function suspendCustomer(username) {
        const reason = prompt('Masukkan alasan isolir (opsional):', 'Telat bayar');
        if (reason === null) return; // cancelled
        try {
            const res = await fetch(`/admin/billing/service-suspension/suspend/${encodeURIComponent(username)}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ reason })
            });
            const data = await res.json();
            if (data.success) {
                showToast('success', 'Isolir Berhasil', `Pelanggan ${username} diisolir. ${reason ? 'Alasan: ' + reason : ''}`);
            } else {
                showToast('error', 'Isolir Gagal', data.message || 'Gagal melakukan isolir');
            }
        } catch (e) {
            console.error(e);
            showToast('error', 'Error', e.message || 'Terjadi kesalahan');
        }
    }

    async function restoreCustomer(username) {
        const reason = prompt('Masukkan alasan pemulihan (opsional):', 'Manual restore');
        if (reason === null) return; // cancelled
        try {
            const res = await fetch(`/admin/billing/service-suspension/restore/${encodeURIComponent(username)}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ reason })
            });
            const data = await res.json();
            if (data.success) {
                showToast('success', 'Restore Berhasil', `Pelanggan ${username} dipulihkan. ${reason ? 'Alasan: ' + reason : ''}`);
            } else {
                showToast('error', 'Restore Gagal', data.message || 'Gagal melakukan restore');
            }
        } catch (e) {
            console.error(e);
            showToast('error', 'Error', e.message || 'Terjadi kesalahan');
        }
    }

    function sendWaReminder(phone, name, invoiceNumber, amount) {
        if (!phone) {
            showToast('error', 'Nomor tidak tersedia', 'Nomor WhatsApp pelanggan kosong.');
            return;
        }
        const rupiah = (() => {
            const n = parseFloat(amount || 0);
            if (isNaN(n)) return '0';
            return n.toLocaleString('id-ID');
        })();
        const text = `Halo ${name}, ini pengingat tagihan Anda${invoiceNumber ? ' #' + invoiceNumber : ''} sebesar Rp ${rupiah}. Mohon segera melakukan pembayaran. Terima kasih.`;
        const url = `https://wa.me/${encodeURIComponent(phone)}?text=${encodeURIComponent(text)}`;
        window.open(url, '_blank');
    }

    // Helper agar onclick tidak mengandung ekspresi kompleks EJS
    function sendWaReminderFromBtn(btn) {
        const phone = btn.getAttribute('data-phone') || '';
        const name = btn.getAttribute('data-name') || '';
        const invoiceNumber = btn.getAttribute('data-invoicenumber') || '';
        const amount = btn.getAttribute('data-amount') || 0;
        sendWaReminder(phone, name, invoiceNumber, amount);
    }
    </script>

    <!-- Bottom Navigation for Mobile -->
    <nav class="bottom-nav d-md-none" style="position: fixed; bottom: 0; left: 0; right: 0; background: linear-gradient(180deg, rgba(11,20,55,0.96), rgba(15,28,79,0.96)); border-top: 1px solid rgba(255,255,255,0.08); height: 70px; display: grid; grid-template-columns: 1fr 1fr 1.5fr 1fr 1fr; z-index: 1000; backdrop-filter: blur(10px); padding: 8px 0;">
        <a class="nav-item" href="/admin/billing/mobile/customers" style="display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 4px; color: white; text-decoration: none; transition: all 0.3s ease;">
            <i class="bi bi-people" style="font-size: 1.2rem;"></i>
            <span style="font-size: 0.7rem; font-weight: 500;">Pelanggan</span>
        </a>
        <a class="nav-item" href="/admin/billing/mobile/invoices" style="display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 4px; color: white; text-decoration: none; transition: all 0.3s ease;">
            <i class="bi bi-receipt" style="font-size: 1.2rem;"></i>
            <span style="font-size: 0.7rem; font-weight: 500;">Tagihan</span>
        </a>
        <a class="nav-item home-button active" href="/admin/billing/mobile" style="display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 4px; color: white; text-decoration: none; transition: all 0.3s ease; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 50%; width: 56px; height: 56px; margin: -8px auto 0 auto; box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4); transform: translateY(-4px); border: 2px solid rgba(255,255,255,0.2); position: relative; overflow: hidden;">
            <i class="bi bi-house" style="font-size: 1.2rem;"></i>
            <span style="font-size: 0.7rem; font-weight: 500;">Home</span>
        </a>
        <a class="nav-item" href="/admin/billing/mobile/payments" style="display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 4px; color: white; text-decoration: none; transition: all 0.3s ease;">
            <i class="bi bi-credit-card" style="font-size: 1.2rem;"></i>
            <span style="font-size: 0.7rem; font-weight: 500;">Bayar</span>
        </a>
        <a class="nav-item" href="/admin/billing/mobile/map" style="display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 4px; color: white; text-decoration: none; transition: all 0.3s ease;">
            <i class="bi bi-geo-alt" style="font-size: 1.2rem;"></i>
            <span style="font-size: 0.7rem; font-weight: 500;">Map</span>
        </a>
    </nav>

    <style>
        /* Bottom Navigation Styles */
        .bottom-nav {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: linear-gradient(180deg, rgba(11,20,55,0.96), rgba(15,28,79,0.96));
            border-top: 1px solid rgba(255,255,255,0.08);
            height: 70px;
            display: grid;
            grid-template-columns: 1fr 1fr 1.5fr 1fr 1fr;
            z-index: 1000;
            backdrop-filter: blur(10px);
            padding: 8px 0;
        }

        .nav-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 4px;
            color: white;
            text-decoration: none;
            transition: all 0.3s ease;
        }

        .nav-item:hover {
            color: #667eea;
            transform: translateY(-2px);
        }

        .nav-item.active {
            color: #667eea;
        }

        /* Special styling for Home button (center button) */
        .nav-item.home-button {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-radius: 50%;
            width: 56px;
            height: 56px;
            margin: -8px auto 0 auto;
            box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4), 0 0 0 0 rgba(102, 126, 234, 0.4);
            transform: translateY(-4px);
            border: 2px solid rgba(255,255,255,0.2);
            position: relative;
            overflow: hidden;
            animation: float-home 3s ease-in-out infinite;
        }

        .nav-item.home-button:hover {
            transform: translateY(-6px);
            box-shadow: 0 6px 20px rgba(102, 126, 234, 0.6), 0 0 0 0 rgba(102, 126, 234, 0.6);
        }

        .nav-item.home-button:active {
            transform: translateY(-2px);
        }

        @keyframes float-home {
            0%, 100% { transform: translateY(-4px); }
            50% { transform: translateY(-8px); }
        }

        /* Add padding to body for mobile */
        body {
            padding-bottom: 80px;
        }

        @media (min-width: 768px) {
            .bottom-nav {
                display: none;
            }
            body {
                padding-bottom: 0;
            }
        }
    </style>

    <!-- Scripts -->
    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script>
        // Fungsi untuk membuat invoice untuk voucher yang belum punya invoice
        async function createMissingVoucherInvoices() {
            const btn = document.getElementById('createMissingInvoiceBtn');
            const originalText = btn.innerHTML;
            
            // Konfirmasi sebelum membuat invoice
            if (!confirm('Apakah Anda yakin ingin membuat invoice untuk voucher yang belum punya invoice?')) {
                return;
            }
            
            // Disable button dan show loading
            btn.disabled = true;
            btn.innerHTML = '<i class="bi bi-circle bx-spin me-1"></i>Memproses...';
            
            try {
                const response = await fetch('/admin/billing/api/create-missing-voucher-invoices', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    }
                });
                
                const result = await response.json();
                
                if (result.success) {
                    // Show success message
                    showAlert('success', 'Berhasil!', result.message);
                    
                    // Reload page setelah 2 detik untuk refresh stats
                    setTimeout(() => {
                        window.location.reload();
                    }, 2000);
                } else {
                    showAlert('danger', 'Error!', result.message || 'Gagal membuat invoice untuk voucher');
                }
            } catch (error) {
                console.error('Error creating missing voucher invoices:', error);
                showAlert('danger', 'Error!', 'Terjadi kesalahan saat membuat invoice untuk voucher');
            } finally {
                btn.disabled = false;
                btn.innerHTML = originalText;
            }
        }

        // Fungsi untuk update invoice voucher menjadi paid saat voucher digunakan
        async function updateVoucherInvoices() {
            const btn = document.getElementById('updateVoucherInvoicesBtn');
            const originalText = btn.innerHTML;
            
            // Disable button dan show loading
            btn.disabled = true;
            btn.innerHTML = '<i class="bi bi-circle bx-spin me-1"></i>Memproses...';
            
            try {
                const response = await fetch('/admin/billing/api/update-voucher-invoices', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    }
                });
                
                const result = await response.json();
                
                if (result.success) {
                    // Show success message
                    showAlert('success', 'Berhasil!', result.message);
                    
                    // Reload page setelah 2 detik untuk update stats
                    setTimeout(() => {
                        location.reload();
                    }, 2000);
                } else {
                    showAlert('danger', 'Error!', result.message);
                }
            } catch (error) {
                showAlert('danger', 'Error!', 'Gagal update invoice voucher: ' + error.message);
            } finally {
                // Restore button
                btn.disabled = false;
                btn.innerHTML = originalText;
            }
        }

        // Fungsi untuk membersihkan invoice voucher yang tidak punya voucher lagi
        async function cleanupOrphanVoucherInvoices() {
            const btn = document.getElementById('cleanupOrphanInvoicesBtn');
            const originalText = btn.innerHTML;
            
            // Konfirmasi sebelum menghapus
            if (!confirm('Apakah Anda yakin ingin menghapus invoice voucher yang tidak punya voucher lagi di RADIUS? Tindakan ini tidak dapat dibatalkan!')) {
                return;
            }
            
            // Disable button dan show loading
            btn.disabled = true;
            btn.innerHTML = '<i class="bi bi-circle bx-spin me-1"></i>Memproses...';
            
            try {
                const response = await fetch('/admin/billing/api/cleanup-orphan-voucher-invoices', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    }
                });
                
                const result = await response.json();
                
                if (result.success) {
                    // Show success message dengan detail
                    let message = result.message;
                    if (result.deleted > 0) {
                        message += ` Berhasil menghapus ${result.deleted} invoice.`;
                    }
                    if (result.failed > 0) {
                        message += ` ${result.failed} invoice gagal dihapus.`;
                    }
                    showAlert('success', 'Berhasil!', message);
                    
                    // Reload page setelah 2 detik untuk refresh stats
                    setTimeout(() => {
                        window.location.reload();
                    }, 2000);
                } else {
                    showAlert('danger', 'Error!', result.message);
                }
            } catch (error) {
                showAlert('danger', 'Error!', 'Gagal menghapus invoice gantung: ' + error.message);
            } finally {
                // Restore button
                btn.disabled = false;
                btn.innerHTML = originalText;
            }
        }

        // Fungsi untuk membersihkan data konsistensi
        async function cleanupData() {
            const btn = document.getElementById('cleanupDataBtn');
            const originalText = btn.innerHTML;
            
            // Disable button dan show loading
            btn.disabled = true;
            btn.innerHTML = '<i class="bi bi-circle bx-spin me-1"></i>Memperbaiki...';
            
            try {
                const response = await fetch('/admin/billing/api/cleanup-data', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    }
                });
                
                const result = await response.json();
                
                if (result.success) {
                    // Show success message
                    showAlert('success', 'Berhasil!', result.message);
                    
                    // Reload page setelah 2 detik
                    setTimeout(() => {
                        location.reload();
                    }, 2000);
                } else {
                    showAlert('danger', 'Error!', result.message);
                }
            } catch (error) {
                showAlert('danger', 'Error!', 'Gagal memperbaiki data: ' + error.message);
            } finally {
                // Restore button
                btn.disabled = false;
                btn.innerHTML = originalText;
            }
        }

        // Fungsi untuk membersihkan voucher expired
        async function cleanupVouchers() {
            const btn = document.getElementById('cleanupVoucherBtn');
            const originalText = btn.innerHTML;
            
            // Konfirmasi sebelum menghapus
            if (!confirm('Apakah Anda yakin ingin menghapus invoice voucher yang expired? Tindakan ini tidak dapat dibatalkan!')) {
                return;
            }
            
            // Disable button dan show loading
            btn.disabled = true;
            btn.innerHTML = '<i class="bi bi-circle bx-spin me-1"></i>Menghapus...';
            
            try {
                const response = await fetch('/admin/billing/api/voucher-cleanup', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    }
                });
                
                const result = await response.json();
                
                if (result.success) {
                    // Show success message dengan detail
                    let message = result.message;
                    if (result.cleaned > 0) {
                        message += ` (${result.cleaned} invoice dihapus)`;
                    }
                    showAlert('success', 'Berhasil!', message);
                    
                    // Reload page setelah 2 detik
                    setTimeout(() => {
                        location.reload();
                    }, 2000);
                } else {
                    showAlert('danger', 'Error!', result.message);
                }
            } catch (error) {
                showAlert('danger', 'Error!', 'Gagal menghapus voucher expired: ' + error.message);
            } finally {
                // Restore button
                btn.disabled = false;
                btn.innerHTML = originalText;
            }
        }

        // Fungsi untuk menampilkan alert
        function showAlert(type, title, message) {
            const alertHtml = `
                <div class="alert alert-${type} alert-dismissible fade show" role="alert">
                    <strong>${title}:</strong> ${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            `;
            
            // Insert alert di atas content
            const mainContent = document.querySelector('.main-content');
            const firstChild = mainContent.firstElementChild;
            firstChild.insertAdjacentHTML('afterend', alertHtml);
            
            // Auto dismiss setelah 5 detik
            setTimeout(() => {
                const alert = document.querySelector('.alert');
                if (alert) {
                    const bsAlert = new bootstrap.Alert(alert);
                    bsAlert.close();
                }
            }, 5000);
        }

        // Auto refresh stats setiap 30 detik
        setInterval(async () => {
            try {
                const response = await fetch('/admin/billing/api/stats');
                const result = await response.json();
                
                if (result.success) {
                    // Update stats tanpa reload page
                    updateStatsDisplay(result.data);
                }
            } catch (error) {
                console.log('Auto refresh stats failed:', error);
            }
        }, 30000);

        // Fungsi untuk update tampilan stats
        function updateStatsDisplay(stats) {
            // Helper function untuk mencari elemen berdasarkan text content
            function findElementByText(selector, text) {
                const elements = document.querySelectorAll(selector);
                for (let el of elements) {
                    if (el.textContent && el.textContent.includes(text)) {
                        return el;
                    }
                }
                return null;
            }
            
            // Update total customers
            const totalCustomersEl = findElementByText('h3', 'Total Pelanggan');
            if (totalCustomersEl) {
                totalCustomersEl.textContent = stats.total_customers || 0;
            }
            
            // Update active customers
            const activeCustomersEl = document.querySelector('.text-success .mdi-arrow-up-bold');
            if (activeCustomersEl && activeCustomersEl.nextElementSibling) {
                activeCustomersEl.nextElementSibling.textContent = stats.active_customers || 0;
            }
            
            // Update total revenue
            const totalRevenueEl = findElementByText('h3', 'Total Pendapatan');
            if (totalRevenueEl) {
                totalRevenueEl.textContent = 'Rp ' + (stats.total_revenue || 0).toLocaleString('id-ID');
            }
            
            // Update unpaid amount
            const unpaidAmountEl = findElementByText('h3', 'Tagihan Belum Lunas');
            if (unpaidAmountEl) {
                unpaidAmountEl.textContent = 'Rp ' + (stats.total_unpaid || 0).toLocaleString('id-ID');
            }
            
            // Update total invoices
            const totalInvoicesEl = findElementByText('h3', 'Total Tagihan');
            if (totalInvoicesEl) {
                totalInvoicesEl.textContent = stats.total_invoices || 0;
            }
        }
    </script>
    
    <!-- Mobile Bottom Navbar -->
    <%- include('../../partials/admin-mobile-navbar', { currentPage: 'dashboard' }) %>
</body>
</html>
