<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('../../partials/hard-reload') %>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link href="/vendor/boxicons/boxicons.min.css" rel="stylesheet">
    <link href="/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
    <link href="/css/admin-mobile.css" rel="stylesheet">
    <link href="/css/finance-modern.css" rel="stylesheet">

    <%- include('../../partials/theme-head') %>
</head>
<body class="finance-content-area">
    <div class="container-fluid">
        <div class="row">
            <%- include('../../partials/billing-sidebar') %>
            <main class="col-md-10 ms-sm-auto col-lg-10 px-md-4 main-content" style="padding-top: 1rem;">
                <div class="f-main-area" style="padding: 0;">
            <header class="f-header-glass" style="margin: -1rem -1.5rem 2rem -1.5rem; padding: 1.25rem 1.5rem;">
                <div>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mb-1" style="background: transparent; padding: 0;">
                            <li class="breadcrumb-item"><a href="/admin/dashboard" class="text-muted text-decoration-none small">Dashboard</a></li>
                            <li class="breadcrumb-item active small" aria-current="page">Laporan Keuangan</li>
                        </ol>
                    </nav>
                    <h1 class="f-page-title f-premium-text">Laporan Keuangan</h1>
                </div>
                <div class="f-actions">
                    <button class="f-btn f-btn-outline" onclick="window.location.reload()" title="Refresh Data">
                        <i class="bi bi-arrow-clockwise"></i>Refresh
                    </button>
                    <button class="f-btn f-btn-primary" onclick="exportProfitLossToExcel()">
                        <i class="bi bi-file-earmark-excel"></i>Export .xlsx
                    </button>
                </div>
            </header>

            <div class="f-container">

                <!-- Stats Grid -->
                <% if (financialData && financialData.summary) { %>
                <% const voucherSummary = financialData.voucherSummary || { recognized_revenue: 0, recognized_vouchers: 0, pending_revenue: 0 }; %>
                <div class="row g-4 mb-4">
                    <div class="col-md-3">
                        <div class="f-premium-card">
                            <div class="f-widget-stat">
                                <div class="f-widget-icon bg-success-glow">
                                    <i class='bi bi-graph-up-arrow'></i>
                                </div>
                                <div class="w-100">
                                    <p class="f-widget-label">Total Pemasukan</p>
                                    <h4 class="f-widget-value text-success">Rp <%= Number(financialData.summary.totalIncome || 0).toLocaleString('id-ID') %></h4>
                                    <div class="d-flex justify-content-between mt-1"><small class="text-muted"><%= financialData.summary.incomeCount %> Transaksi</small></div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="f-premium-card">
                            <div class="f-widget-stat">
                                <div class="f-widget-icon bg-warning-glow">
                                    <i class='bi bi-graph-down-arrow'></i>
                                </div>
                                <div class="w-100">
                                    <p class="f-widget-label">Total Pengeluaran</p>
                                    <h4 class="f-widget-value text-danger">Rp <%= Number(financialData.summary.totalExpense || 0).toLocaleString('id-ID') %></h4>
                                    <div class="d-flex justify-content-between mt-1"><small class="text-muted"><%= financialData.summary.expenseCount %> Transaksi</small></div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="f-premium-card">
                            <div class="f-widget-stat">
                                <div class="f-widget-icon bg-info-glow">
                                    <i class='bi bi-circle'></i>
                                </div>
                                <div class="w-100">
                                    <p class="f-widget-label">Pendapatan Voucher</p>
                                    <h4 class="f-widget-value text-info">Rp <%= Number(voucherSummary.recognized_revenue || 0).toLocaleString('id-ID') %></h4>
                                    <div class="d-flex justify-content-between mt-1"><small class="text-muted"><%= voucherSummary.recognized_vouchers %> Voucher</small></div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="f-premium-card">
                            <div class="f-widget-stat">
                                <div class="f-widget-icon bg-primary-glow">
                                    <i class='bi bi-cash'></i>
                                </div>
                                <div class="w-100">
                                    <p class="f-widget-label">Laba Bersih</p>
                                    <h4 class="f-widget-value" style="color: <%= (financialData.summary.netProfit || 0) >= 0 ? 'var(--f-info)' : 'var(--f-error)' %>;">
                                        Rp <%= Number(financialData.summary.netProfit || 0).toLocaleString('id-ID') %>
                                    </h4>
                                    <div class="d-flex justify-content-between mt-1"><small class="text-muted">Net Earnings</small></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <% } %>

                <!-- Profit Loss -->
                <% if (financialData && financialData.profitLossData) { %>
                <div class="f-card mb-4">
                    <div class="f-card-header">
                        <h5 class="f-card-title f-premium-text"><i class="bi bi-file-earmark-text me-2"></i>Laporan Laba Rugi</h5>
                    </div>
                    <div class="f-card-body">
                        <div class="table-responsive">
                            <table class="f-profit-loss-table">
                                <tbody>
                                    <tr class="f-pl-category-row"><td colspan="2">PENDAPATAN USAHA</td></tr>
                                    <tr><td class="ps-4">Pendapatan PPPoE</td><td class="text-end text-success">Rp <%= Number(financialData.profitLossData.revenue.pppoePayment || 0).toLocaleString('id-ID') %></td></tr>
                                    <tr><td class="ps-4">Pendapatan Member</td><td class="text-end text-success">Rp <%= Number(financialData.profitLossData.revenue.memberPayment || 0).toLocaleString('id-ID') %></td></tr>
                                    <tr><td class="ps-4">Pendapatan Voucher</td><td class="text-end text-success">Rp <%= Number(financialData.profitLossData.revenue.voucher || 0).toLocaleString('id-ID') %></td></tr>
                                    <tr><td class="ps-4">Pendapatan Lain-lain</td><td class="text-end text-success">Rp <%= Number(financialData.profitLossData.revenue.otherIncome || 0).toLocaleString('id-ID') %></td></tr>
                                    <tr class="f-pl-total-row"><td>Total Pendapatan Usaha</td><td class="text-end fw-bold text-success">Rp <%= Number(financialData.profitLossData.revenue.total || 0).toLocaleString('id-ID') %></td></tr>
                                    
                                    <tr class="f-pl-category-row mt-3"><td colspan="2">PENGELUARAN</td></tr>
                                    <% 
                                        const categories = financialData.profitLossData.expenses.byCategory;
                                        Object.keys(categories).forEach(cat => {
                                            const catTotal = financialData.profitLossData.expenses.totalByCategory[cat] || 0;
                                    %>
                                        <tr><td class="ps-4 fw-bold"><%= cat %></td><td class="text-end text-danger fw-bold">Rp <%= Number(catTotal).toLocaleString('id-ID') %></td></tr>
                                        <% Object.keys(categories[cat]).forEach(acc => { %>
                                            <tr><td class="ps-5 small text-muted"><%= acc %></td><td class="text-end small text-muted">Rp <%= Number(categories[cat][acc]).toLocaleString('id-ID') %></td></tr>
                                        <% }); %>
                                    <% }); %>
                                    <tr class="f-pl-total-row"><td>Total Pengeluaran</td><td class="text-end fw-bold text-danger">Rp <%= Number(financialData.profitLossData.expenses.total || 0).toLocaleString('id-ID') %></td></tr>
                                    
                                    <tr class="f-pl-category-row" style="background: <%= financialData.profitLossData.netProfit >= 0 ? 'var(--f-info-soft)' : 'var(--f-error-soft)' %>">
                                        <td>LABA BERSIH</td>
                                        <td class="text-end fw-bold" style="color: <%= financialData.profitLossData.netProfit >= 0 ? 'var(--f-info)' : 'var(--f-error)' %>">
                                            Rp <%= Number(financialData.profitLossData.netProfit || 0).toLocaleString('id-ID') %>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Charts -->
                <div class="row g-4 mb-4">
                    <div class="col-md-12">
                        <div class="f-premium-card">
                            <h6 class="fw-bold mb-4 f-premium-text">Arus Kas (Pendapatan vs Pengeluaran)</h6>
                            <div style="height: 350px;"><canvas id="revenueExpenseChart"></canvas></div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="f-premium-card">
                            <h6 class="fw-bold mb-4 f-premium-text">Breakdown Pengeluaran</h6>
                            <div style="height: 250px;"><canvas id="expenseCategoryChart"></canvas></div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="f-premium-card">
                            <h6 class="fw-bold mb-4 f-premium-text">Sumber Pendapatan</h6>
                            <div style="height: 250px;"><canvas id="revenueBreakdownChart"></canvas></div>
                        </div>
                    </div>
                </div>
                <% } %>

                <!-- Filters -->
                <div class="f-card mb-4">
                    <div class="f-card-body">
                        <form id="filterForm" class="row g-3">
                            <div class="col-md-3">
                                <label class="f-label">DARI TANGGAL</label>
                                <input type="date" class="f-input" name="start_date" id="start_date" value="<%= startDate %>">
                            </div>
                            <div class="col-md-3">
                                <label class="f-label">SAMPAI TANGGAL</label>
                                <input type="date" class="f-input" name="end_date" id="end_date" value="<%= endDate %>">
                            </div>
                            <div class="col-md-3">
                                <label class="f-label">TIPE TRANSAKSI</label>
                                <select class="f-select" name="type" id="filter_type">
                                    <option value="all" <%= type === 'all' ? 'selected' : '' %>>Semua</option>
                                    <option value="income" <%= type === 'income' ? 'selected' : '' %>>Pemasukan</option>
                                    <option value="expense" <%= type === 'expense' ? 'selected' : '' %>>Pengeluaran</option>
                                </select>
                            </div>
                            <div class="col-md-3 d-flex align-items-end gap-2">
                                <button type="button" class="f-btn f-btn-primary flex-grow-1" onclick="applyFinancialFilters()">Terapkan Filter</button>
                                <button type="button" class="f-btn f-btn-outline" onclick="exportToCSV()"><i class="bi bi-download"></i></button>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Transaction List -->
                <div class="f-card">
                    <div class="f-card-header">
                        <h5 class="f-card-title f-premium-text">Daftar Transaksi Kas</h5>
                    </div>
                    <div class="f-card-body">
                        <div class="f-table-wrapper">
                            <table class="f-table-premium">
                                <thead>
                                    <tr>
                                        <th>TANGGAL</th>
                                        <th>TIPE</th>
                                        <th>JUMLAH</th>
                                        <th>METODE</th>
                                        <th>KETERANGAN</th>
                                        <th>INVOICE/NAME</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (financialData && financialData.transactions && financialData.transactions.length > 0) { %>
                                        <% financialData.transactions.forEach(tx => { %>
                                            <tr>
                                                <td><small><%= tx.date ? new Date(tx.date).toLocaleDateString('id-ID') : '-' %></small></td>
                                                <td>
                                                    <span class="f-badge <%= tx.type === 'income' ? 'f-badge-success' : 'f-badge-error' %> px-2 py-1">
                                                        <%= tx.type === 'income' ? 'Income' : 'Expense' %>
                                                    </span>
                                                </td>
                                                <td class="fw-bold <%= tx.type === 'income' ? 'text-success' : 'text-error' %>">
                                                    <%= tx.type === 'income' ? '+' : '-' %>Rp <%= Number(tx.amount || 0).toLocaleString('id-ID') %>
                                                </td>
                                                <td><span class="f-badge f-badge-outline"><%= tx.payment_method || '-' %></span></td>
                                                <td class="small"><%= tx.description || tx.notes || '-' %></td>
                                                <td>
                                                    <div class="d-flex flex-column small text-muted">
                                                        <span class="fw-bold text-dark"><%= tx.invoice_number || '-' %></span>
                                                        <span><%= tx.customer_name || tx.collector_name || '' %></span>
                                                    </div>
                                                </td>
                                            </tr>
                                        <% }); %>
                                    <% if (financialData.transactions.length > 20) { %>
                                        <tr><td colspan="6" class="text-center py-5">Gunakan filter untuk melihat data lebih lengkap</td></tr>
                                    <% } %>
                                    <% } else { %>
                                        <tr><td colspan="6" class="text-center py-5">Belum ada data transaksi</td></tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
                </div>
            </main>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        function applyFinancialFilters() {
            const startDate = document.getElementById('start_date').value;
            const endDate = document.getElementById('end_date').value;
            const type = document.getElementById('filter_type').value;
            
            const params = new URLSearchParams();
            if (startDate) params.append('start_date', startDate);
            if (endDate) params.append('end_date', endDate);
            if (type) params.append('type', type);
            
            window.location.href = `/admin/billing/financial-report?${params.toString()}`;
        }

        function exportProfitLossToExcel() {
            const sd = document.getElementById('start_date').value;
            const ed = document.getElementById('end_date').value;
            window.location.href = `/admin/billing/export/financial-report.xlsx?start_date=${sd}&end_date=${ed}`;
        }

        function exportToCSV() {
            alert('Fitur export CSV sedang disiapkan.');
        }

        <% if (financialData && financialData.profitLossData) { %>
        const plData = <%- JSON.stringify(financialData.profitLossData) %>;
        document.addEventListener('DOMContentLoaded', () => {
            // Arus Kas Chart
            new Chart(document.getElementById('revenueExpenseChart'), {
                type: 'bar',
                data: {
                    labels: ['PPPoE', 'Member', 'Voucher', 'Lainnya', ...Object.keys(plData.expenses.totalByCategory)],
                    datasets: [
                        {
                            label: 'Pendapatan',
                            data: [plData.revenue.pppoePayment, plData.revenue.memberPayment, plData.revenue.voucher, plData.revenue.otherIncome, null, null, null],
                            backgroundColor: '#4cc9f0', borderRadius: 8
                        },
                        {
                            label: 'Pengeluaran',
                            data: [null, null, null, null, ...Object.values(plData.expenses.totalByCategory)],
                            backgroundColor: '#f72585', borderRadius: 8
                        }
                    ]
                },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true } } }
            });

            // Pie Chart Pendapatan
            new Chart(document.getElementById('revenueBreakdownChart'), {
                type: 'doughnut',
                data: {
                    labels: ['PPPoE', 'Member', 'Voucher', 'Lainnya'],
                    datasets: [{
                        data: [plData.revenue.pppoePayment, plData.revenue.memberPayment, plData.revenue.voucher, plData.revenue.otherIncome],
                        backgroundColor: ['#4361ee', '#4cc9f0', '#4895ef', '#e0e0e0'], cutout: '70%', borderWidth: 0
                    }]
                },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'right' } } }
            });

            // Bar Chart Pengeluaran
            new Chart(document.getElementById('expenseCategoryChart'), {
                type: 'bar',
                data: {
                    labels: Object.keys(plData.expenses.totalByCategory),
                    datasets: [{
                        data: Object.values(plData.expenses.totalByCategory),
                        backgroundColor: '#f72585', borderRadius: 6
                    }]
                },
                options: { indexAxis: 'y', responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } }
            });
        });
        <% } %>
    </script>
</body>
</html>
