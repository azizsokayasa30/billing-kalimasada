<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Laporan Kolektor - <%= appSettings.companyHeader %></title>
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="/css/admin-mobile.css" rel="stylesheet">
    <style>
        :root {
            --primary: #4361ee;
            --primary-soft: #4361ee15;
            --secondary: #3f37c9;
            --success: #4cc9f0;
            --success-soft: #4cc9f015;
            --info: #4895ef;
            --warning: #f72585;
            --bg-light: #f0f2f5;
            --card-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
            --card-border: 1px solid rgba(0, 0, 0, 0.05);
            --glass-bg: rgba(255, 255, 255, 0.85);
            --glass-border: 1px solid rgba(255, 255, 255, 0.3);
        }

        body {
            background: var(--bg-light);
            font-family: 'Outfit', sans-serif;
            color: #2b2d42;
        }
        
        .main-content {
            padding-bottom: 5rem;
        }

        .page-header {
            background: var(--glass-bg);
            backdrop-filter: blur(10px);
            border-bottom: var(--glass-border);
            padding: 1.5rem 0;
            margin-bottom: 2rem;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .premium-card {
            background: white;
            border-radius: 16px;
            border: var(--card-border);
            box-shadow: var(--card-shadow);
            padding: 1.5rem;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            height: 100%;
        }

        .premium-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.08);
        }

        .widget-stat {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .widget-icon {
            width: 54px;
            height: 54px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            flex-shrink: 0;
        }

        .bg-primary-soft { background: var(--primary-soft); color: var(--primary); }
        .bg-success-soft { background: var(--success-soft); color: var(--success); }
        .bg-info-soft { background: #4895ef15; color: #4895ef; }
        .bg-warning-soft { background: #f7258515; color: #f72585; }

        .widget-label {
            font-size: 0.85rem;
            color: #6c757d;
            font-weight: 500;
            margin-bottom: 0.25rem;
        }

        .widget-value {
            font-size: 1.25rem;
            font-weight: 700;
            color: #2b2d42;
            margin: 0;
        }

        .filter-header {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-bottom: 1.25rem;
            color: var(--secondary);
            font-weight: 600;
        }

        .form-control, .form-select {
            border: 1px solid #e0e0e0;
            border-radius: 10px;
            padding: 0.6rem 1rem;
            font-size: 0.95rem;
            transition: all 0.2s;
        }

        .form-control:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 4px var(--primary-soft);
        }

        .collector-avatar {
            width: 48px;
            height: 48px;
            background: #f8faff;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.25rem;
            color: var(--primary);
        }

        .collector-name {
            font-size: 1.1rem;
            font-weight: 600;
            margin-bottom: 2px;
        }

        .stats-summary {
            background: #f8f9fa;
            border-radius: 12px;
            padding: 1rem;
            margin: 1.25rem 0;
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1rem;
        }

        .mini-stat {
            display: flex;
            flex-direction: column;
        }

        .mini-stat-label {
            font-size: 0.75rem;
            color: #8d99ae;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 2px;
        }

        .mini-stat-value {
            font-size: 0.95rem;
            font-weight: 600;
            color: #2b2d42;
        }

        .badge-premium {
            padding: 6px 14px;
            border-radius: 8px;
            font-weight: 600;
            font-size: 0.75rem;
        }

        .btn-premium {
            padding: 10px 20px;
            border-radius: 10px;
            font-weight: 600;
            transition: all 0.3s;
        }

        .btn-premium-primary {
            background: var(--primary);
            color: white;
            border: none;
        }

        .btn-premium-primary:hover {
            background: var(--secondary);
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(67, 97, 238, 0.3);
        }

        .btn-premium-outline {
            background: transparent;
            border: 1.5px solid #e0e0e0;
            color: #4b4e6d;
        }

        .btn-premium-outline:hover {
            border-color: var(--primary);
            color: var(--primary);
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .animate-fade {
            animation: fadeIn 0.4s ease forwards;
        }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <%- include('../../partials/billing-sidebar') %>
            <main class="col-md-10 ms-sm-auto col-lg-10 px-md-4 main-content">
                <div class="page-header d-flex justify-content-between align-items-center">
                    <div>
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb mb-1">
                                <li class="breadcrumb-item text-muted"><a href="/admin/dashboard" class="text-decoration-none text-muted">Dashboard</a></li>
                                <li class="breadcrumb-item active" aria-current="page">Laporan Kolektor</li>
                            </ol>
                        </nav>
                        <h1 class="h3 fw-bold mb-0">Laporan Kolektor</h1>
                    </div>
                    <div>
                        <button class="btn btn-premium btn-premium-outline" onclick="exportReport()">
                            <i class="bi bi-file-earmark-excel me-2"></i>Export Excel
                        </button>
                    </div>
                </div>

                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="alert alert-warning border-0 shadow-sm rounded-4 mb-4 animate-fade" role="alert">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-exclamation-circle-fill fs-4 me-3"></i>
                            <div><%= error %></div>
                        </div>
                    </div>
                <% } %>

                <div class="row g-4 mb-4">
                    <div class="col-md-3">
                        <div class="premium-card animate-fade" style="animation-delay: 0.1s">
                            <div class="widget-stat">
                                <div class="widget-icon bg-primary-soft">
                                    <i class='bx bx-group'></i>
                                </div>
                                <div>
                                    <p class="widget-label">Total Kolektor</p>
                                    <h4 class="widget-value"><%= summary.total_collectors || 0 %></h4>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="premium-card animate-fade" style="animation-delay: 0.2s">
                            <div class="widget-stat">
                                <div class="widget-icon bg-success-soft">
                                    <i class='bx bx-wallet'></i>
                                </div>
                                <div>
                                    <p class="widget-label">Total Pembayaran</p>
                                    <h4 class="widget-value">Rp <%= (summary.total_payments || 0).toLocaleString('id-ID') %></h4>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="premium-card animate-fade" style="animation-delay: 0.3s">
                            <div class="widget-stat">
                                <div class="widget-icon bg-info-soft">
                                    <i class='bx bx-doughnut-chart'></i>
                                </div>
                                <div>
                                    <p class="widget-label">Total Komisi</p>
                                    <h4 class="widget-value">Rp <%= (summary.total_commissions || 0).toLocaleString('id-ID') %></h4>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="premium-card animate-fade" style="animation-delay: 0.4s">
                            <div class="widget-stat">
                                <div class="widget-icon bg-warning-soft">
                                    <i class='bx bx-money'></i>
                                </div>
                                <div>
                                    <p class="widget-label">Total Setoran</p>
                                    <h4 class="widget-value">Rp <%= (summary.total_setoran || 0).toLocaleString('id-ID') %></h4>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="premium-card mb-4 animate-fade" style="animation-delay: 0.5s">
                    <div class="filter-header">
                        <i class="bi bi-sliders2 me-2"></i>Filter Laporan
                    </div>
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label small fw-bold text-muted">DARI TANGGAL</label>
                            <input type="date" class="form-control shadow-none" id="dateFrom" value="<%= filters.dateFrom %>">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small fw-bold text-muted">SAMPAI TANGGAL</label>
                            <input type="date" class="form-control shadow-none" id="dateTo" value="<%= filters.dateTo %>">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small fw-bold text-muted">KOLEKTOR</label>
                            <select class="form-select shadow-none" id="collectorFilter">
                                <option value="">Semua Kolektor</option>
                                <% collectors.forEach(function(collector) { %>
                                    <option value="<%= collector.id %>" <%= filters.collector == collector.id ? 'selected' : '' %>><%= collector.name %></option>
                                <% }); %>
                            </select>
                        </div>
                        <div class="col-md-3 d-flex align-items-end">
                            <button class="btn btn-premium btn-premium-primary w-100" onclick="applyFilters()">
                                <i class="bi bi-filter me-2"></i>Terapkan Filter
                            </button>
                        </div>
                    </div>
                </div>

                <div class="row g-4">
                    <% if (collectors.length > 0) { %>
                        <% collectors.forEach(function(collector, index) { %>
                            <div class="col-md-6 col-lg-4">
                                <div class="premium-card animate-fade" style="animation-delay: <%= 0.6 + (index * 0.05) %>s">
                                    <div class="d-flex justify-content-between align-items-start mb-3">
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="collector-avatar">
                                                <i class='bx bx-user'></i>
                                            </div>
                                            <div>
                                                <h5 class="collector-name mb-0"><%= collector.name %></h5>
                                                <small class="text-muted"><i class="bi bi-telephone-outbound me-1"></i><%= collector.phone || '-' %></small>
                                            </div>
                                        </div>
                                        <span class="badge badge-premium bg-success-soft text-success text-uppercase">Aktif</span>
                                    </div>

                                    <div class="stats-summary">
                                        <div class="mini-stat">
                                            <span class="mini-stat-label">Transaksi</span>
                                            <span class="mini-stat-value"><%= collector.total_payments || 0 %> Items</span>
                                        </div>
                                        <div class="mini-stat">
                                            <span class="mini-stat-label">Omzet</span>
                                            <span class="mini-stat-value text-primary">Rp <%= (collector.total_payment_amount || 0).toLocaleString('id-ID') %></span>
                                        </div>
                                        <div class="mini-stat">
                                            <span class="mini-stat-label">Komisi</span>
                                            <span class="mini-stat-value text-warning">Rp <%= (collector.total_commission || 0).toLocaleString('id-ID') %></span>
                                        </div>
                                        <div class="mini-stat">
                                            <span class="mini-stat-label">Setoran</span>
                                            <span class="mini-stat-value text-success">Rp <%= (collector.total_setoran || 0).toLocaleString('id-ID') %></span>
                                        </div>
                                    </div>

                                    <div class="d-flex justify-content-between align-items-center pt-2">
                                        <div class="small fw-500 text-muted">
                                            <i class="bi bi-award me-1"></i>Rate: <%= collector.commission_rate || 5 %>%
                                        </div>
                                        <button class="btn btn-sm btn-premium-outline" onclick="viewCollectorDetails(<%= collector.id %>)">
                                            Lihat Detail<i class="bi bi-arrow-right ms-2"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div class="col-12 text-center py-5">
                            <div class="premium-card py-5">
                                <h4 class="text-muted">Tidak ada data ditemukan</h4>
                                <p class="text-secondary small mb-4">Coba sesuaikan filter tanggal atau pilih kolektor lain.</p>
                                <a href="/admin/billing/collector-reports" class="btn btn-premium btn-premium-primary">
                                    <i class="bi bi-arrow-clockwise me-2"></i>Reset Filter
                                </a>
                            </div>
                        </div>
                    <% } %>
                </div>
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function applyFilters() {
            const dateFrom = document.getElementById('dateFrom').value;
            const dateTo = document.getElementById('dateTo').value;
            const collectorFilter = document.getElementById('collectorFilter').value;
            
            const params = new URLSearchParams();
            if (dateFrom) params.append('dateFrom', dateFrom);
            if (dateTo) params.append('dateTo', dateTo);
            if (collectorFilter) params.append('collector', collectorFilter);
            
            window.location.href = `/admin/billing/collector-reports?${params.toString()}`;
        }
        
        function viewCollectorDetails(collectorId) {
            window.location.href = `/admin/billing/collector-details/${collectorId}`;
        }
        
        function exportReport() {
            const dateFrom = document.getElementById('dateFrom').value;
            const dateTo = document.getElementById('dateTo').value;
            const collectorFilter = document.getElementById('collectorFilter').value;
            
            const params = new URLSearchParams();
            if (dateFrom) params.append('dateFrom', dateFrom);
            if (dateTo) params.append('dateTo', dateTo);
            if (collectorFilter) params.append('collector', collectorFilter);
            params.append('export', 'excel');
            
            window.location.href = `/admin/billing/collector-reports/export?${params.toString()}`;
        }
    </script>
</body>
</html>
