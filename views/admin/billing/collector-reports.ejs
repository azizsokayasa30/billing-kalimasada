<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Laporan Kolektor - <%= appSettings.companyHeader %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="/css/admin-mobile.css" rel="stylesheet">
    <link href="/css/dashboard-modern.css" rel="stylesheet">
    <style>
        .page-header-bar {
            padding: 0 0 16px;
            margin-bottom: 20px;
            border-bottom: 1px solid var(--border);
        }
        .page-header-bar h1 {
            font-size: 1.25rem;
            font-weight: 700;
            color: var(--fg);
            margin: 0 0 2px;
            letter-spacing: -0.02em;
        }
        .page-header-bar .page-desc {
            font-size: 0.8rem;
            color: var(--fg-muted);
            margin: 0;
        }
        .breadcrumb { margin-bottom: 6px; }
        .breadcrumb-item, .breadcrumb-item a {
            font-size: 0.8rem;
            color: var(--fg-muted) !important;
            text-decoration: none;
        }
        .breadcrumb-item.active { color: var(--fg) !important; }
        .breadcrumb-item + .breadcrumb-item::before { color: var(--fg-subtle) !important; }

        /* Filter card */
        .filter-header {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin-bottom: 12px;
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--fg);
        }
        .filter-header i { color: var(--fg-muted); }

        .form-control, .form-select {
            border: 1px solid var(--border) !important;
            border-radius: var(--radius-md) !important;
            padding: 8px 12px !important;
            font-size: 0.85rem !important;
            font-family: 'Inter', sans-serif !important;
            color: var(--fg) !important;
            background: var(--card-bg) !important;
            transition: all 150ms;
        }
        .form-control:focus, .form-select:focus {
            border-color: var(--primary) !important;
            box-shadow: 0 0 0 3px var(--primary-muted) !important;
        }
        .form-label {
            font-size: 0.7rem !important;
            font-weight: 600 !important;
            color: var(--fg-muted) !important;
            text-transform: uppercase;
            letter-spacing: 0.06em;
        }

        /* Collector card */
        .collector-avatar {
            width: 40px;
            height: 40px;
            background: var(--primary-muted);
            border-radius: var(--radius-md);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            color: var(--primary);
            flex-shrink: 0;
        }
        .collector-name {
            font-size: 0.95rem;
            font-weight: 600;
            color: var(--fg);
            margin: 0;
        }

        .stats-summary {
            background: var(--bg-secondary);
            border-radius: var(--radius-md);
            padding: 12px;
            margin: 12px 0;
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 10px;
        }
        .mini-stat-label {
            font-size: 0.7rem;
            color: var(--fg-muted);
            text-transform: uppercase;
            letter-spacing: 0.04em;
            margin-bottom: 1px;
            display: block;
        }
        .mini-stat-value {
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--fg);
        }
        .mini-stat-value.text-primary { color: var(--primary) !important; }
        .mini-stat-value.text-warning { color: var(--warning) !important; }
        .mini-stat-value.text-success { color: var(--success) !important; }

        .badge-status {
            padding: 4px 10px;
            border-radius: var(--radius-sm);
            font-weight: 600;
            font-size: 0.65rem;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            background: var(--success-muted);
            color: var(--success);
            border: 1px solid var(--success-border);
        }

        .btn-filter {
            background: var(--primary) !important;
            color: var(--primary-fg) !important;
            border: none !important;
            border-radius: var(--radius-md) !important;
            padding: 8px 16px !important;
            font-size: 0.825rem !important;
            font-weight: 500 !important;
            font-family: 'Inter', sans-serif !important;
            transition: all 150ms;
        }
        .btn-filter:hover {
            background: var(--primary-hover) !important;
        }

        .btn-export {
            background: var(--card-bg) !important;
            color: var(--fg) !important;
            border: 1px solid var(--border) !important;
            border-radius: var(--radius-md) !important;
            padding: 6px 14px !important;
            font-size: 0.8rem !important;
            font-weight: 500 !important;
            font-family: 'Inter', sans-serif !important;
            transition: all 150ms;
        }
        .btn-export:hover {
            background: var(--bg-secondary) !important;
            border-color: var(--border-hover) !important;
        }

        .btn-detail {
            background: transparent;
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            padding: 4px 12px;
            font-size: 0.75rem;
            font-weight: 500;
            color: var(--fg-muted);
            transition: all 150ms;
            text-decoration: none;
        }
        .btn-detail:hover {
            background: var(--bg-secondary);
            color: var(--primary);
            border-color: var(--primary-muted-border);
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(8px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-fade { animation: fadeIn 0.3s ease forwards; }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <%- include('../../partials/billing-sidebar') %>
            <main class="col-md-10 ms-sm-auto col-lg-10 px-md-4 main-content">
                <!-- PAGE HEADER -->
                <div class="page-header-bar">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <nav aria-label="breadcrumb">
                                <ol class="breadcrumb mb-1">
                                    <li class="breadcrumb-item"><a href="/admin/dashboard">Dashboard</a></li>
                                    <li class="breadcrumb-item active" aria-current="page">Laporan Kolektor</li>
                                </ol>
                            </nav>
                            <h1>Laporan Kolektor</h1>
                        </div>
                        <div>
                            <button class="btn btn-export" onclick="exportReport()">
                                <i class="bi bi-file-earmark-excel me-1"></i>Export Excel
                            </button>
                        </div>
                    </div>
                </div>

                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="alert alert-warning mb-3 animate-fade" role="alert">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-exclamation-circle-fill me-2"></i>
                            <div><%= error %></div>
                        </div>
                    </div>
                <% } %>

                <!-- STAT CARDS -->
                <div class="row g-3 mb-3">
                    <div class="col-md-3">
                        <div class="metric-card animate-fade" style="animation-delay: 0.05s">
                            <div class="metric-card-icon" style="background: var(--primary-muted); color: var(--primary);">
                                <i class="bi bi-people"></i>
                            </div>
                            <div class="metric-card-value"><%= summary.total_collectors || 0 %></div>
                            <div class="metric-card-label">Total Kolektor</div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="metric-card animate-fade" style="animation-delay: 0.1s">
                            <div class="metric-card-icon" style="background: var(--success-muted); color: var(--success);">
                                <i class="bi bi-wallet2"></i>
                            </div>
                            <div class="metric-card-value">Rp <%= (summary.total_payments || 0).toLocaleString('id-ID') %></div>
                            <div class="metric-card-label">Total Pembayaran</div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="metric-card animate-fade" style="animation-delay: 0.15s">
                            <div class="metric-card-icon" style="background: var(--info-muted); color: var(--info);">
                                <i class="bi bi-pie-chart"></i>
                            </div>
                            <div class="metric-card-value">Rp <%= (summary.total_commissions || 0).toLocaleString('id-ID') %></div>
                            <div class="metric-card-label">Total Komisi</div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="metric-card animate-fade" style="animation-delay: 0.2s">
                            <div class="metric-card-icon" style="background: var(--warning-muted); color: var(--warning);">
                                <i class="bi bi-cash-stack"></i>
                            </div>
                            <div class="metric-card-value">Rp <%= (summary.total_setoran || 0).toLocaleString('id-ID') %></div>
                            <div class="metric-card-label">Total Setoran</div>
                        </div>
                    </div>
                </div>

                <!-- FILTER -->
                <div class="card mb-3 animate-fade" style="animation-delay: 0.25s">
                    <div class="card-body" style="padding: 16px 20px;">
                        <div class="filter-header">
                            <i class="bi bi-sliders2"></i>Filter Laporan
                        </div>
                        <div class="row g-3">
                            <div class="col-md-3">
                                <label class="form-label">DARI TANGGAL</label>
                                <input type="date" class="form-control" id="dateFrom" value="<%= filters.dateFrom %>">
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">SAMPAI TANGGAL</label>
                                <input type="date" class="form-control" id="dateTo" value="<%= filters.dateTo %>">
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">KOLEKTOR</label>
                                <select class="form-select" id="collectorFilter">
                                    <option value="">Semua Kolektor</option>
                                    <% collectors.forEach(function(collector) { %>
                                        <option value="<%= collector.id %>" <%= filters.collector == collector.id ? 'selected' : '' %>><%= collector.name %></option>
                                    <% }); %>
                                </select>
                            </div>
                            <div class="col-md-3 d-flex align-items-end">
                                <button class="btn btn-filter w-100" onclick="applyFilters()">
                                    <i class="bi bi-filter me-1"></i>Terapkan Filter
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- COLLECTOR CARDS -->
                <div class="row g-3">
                    <% if (collectors.length > 0) { %>
                        <% collectors.forEach(function(collector, index) { %>
                            <div class="col-md-6 col-lg-4">
                                <div class="card animate-fade" style="animation-delay: <%= 0.3 + (index * 0.04) %>s">
                                    <div class="card-body" style="padding: 16px;">
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <div class="d-flex align-items-center gap-3">
                                                <div class="collector-avatar">
                                                    <i class="bi bi-person"></i>
                                                </div>
                                                <div>
                                                    <h6 class="collector-name"><%= collector.name %></h6>
                                                    <small style="color: var(--fg-muted); font-size: 0.75rem;">
                                                        <i class="bi bi-telephone me-1"></i><%= collector.phone || '-' %>
                                                    </small>
                                                </div>
                                            </div>
                                            <span class="badge-status">AKTIF</span>
                                        </div>

                                        <div class="stats-summary">
                                            <div>
                                                <span class="mini-stat-label">Transaksi</span>
                                                <span class="mini-stat-value"><%= collector.total_payments || 0 %> Items</span>
                                            </div>
                                            <div>
                                                <span class="mini-stat-label">Omzet</span>
                                                <span class="mini-stat-value text-primary">Rp <%= (collector.total_payment_amount || 0).toLocaleString('id-ID') %></span>
                                            </div>
                                            <div>
                                                <span class="mini-stat-label">Komisi</span>
                                                <span class="mini-stat-value text-warning">Rp <%= (collector.total_commission || 0).toLocaleString('id-ID') %></span>
                                            </div>
                                            <div>
                                                <span class="mini-stat-label">Setoran</span>
                                                <span class="mini-stat-value text-success">Rp <%= (collector.total_setoran || 0).toLocaleString('id-ID') %></span>
                                            </div>
                                        </div>

                                        <div class="d-flex justify-content-between align-items-center pt-1">
                                            <div style="font-size: 0.75rem; color: var(--fg-muted); font-weight: 500;">
                                                <i class="bi bi-award me-1"></i>Rate: <%= collector.commission_rate || 5 %>%
                                            </div>
                                            <button class="btn-detail" onclick="viewCollectorDetails(<%= collector.id %>)">
                                                Lihat Detail <i class="bi bi-arrow-right ms-1"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div class="col-12 text-center py-5">
                            <div class="card">
                                <div class="card-body py-5">
                                    <i class="bi bi-inbox" style="font-size: 2.5rem; color: var(--fg-subtle);"></i>
                                    <h6 style="color: var(--fg-muted); margin-top: 12px;">Tidak ada data ditemukan</h6>
                                    <p style="font-size: 0.8rem; color: var(--fg-subtle); margin-bottom: 16px;">Coba sesuaikan filter tanggal atau pilih kolektor lain.</p>
                                    <a href="/admin/billing/collector-reports" class="btn btn-filter">
                                        <i class="bi bi-arrow-clockwise me-1"></i>Reset Filter
                                    </a>
                                </div>
                            </div>
                        </div>
                    <% } %>
                </div>
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function applyFilters() {
            const dateFrom = document.getElementById('dateFrom').value;
            const dateTo = document.getElementById('dateTo').value;
            const collectorFilter = document.getElementById('collectorFilter').value;
            
            const params = new URLSearchParams();
            if (dateFrom) params.append('dateFrom', dateFrom);
            if (dateTo) params.append('dateTo', dateTo);
            if (collectorFilter) params.append('collector', collectorFilter);
            
            window.location.href = `/admin/billing/collector-reports?${params.toString()}`;
        }
        
        function viewCollectorDetails(collectorId) {
            window.location.href = `/admin/billing/collector-details/${collectorId}`;
        }
        
        function exportReport() {
            const dateFrom = document.getElementById('dateFrom').value;
            const dateTo = document.getElementById('dateTo').value;
            const collectorFilter = document.getElementById('collectorFilter').value;
            
            const params = new URLSearchParams();
            if (dateFrom) params.append('dateFrom', dateFrom);
            if (dateTo) params.append('dateTo', dateTo);
            if (collectorFilter) params.append('collector', collectorFilter);
            params.append('export', 'excel');
            
            window.location.href = `/admin/billing/collector-reports/export?${params.toString()}`;
        }
    </script>
</body>
</html>
