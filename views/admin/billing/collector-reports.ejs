<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('../../partials/hard-reload') %>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Laporan Kolektor - <%= appSettings.companyHeader %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link href="/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
    <link href="/css/admin-mobile.css" rel="stylesheet">
    <link href="/css/finance-modern.css" rel="stylesheet">
    <style>
        .collector-avatar-modern {
            width: 54px;
            height: 54px;
            background: var(--f-muted);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            color: var(--f-primary);
            border: 1px solid var(--f-border);
            transition: all 0.3s ease;
        }
        .f-card:hover .collector-avatar-modern {
            background-color: var(--f-primary);
            color: white;
            transform: scale(1.05);
        }
        .mini-stat-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 0.75rem;
            margin: 1rem 0;
            padding: 0.75rem;
            background-color: var(--f-muted);
            border-radius: var(--f-radius-sm);
        }
        .animate-in {
            animation: f-in 0.4s ease-out forwards;
        }
    </style>

    <!-- GLOBAL THEME INJECTION -->
    <script>
      (function(){
        if(window.__theme_init) return; window.__theme_init=true;
        var t=localStorage.getItem('kalimasada_theme');
        if(!t) t=window.matchMedia('(prefers-color-scheme: dark)').matches?'dark':'light';
        document.documentElement.setAttribute('data-theme',t);
      })();
    </script>
    <link href="/css/dark-theme-global.css?v=2" rel="stylesheet">
    <link href="/css/theme-system.css?v=2" rel="stylesheet">
    <link href="/css/theme-overrides.css?v=1" rel="stylesheet">
    <!-- END GLOBAL THEME INJECTION -->
</head>
<body class="finance-content-area">
    <div class="f-wrapper">
        <%- include('../../partials/billing-sidebar') %>
        
        <main class="f-main-area main-content">
            <!-- PAGE HEADER -->
            <header class="d-flex flex-wrap justify-content-between align-items-center mb-4 pb-3 border-bottom" style="padding-top: 1rem;">
                <div class="mb-3 mb-md-0">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mb-1" style="background: transparent; padding: 0;">
                            <li class="breadcrumb-item"><a href="/admin/dashboard" class="text-muted text-decoration-none small">Dashboard</a></li>
                            <li class="breadcrumb-item active small" aria-current="page">Laporan Kolektor</li>
                        </ol>
                    </nav>
                    <h1 class="f-page-title f-premium-text m-0">Laporan Kolektor</h1>
                </div>
                <div class="f-actions d-flex gap-2">
                    <button class="f-btn f-btn-outline d-flex align-items-center gap-1" onclick="window.location.reload()" title="Refresh Content">
                        <i class="bi bi-arrow-clockwise"></i>Refresh
                    </button>
                    <button class="f-btn f-btn-primary d-flex align-items-center gap-1" onclick="exportReport()">
                        <i class="bi bi-file-earmark-excel"></i>Export .xlsx
                    </button>
                </div>
            </header>

            <div class="f-container">

                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="alert alert-warning border-0 shadow-sm mb-4" role="alert" style="border-radius: var(--f-radius-md);">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-exclamation-circle-fill me-2"></i>
                            <div><%= error %></div>
                        </div>
                    </div>
                <% } %>

                <!-- STAT CARDS -->
                 <div class="f-grid f-grid-4 mb-5">
                    <div class="f-stat-card animate-in" style="animation-delay: 0.1s;">
                        <div class="f-stat-header">
                            <span class="f-stat-label">Total Tagihan Area</span>
                            <div class="f-stat-icon-wrapper bg-primary-glow">
                                <i class="bi bi-receipt"></i>
                            </div>
                        </div>
                        <div class="f-stat-value f-premium-text">Rp <%= (summary.total_tagihan || 0).toLocaleString('id-ID') %></div>
                        <div class="f-stat-desc">Seluruh target area</div>
                    </div>
                    <div class="f-stat-card animate-in" style="animation-delay: 0.2s;">
                        <div class="f-stat-header">
                            <span class="f-stat-label">Total Lunas</span>
                            <div class="f-stat-icon-wrapper bg-success-glow">
                                <i class="bi bi-check-circle"></i>
                            </div>
                        </div>
                        <div class="f-stat-value f-premium-text text-success">Rp <%= (summary.total_lunas || 0).toLocaleString('id-ID') %></div>
                        <div class="f-stat-desc">Pembayaran sah masuk</div>
                    </div>
                    <div class="f-stat-card animate-in" style="animation-delay: 0.3s;">
                        <div class="f-stat-header">
                            <span class="f-stat-label">Belum Lunas</span>
                            <div class="f-stat-icon-wrapper bg-warning-glow">
                                <i class="bi bi-clock-history"></i>
                            </div>
                        </div>
                        <div class="f-stat-value f-premium-text text-warning">Rp <%= (summary.total_belum_lunas || 0).toLocaleString('id-ID') %></div>
                        <div class="f-stat-desc">Ngutang di area kolektor</div>
                    </div>
                    <div class="f-stat-card animate-in" style="animation-delay: 0.4s;">
                        <div class="f-stat-header">
                            <span class="f-stat-label">Komisi Kolektor</span>
                            <div class="f-stat-icon-wrapper bg-info-glow">
                                <i class="bi bi-cash-stack"></i>
                            </div>
                        </div>
                        <div class="f-stat-value f-premium-text text-info">Rp <%= (summary.total_komisi || 0).toLocaleString('id-ID') %></div>
                        <div class="f-stat-desc">Total bruto yang dicapai</div>
                    </div>
                </div>

                <!-- FILTER -->
                <div class="f-card mb-4">
                    <div class="f-card-body">
                        <div class="row g-3 align-items-end">
                            <div class="col-md-3">
                                <label class="f-label">BULAN</label>
                                <select class="f-select" id="monthFilter">
                                    <% const months = ['Januari', 'Februari', 'Maret', 'April', 'Mei', 'Juni', 'Juli', 'Agustus', 'September', 'Oktober', 'November', 'Desember']; %>
                                    <% for(let m=1; m<=12; m++) { %>
                                        <option value="<%= m %>" <%= filters.month == m ? 'selected' : '' %>><%= months[m-1] %></option>
                                    <% } %>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="f-label">TAHUN</label>
                                <select class="f-select" id="yearFilter">
                                    <% const currY = new Date().getFullYear(); %>
                                    <% for(let y=currY-3; y<=currY+1; y++) { %>
                                        <option value="<%= y %>" <%= filters.year == y ? 'selected' : '' %>><%= y %></option>
                                    <% } %>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="f-label">KOLEKTOR</label>
                                <select class="f-select" id="collectorFilter">
                                    <option value="">Semua Kolektor</option>
                                    <% collectors.forEach(function(collector) { %>
                                        <option value="<%= collector.id %>" <%= filters.collector == collector.id ? 'selected' : '' %>><%= collector.name %></option>
                                    <% }); %>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <button class="f-btn f-btn-primary w-100" onclick="applyFilters()">
                                    <i class="bi bi-filter"></i>Terapkan Filter
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- COLLECTOR LIST -->
                <div class="f-grid f-grid-3">
                    <% if (collectors.length > 0) { %>
                        <% collectors.forEach(function(collector, index) { %>
                            <div class="f-card">
                                <div class="f-card-body">
                                    <div class="d-flex justify-content-between align-items-start mb-3">
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="collector-avatar-modern">
                                                <i class="bi bi-person"></i>
                                            </div>
                                            <div>
                                                <h3 class="f-card-title"><%= collector.name %></h3>
                                                <p class="f-card-description mb-0"><i class="bi bi-telephone me-1"></i><%= collector.phone || '-' %></p>
                                            </div>
                                        </div>
                                        <span class="f-badge f-badge-success">Aktif</span>
                                    </div>

                                    <div class="mini-stat-grid">
                                        <div>
                                            <span class="f-stat-label" style="font-size: 0.65rem;">Transaksi</span>
                                            <div class="f-mono font-weight-bold" style="font-size: 0.875rem;"><%= collector.total_payments || 0 %> Tx</div>
                                        </div>
                                        <div>
                                            <span class="f-stat-label" style="font-size: 0.65rem;">Rate Komisi</span>
                                            <div class="f-mono text-info font-weight-bold" style="font-size: 0.875rem;"><%= collector.commission_rate !== null && collector.commission_rate !== undefined ? collector.commission_rate : 5 %>%</div>
                                        </div>
                                        <div class="col-span-2 pt-1 border-top" style="grid-column: span 2;">
                                            <div class="d-flex justify-content-between align-items-center mb-1">
                                                <span class="f-stat-label" style="font-size: 0.65rem;">Tagihan Area</span>
                                                <span class="f-mono font-weight-bold" style="font-size: 0.875rem;">Rp <%= (collector.total_tagihan_area || 0).toLocaleString('id-ID') %></span>
                                            </div>
                                            <div class="d-flex justify-content-between align-items-center mb-1">
                                                <span class="f-stat-label" style="font-size: 0.65rem;">Belum Lunas</span>
                                                <span class="f-mono text-warning font-weight-bold" style="font-size: 0.875rem;">Rp <%= (collector.total_belum_lunas_amount || 0).toLocaleString('id-ID') %> (<%= collector.total_belum_lunas_count || 0 %> org)</span>
                                            </div>
                                            <div class="d-flex justify-content-between align-items-center mb-1">
                                                <span class="f-stat-label" style="font-size: 0.65rem;">Total Lunas</span>
                                                <span class="f-mono text-success font-weight-bold" style="font-size: 0.875rem;">Rp <%= (collector.total_lunas_area || 0).toLocaleString('id-ID') %></span>
                                            </div>
                                            <div class="d-flex justify-content-between align-items-center pt-1 mt-1 border-top" style="border-top-style: dashed !important;">
                                                <span class="f-stat-label" style="font-weight: 600; color: var(--f-info);">Komisi</span>
                                                <span class="f-mono text-info font-weight-bold" style="font-size: 1rem;">Rp <%= (collector.total_commission || 0).toLocaleString('id-ID') %></span>
                                            </div>
                                        </div>
                                    </div>

                                    <button class="f-btn f-btn-outline w-100" onclick="viewCollectorDetails(<%= collector.id %>)">
                                        Detail Performa <i class="bi bi-arrow-right"></i>
                                    </button>
                                </div>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div class="col-span-full py-5 text-center" style="grid-column: 1 / -1;">
                            <div class="f-card py-5">
                                <div class="f-card-body">
                                    <i class="bi bi-inbox text-muted mb-3" style="font-size: 3rem;"></i>
                                    <h3 class="f-card-title text-muted">Data Tidak Ditemukan</h3>
                                    <p class="f-card-description">Coba sesuaikan filter tanggal atau pilih kolektor lain.</p>
                                    <a href="/admin/billing/collector-reports" class="f-btn f-btn-ghost mt-2">
                                        <i class="bi bi-arrow-clockwise"></i>Reset Filter
                                    </a>
                                </div>
                            </div>
                        </div>
                    <% } %>
                </div>
            </div>
        </main>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script>
        function applyFilters() {
            const month = document.getElementById('monthFilter').value;
            const year = document.getElementById('yearFilter').value;
            const collectorFilter = document.getElementById('collectorFilter').value;
            
            const params = new URLSearchParams();
            if (month) params.append('month', month);
            if (year) params.append('year', year);
            if (collectorFilter) params.append('collector', collectorFilter);
            
            window.location.href = `/admin/billing/collector-reports?${params.toString()}`;
        }
        
        function viewCollectorDetails(collectorId) {
            window.location.href = `/admin/billing/collector-details/${collectorId}`;
        }
        
        function exportReport() {
            const month = document.getElementById('monthFilter').value;
            const year = document.getElementById('yearFilter').value;
            const collectorFilter = document.getElementById('collectorFilter').value;
            
            const params = new URLSearchParams();
            if (month) params.append('month', month);
            if (year) params.append('year', year);
            if (collectorFilter) params.append('collector', collectorFilter);
            
            window.location.href = `/admin/billing/collector-reports/export?${params.toString()}`;
        }
    </script>
</body>
</html>
