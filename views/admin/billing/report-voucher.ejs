<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Laporan Keuangan Voucher - <%= appSettings.companyHeader %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/boxicons@2.0.7/css/boxicons.min.css" rel="stylesheet">
    <link href="/css/admin-mobile.css" rel="stylesheet">
    <style>
        .stat-card {
            border-left: 4px solid #007bff;
        }
        .stat-card.revenue {
            border-left-color: #28a745;
        }
        .stat-card.unpaid {
            border-left-color: #dc3545;
        }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <%- include('../../partials/billing-sidebar') %>

            <!-- Main content -->
            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 main-content">
                <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                    <h1 class="h2">
                        <i class="bi bi-ticket-perforated"></i> Laporan Keuangan Voucher
                    </h1>
                    <div>
                        <a href="/admin/billing/reports/pppoe" class="btn btn-secondary">
                            <i class="bi bi-router"></i> Laporan PPPoE
                        </a>
                        <a href="/admin/billing/dashboard" class="btn btn-primary">
                            <i class="bi bi-house"></i> Dashboard
                        </a>
                    </div>
                </div>

                <!-- Filter Form -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-funnel"></i> Filter Laporan</h5>
                    </div>
                    <div class="card-body">
                        <form method="GET" action="/admin/billing/reports/voucher" class="row g-3">
                            <div class="col-md-4">
                                <label for="start_date" class="form-label">Tanggal Mulai</label>
                                <input type="date" class="form-control" id="start_date" name="start_date" value="<%= startDate %>" required>
                            </div>
                            <div class="col-md-4">
                                <label for="end_date" class="form-label">Tanggal Akhir</label>
                                <input type="date" class="form-control" id="end_date" name="end_date" value="<%= endDate %>" required>
                            </div>
                            <div class="col-md-4">
                                <label for="status" class="form-label">Status</label>
                                <select class="form-select" id="status" name="status">
                                    <option value="all" <%= status === 'all' ? 'selected' : '' %>>Semua</option>
                                    <option value="paid" <%= status === 'paid' ? 'selected' : '' %>>Sudah Digunakan (Lunas)</option>
                                    <option value="unpaid" <%= status === 'unpaid' ? 'selected' : '' %>>Belum Digunakan</option>
                                </select>
                            </div>
                            <div class="col-md-12">
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-search"></i> Filter
                                </button>
                                <a href="/admin/billing/reports/voucher" class="btn btn-secondary">
                                    <i class="bi bi-arrow-clockwise"></i> Reset
                                </a>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Statistik Cards -->
                <div class="row mb-4">
                    <div class="col-xl-3 col-md-6">
                        <div class="card stat-card">
                            <div class="card-body">
                                <h5 class="text-muted mb-3">Total Voucher</h5>
                                <h2 class="mb-0"><%= stats.total_vouchers || 0 %></h2>
                                <small class="text-muted">voucher dibuat</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-xl-3 col-md-6">
                        <div class="card stat-card revenue">
                            <div class="card-body">
                                <h5 class="text-muted mb-3">Pendapatan</h5>
                                <h2 class="mb-0 text-success">Rp <%= (stats.total_revenue || 0).toLocaleString('id-ID') %></h2>
                                <small class="text-muted"><%= stats.paid_vouchers || 0 %> voucher sudah digunakan</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-xl-3 col-md-6">
                        <div class="card stat-card">
                            <div class="card-body">
                                <h5 class="text-muted mb-3">Rata-rata Harga</h5>
                                <h2 class="mb-0">Rp <%= (stats.average_price || 0).toLocaleString('id-ID') %></h2>
                                <small class="text-muted">per voucher</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-xl-3 col-md-6">
                        <div class="card stat-card unpaid">
                            <div class="card-body">
                                <h5 class="text-muted mb-3">Belum Digunakan</h5>
                                <h2 class="mb-0 text-muted">Rp <%= (stats.unpaid_amount || 0).toLocaleString('id-ID') %></h2>
                                <small class="text-muted"><%= stats.unpaid_vouchers || 0 %> voucher (tidak dihitung pemasukan)</small>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Tabel Invoice Voucher -->
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">
                            <i class="bi bi-list-ul"></i> Daftar Invoice Voucher
                            <span class="badge bg-primary ms-2"><%= invoices.length %></span>
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead>
                                    <tr>
                                        <th>No</th>
                                        <th>Invoice Number</th>
                                        <th>Voucher Username</th>
                                        <th>Tanggal</th>
                                        <th>Jumlah</th>
                                        <th>Status Penggunaan</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (invoices.length === 0) { %>
                                        <tr>
                                            <td colspan="6" class="text-center text-muted py-4">
                                                <i class="bi bi-inbox"></i> Tidak ada data invoice voucher
                                            </td>
                                        </tr>
                                    <% } else { %>
                                        <% invoices.forEach((invoice, index) => { %>
                                            <% 
                                                // Extract username from notes
                                                const notesMatch = invoice.notes ? invoice.notes.match(/Voucher Hotspot\s+(\S+)/i) : null;
                                                const voucherUsername = notesMatch ? notesMatch[1] : 'N/A';
                                            %>
                                            <tr>
                                                <td><%= index + 1 %></td>
                                                <td><%= invoice.invoice_number %></td>
                                                <td><code><%= voucherUsername %></code></td>
                                                <td><%= new Date(invoice.created_at).toLocaleDateString('id-ID') %></td>
                                                <td><strong>Rp <%= parseFloat(invoice.amount || 0).toLocaleString('id-ID') %></strong></td>
                                                <td>
                                                    <% if (invoice.status === 'paid') { %>
                                                        <span class="badge bg-success">Lunas (Sudah Digunakan)</span>
                                                    <% } else { %>
                                                        <span class="badge bg-secondary">Belum Digunakan</span>
                                                    <% } %>
                                                </td>
                                            </tr>
                                        <% }); %>
                                    <% } %>
                                </tbody>
                                <tfoot>
                                    <tr class="table-info">
                                        <th colspan="4" class="text-end">Total:</th>
                                        <th>Rp <%= invoices.reduce((sum, inv) => sum + parseFloat(inv.amount || 0), 0).toLocaleString('id-ID') %></th>
                                        <th>
                                            <span class="badge bg-success"><%= invoices.filter(i => i.status === 'paid').length %> Sudah Digunakan</span>
                                            <span class="badge bg-secondary"><%= invoices.filter(i => i.status === 'unpaid').length %> Belum Digunakan</span>
                                        </th>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

