<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Laporan Keuangan Voucher - <%= appSettings.companyHeader %></title>
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="/css/admin-mobile.css" rel="stylesheet">
    <style>
        :root {
            --primary: #4361ee;
            --primary-soft: #4361ee15;
            --secondary: #3f37c9;
            --success: #4cc9f0;
            --success-soft: #4cc9f015;
            --info: #4895ef;
            --warning: #f72585;
            --bg-light: #f0f2f5;
            --card-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
            --card-border: 1px solid rgba(0, 0, 0, 0.05);
            --glass-bg: rgba(255, 255, 255, 0.85);
            --glass-border: 1px solid rgba(255, 255, 255, 0.3);
        }

        body {
            background: var(--bg-light);
            font-family: 'Outfit', sans-serif;
            color: #2b2d42;
        }
        
        .main-content {
            padding-bottom: 5rem;
        }

        .page-header {
            background: var(--glass-bg);
            backdrop-filter: blur(10px);
            border-bottom: var(--glass-border);
            padding: 1.5rem 0;
            margin-bottom: 2rem;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .premium-card {
            background: white;
            border-radius: 16px;
            border: var(--card-border);
            box-shadow: var(--card-shadow);
            padding: 1.5rem;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            height: 100%;
        }

        .premium-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.08);
        }

        .widget-stat {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .widget-icon {
            width: 54px;
            height: 54px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            flex-shrink: 0;
        }

        .bg-primary-soft { background: var(--primary-soft); color: var(--primary); }
        .bg-success-soft { background: var(--success-soft); color: var(--success); }
        .bg-info-soft { background: #4895ef15; color: #4895ef; }
        .bg-warning-soft { background: #f7258515; color: #f72585; }

        .widget-label {
            font-size: 0.85rem;
            color: #6c757d;
            font-weight: 500;
            margin-bottom: 0.25rem;
        }

        .widget-value {
            font-size: 1.25rem;
            font-weight: 700;
            margin: 0;
        }

        .filter-header {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-bottom: 1.25rem;
            color: var(--secondary);
            font-weight: 600;
        }

        .form-control, .form-select {
            border: 1px solid #e0e0e0;
            border-radius: 10px;
            padding: 0.6rem 1rem;
            font-size: 0.95rem;
        }

        .form-control:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 4px var(--primary-soft);
        }

        .table {
            border-collapse: separate;
            border-spacing: 0 8px;
        }

        .table thead th {
            border: none;
            color: #8d99ae;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            padding: 1rem;
        }

        .table tbody tr {
            background: white;
            transition: all 0.2s;
        }

        .table tbody tr td {
            padding: 1rem;
            vertical-align: middle;
            border: none;
            border-top: 1px solid #f8f9fa;
            border-bottom: 1px solid #f8f9fa;
        }

        .table tbody tr td:first-child { border-left: 1px solid #f8f9fa; border-top-left-radius: 12px; border-bottom-left-radius: 12px; }
        .table tbody tr td:last-child { border-right: 1px solid #f8f9fa; border-top-right-radius: 12px; border-bottom-right-radius: 12px; }

        .table tbody tr:hover {
            transform: scale(1.005);
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        }

        .btn-premium {
            padding: 10px 20px;
            border-radius: 10px;
            font-weight: 600;
            transition: all 0.3s;
        }

        .btn-premium-primary { background: var(--primary); color: white; border: none; }
        .btn-premium-primary:hover { background: var(--secondary); transform: translateY(-2px); box-shadow: 0 4px 15px rgba(67, 97, 238, 0.3); }

        .btn-premium-outline { background: transparent; border: 1.5px solid #e0e0e0; color: #4b4e6d; }
        .btn-premium-outline:hover { border-color: var(--primary); color: var(--primary); }

        .usage-badge {
            padding: 6px 12px;
            border-radius: 6px;
            font-weight: 600;
            font-size: 0.7rem;
            text-transform: uppercase;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .animate-fade { animation: fadeIn 0.4s ease forwards; }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <%- include('../../partials/billing-sidebar') %>
            <main class="col-md-10 ms-sm-auto col-lg-10 px-md-4 main-content">
                <div class="page-header d-flex justify-content-between align-items-center">
                    <div>
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb mb-1">
                                <li class="breadcrumb-item text-muted"><a href="/admin/dashboard" class="text-decoration-none text-muted">Dashboard</a></li>
                                <li class="breadcrumb-item active" aria-current="page">Laporan Voucher</li>
                            </ol>
                        </nav>
                        <h1 class="h3 fw-bold mb-0">Laporan Keuangan Voucher</h1>
                    </div>
                    <div class="d-flex gap-2">
                        <a href="/admin/billing/reports/pppoe" class="btn btn-premium btn-premium-outline">
                            <i class="bi bi-router me-2"></i>Laporan PPPoE
                        </a>
                        <button class="btn btn-premium btn-premium-primary" onclick="updateVoucherInvoices()">
                            <i class="bi bi-arrow-clockwise me-2"></i>Update Status
                        </button>
                    </div>
                </div>

                <!-- Stats Grid -->
                <div class="row g-4 mb-4">
                    <div class="col-md-3">
                        <div class="premium-card animate-fade" style="animation-delay: 0.1s">
                            <div class="widget-stat">
                                <div class="widget-icon bg-primary-soft">
                                    <i class='bx bx-ticket'></i>
                                </div>
                                <div>
                                    <p class="widget-label">Total Voucher</p>
                                    <h4 class="widget-value"><%= stats.total_vouchers || 0 %></h4>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="premium-card animate-fade" style="animation-delay: 0.2s">
                            <div class="widget-stat">
                                <div class="widget-icon bg-success-soft">
                                    <i class='bx bx-trending-up'></i>
                                </div>
                                <div>
                                    <p class="widget-label">Pendapatan</p>
                                    <h4 class="widget-value text-success">Rp <%= (stats.total_revenue || 0).toLocaleString('id-ID') %></h4>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="premium-card animate-fade" style="animation-delay: 0.3s">
                            <div class="widget-stat">
                                <div class="widget-icon bg-info-soft">
                                    <i class='bx bx-calculator'></i>
                                </div>
                                <div>
                                    <p class="widget-label">Rata-rata Harga</p>
                                    <h4 class="widget-value">Rp <%= (stats.average_price || 0).toLocaleString('id-ID') %></h4>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="premium-card animate-fade" style="animation-delay: 0.4s">
                            <div class="widget-stat">
                                <div class="widget-icon bg-warning-soft">
                                    <i class='bx bx-time-five'></i>
                                </div>
                                <div>
                                    <p class="widget-label">Belum Digunakan</p>
                                    <h4 class="widget-value text-warning">Rp <%= (stats.unpaid_amount || 0).toLocaleString('id-ID') %></h4>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Filter Card -->
                <div class="premium-card mb-4 animate-fade" style="animation-delay: 0.5s">
                    <div class="filter-header">
                        <i class="bi bi-funnel me-2"></i>Filter Laporan
                    </div>
                    <form method="GET" action="/admin/billing/reports/voucher" class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label small fw-bold text-muted">DARI TANGGAL</label>
                            <input type="date" class="form-control" name="start_date" value="<%= startDate %>">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small fw-bold text-muted">SAMPAI TANGGAL</label>
                            <input type="date" class="form-control" name="end_date" value="<%= endDate %>">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small fw-bold text-muted">STATUS PENGGUNAAN</label>
                            <select class="form-select" name="status">
                                <option value="all" <%= status === 'all' ? 'selected' : '' %>>Semua</option>
                                <option value="paid" <%= status === 'paid' ? 'selected' : '' %>>Sudah Digunakan (Lunas)</option>
                                <option value="unpaid" <%= status === 'unpaid' ? 'selected' : '' %>>Belum Digunakan</option>
                            </select>
                        </div>
                        <div class="col-md-3 d-flex align-items-end gap-2">
                            <button type="submit" class="btn btn-premium btn-premium-primary flex-grow-1">
                                <i class="bi bi-search me-2"></i>Filter
                            </button>
                            <a href="/admin/billing/reports/voucher" class="btn btn-premium btn-premium-outline">
                                <i class="bi bi-arrow-clockwise"></i>
                            </a>
                        </div>
                    </form>
                </div>

                <!-- Visualization -->
                <div class="row g-4 mb-4">
                    <div class="col-md-5">
                        <div class="premium-card animate-fade" style="animation-delay: 0.6s">
                            <div class="d-flex align-items-center mb-4">
                                <i class="bi bi-pie-chart text-primary me-2"></i>
                                <h6 class="mb-0 fw-bold">Distribusi Voucher</h6>
                            </div>
                            <div style="height: 250px;">
                                <canvas id="voucherChart"></canvas>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-7">
                        <div class="premium-card animate-fade" style="animation-delay: 0.7s">
                            <div class="d-flex align-items-center mb-4">
                                <i class="bi bi-bar-chart text-primary me-2"></i>
                                <h6 class="mb-0 fw-bold">Ringkasan Angka</h6>
                            </div>
                            <div class="table-responsive">
                                <table class="table mb-0">
                                    <tbody style="font-size: 0.9rem;">
                                        <tr>
                                            <td class="text-muted border-0 py-2">Total Voucher Dibuat</td>
                                            <td class="text-end border-0 fw-600 py-2"><%= stats.total_vouchers || 0 %></td>
                                        </tr>
                                        <tr>
                                            <td class="text-muted border-0 py-2">Sudah Digunakan</td>
                                            <td class="text-end border-0 fw-600 text-success py-2"><%= stats.paid_vouchers || 0 %></td>
                                        </tr>
                                        <tr>
                                            <td class="text-muted border-0 py-2">Belum Digunakan</td>
                                            <td class="text-end border-0 fw-600 text-muted py-2"><%= stats.unpaid_vouchers || 0 %></td>
                                        </tr>
                                        <tr>
                                            <td class="text-muted border-0 py-2">Potensi Pendapatan Baru</td>
                                            <td class="text-end border-0 fw-600 text-info py-2">Rp <%= (stats.unpaid_amount || 0).toLocaleString('id-ID') %></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Data Table -->
                <div class="premium-card animate-fade" style="animation-delay: 0.8s">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="mb-0 fw-bold">Daftar Invoice Voucher</h5>
                        <div class="d-flex gap-2">
                            <button class="btn btn-sm btn-outline-success rounded-3" onclick="exportToExcel()">
                                <i class="bi bi-file-earmark-excel me-1"></i>Excel
                            </button>
                            <button class="btn btn-sm btn-outline-danger rounded-3" onclick="window.print()">
                                <i class="bi bi-printer me-1"></i>Print
                            </button>
                        </div>
                    </div>
                    <div class="table-responsive">
                        <table class="table" id="voucherTable">
                            <thead>
                                <tr>
                                    <th>NO</th>
                                    <th>INVOICE</th>
                                    <th>USERNAME</th>
                                    <th>TANGGAL BUAT</th>
                                    <th>TANGGAL GUNAKAN</th>
                                    <th>HARGA</th>
                                    <th>STATUS</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (invoices.length === 0) { %>
                                    <tr><td colspan="7" class="text-center py-5 text-muted">Belum ada data untuk periode ini</td></tr>
                                <% } else { %>
                                    <% invoices.forEach((invoice, index) => { %>
                                        <tr>
                                            <td><%= index + 1 %></td>
                                            <td class="fw-bold text-primary"><%= invoice.invoice_number %></td>
                                            <td><span class="badge bg-light text-dark font-monospace"><%= invoice.voucher_username || 'N/A' %></span></td>
                                            <td><small><%= invoice.created_at ? new Date(invoice.created_at).toLocaleString('id-ID') : '-' %></small></td>
                                            <td>
                                                <% if (invoice.first_used_at) { %>
                                                    <small class="text-success"><%= new Date(invoice.first_used_at).toLocaleString('id-ID') %></small>
                                                <% } else { %>
                                                    <span class="text-muted">-</span>
                                                <% } %>
                                            </td>
                                            <td class="fw-bold text-success">Rp <%= (invoice.amount || 0).toLocaleString('id-ID') %></td>
                                            <td>
                                                <% if (invoice.first_used_at) { %>
                                                    <span class="usage-badge bg-success-soft text-success">Used</span>
                                                <% } else { %>
                                                    <span class="usage-badge bg-secondary-soft text-muted">Unused</span>
                                                <% } %>
                                            </td>
                                        </tr>
                                    <% }); %>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@3.9.1/dist/chart.min.js"></script>
    <script>
        async function updateVoucherInvoices() {
            if (!confirm('Update status invoice voucher berdasarkan penggunaan sekarang?')) return;
            const btn = event.target;
            btn.disabled = true;
            try {
                const res = await fetch('/admin/billing/api/update-voucher-invoices', { method: 'POST' });
                const data = await res.json();
                if (data.success) { alert(data.message); location.reload(); }
                else alert('Gagal: ' + data.message);
            } catch (e) { alert('Error: ' + e.message); }
            finally { btn.disabled = false; }
        }

        function exportToExcel() {
            // Simple CSV export logic
            let csv = "No,Invoice,Username,Dibuat,Digunakan,Harga,Status\n";
            document.querySelectorAll('#voucherTable tbody tr').forEach(tr => {
                const row = Array.from(tr.cells).map(td => `"${td.innerText.trim()}"`).join(',');
                csv += row + "\n";
            });
            const blob = new Blob([csv], { type: 'text/csv' });
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = 'laporan_voucher.csv';
            a.click();
        }

        document.addEventListener('DOMContentLoaded', function() {
            const ctx = document.getElementById('voucherChart');
            if (!ctx) return;
            new Chart(ctx.getContext('2d'), {
                type: 'doughnut',
                data: {
                    labels: ['Sudah Digunakan', 'Belum Digunakan'],
                    datasets: [{
                        data: [<%= stats.paid_vouchers || 0 %>, <%= stats.unpaid_vouchers || 0 %>],
                        backgroundColor: ['#4cc9f0', '#e9ecef'],
                        borderWidth: 0,
                        hoverOffset: 15
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'bottom', labels: { usePointStyle: true, padding: 20, font: { family: 'Outfit', size: 12 } } }
                    },
                    cutout: '70%'
                }
            });
        });
    </script>
</body>
</html>
