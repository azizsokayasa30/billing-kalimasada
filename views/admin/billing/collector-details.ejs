<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Detail Kolektor - <%= appSettings.companyHeader %></title>
    
    <!-- Modern Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- Core CSS -->
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link href="/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
    <link href="/css/finance-modern.css" rel="stylesheet">
    <link href="/css/dashboard-modern.css" rel="stylesheet">
    
    <style>
        :root {
            --f-primary: #10b981; /* Emerald for Collector context */
            --f-primary-soft: #ecfdf5;
        }

        .collector-profile-card {
            background: white;
            border-radius: var(--f-radius-lg);
            padding: 2rem;
            display: flex;
            align-items: center;
            gap: 2rem;
            margin-bottom: 2rem;
            border: 1px solid var(--f-border);
            position: relative;
            overflow: hidden;
        }

        .collector-profile-card::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 4px;
            height: 100%;
            background: var(--f-primary);
        }

        .collector-avatar {
            width: 80px;
            height: 80px;
            background: var(--f-primary-soft);
            color: var(--f-primary);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            font-weight: 700;
        }

        .collector-meta {
            display: flex;
            gap: 2rem;
            margin-top: 1rem;
        }

        .meta-item {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            color: var(--f-text-light);
            font-size: 0.875rem;
        }

        .meta-item i {
            color: var(--f-primary);
        }

        .status-badge-active {
            background: #dcfce7;
            color: #166534;
            padding: 0.25rem 0.75rem;
            border-radius: 99px;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
        }

        @media (max-width: 768px) {
            .collector-profile-card {
                flex-direction: column;
                text-align: center;
                padding: 1.5rem;
            }
            .collector-meta {
                flex-direction: column;
                gap: 0.5rem;
                align-items: center;
            }
        }
    </style>
</head>
<body class="finance-content-area">
    <div class="f-wrapper">
        <%- include('../../partials/billing-sidebar') %>
        
        <main class="f-main-area main-content">
            <!-- PAGE HEADER (Glass) -->
            <header class="f-header-glass">
                <div>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mb-1" style="background: transparent; padding: 0;">
                            <li class="breadcrumb-item"><a href="/admin/billing/collector-reports" class="text-muted text-decoration-none small">Laporan Kolektor</a></li>
                            <li class="breadcrumb-item active small" aria-current="page">Detail Kolektor</li>
                        </ol>
                    </nav>
                    <h1 class="f-page-title f-premium-text">Profil Kolektor</h1>
                </div>
                <div class="f-actions">
                    <button class="f-btn f-btn-outline" onclick="window.fPjax(window.location.href)" title="Refresh Content">
                        <i class="bi bi-arrow-clockwise"></i>Refresh
                    </button>
                    <button class="f-btn f-btn-outline" onclick="goBack()">
                        <i class="bi bi-arrow-left me-2"></i>Kembali
                    </button>
                    <button class="f-btn f-btn-primary" onclick="exportCollectorDetails()">
                        <i class="bi bi-file-earmark-excel me-2"></i>Export .xlsx
                    </button>
                </div>
            </header>

            <div class="f-container">

                <!-- COLLECTOR PROFILE -->
                <div class="collector-profile-card">
                    <div class="collector-avatar">
                        <%= collector.name.charAt(0).toUpperCase() %>
                    </div>
                    <div>
                        <div class="d-flex align-items-center gap-3">
                            <h2 class="mb-0" style="font-weight: 700; color: var(--f-text-dark);"><%= collector.name %></h2>
                            <span class="status-badge-active">Aktif</span>
                        </div>
                        <div class="collector-meta">
                            <div class="meta-item">
                                <i class="bi bi-telephone-fill"></i>
                                <%= collector.phone || '-' %>
                            </div>
                            <div class="meta-item">
                                <i class="bi bi-envelope-fill"></i>
                                <%= collector.email || '-' %>
                            </div>
                            <div class="meta-item">
                                <i class="bi bi-percent"></i>
                                Komisi: <strong><%= collector.commission_rate || 5 %>%</strong>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- STATS GRID -->
                <div class="f-grid">
                    <div class="f-stat-card">
                        <div class="f-stat-header">
                            <span class="f-stat-label">Total Transaksi</span>
                            <div class="f-stat-icon-wrapper bg-primary-glow">
                                <i class="bi bi-receipt"></i>
                            </div>
                        </div>
                        <div class="f-stat-value f-premium-text"><%= stats.total_payments || 0 %></div>
                    </div>
                    <div class="f-stat-card">
                        <div class="f-stat-header">
                            <span class="f-stat-label">Total Penagihan</span>
                            <div class="f-stat-icon-wrapper bg-success-glow">
                                <i class="bi bi-cash-stack"></i>
                            </div>
                        </div>
                        <div class="f-stat-value f-premium-text text-success">Rp <%= (stats.total_payment_amount || 0).toLocaleString('id-ID') %></div>
                    </div>
                    <div class="f-stat-card">
                        <div class="f-stat-header">
                            <span class="f-stat-label">Total Komisi</span>
                            <div class="f-stat-icon-wrapper bg-warning-glow">
                                <i class="bi bi-piggy-bank"></i>
                            </div>
                        </div>
                        <div class="f-stat-value f-premium-text text-warning">Rp <%= (stats.total_commission || 0).toLocaleString('id-ID') %></div>
                    </div>
                    <div class="f-stat-card">
                        <div class="f-stat-header">
                            <span class="f-stat-label">Bersih ke Kantor</span>
                            <div class="f-stat-icon-wrapper bg-info-glow">
                                <i class="bi bi-wallet2"></i>
                            </div>
                        </div>
                        <div class="f-stat-value f-premium-text text-info">Rp <%= (stats.total_setoran || 0).toLocaleString('id-ID') %></div>
                    </div>
                </div>

                <!-- FILTER & HISTORY -->
                <div class="row mt-4">
                    <div class="col-lg-3">
                        <div class="f-card" style="position: sticky; top: 2rem;">
                            <div class="f-card-header">
                                <h3 class="f-card-title"><i class="bi bi-funnel me-2"></i>Filter Data</h3>
                            </div>
                            <div class="f-card-body">
                                <div class="mb-3">
                                    <label class="f-label">Dari Tanggal</label>
                                    <input type="date" class="f-control" id="dateFrom" value="<%= filters.dateFrom %>">
                                </div>
                                <div class="mb-4">
                                    <label class="f-label">Sampai Tanggal</label>
                                    <input type="date" class="f-control" id="dateTo" value="<%= filters.dateTo %>">
                                </div>
                                <button class="f-btn f-btn-primary w-100" onclick="applyFilters()">
                                    <i class="bi bi-search me-2"></i>Terapkan
                                </button>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-9">
                        <div class="f-card">
                            <div class="f-card-header d-flex justify-content-between align-items-center">
                                <h3 class="f-card-title"><i class="bi bi-clock-history me-2"></i>Riwayat Pembayaran</h3>
                                <span class="badge bg-light text-dark fw-normal"><%= payments.length %> Transaksi</span>
                            </div>
                            <div class="table-responsive">
                                <table class="f-table">
                                    <thead>
                                        <tr>
                                            <th>Tanggal</th>
                                            <th>Pelanggan</th>
                                            <th>Metode</th>
                                            <th class="text-end">Jumlah</th>
                                            <th class="text-end">Komisi</th>
                                            <th class="text-end">Setoran</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% if (payments.length > 0) { %>
                                            <% payments.forEach(function(payment) { %>
                                                <tr>
                                                    <td>
                                                        <div class="d-flex flex-column">
                                                            <span class="fw-medium"><%= new Date(payment.collected_at).toLocaleDateString('id-ID', {day:'2-digit', month:'short', year:'numeric'}) %></span>
                                                            <small class="text-muted"><%= new Date(payment.collected_at).toLocaleTimeString('id-ID', {hour:'2-digit', minute:'2-digit'}) %></small>
                                                        </div>
                                                    </td>
                                                    <td>
                                                        <div class="fw-semibold"><%= payment.customer_name || 'Unknown' %></div>
                                                        <small class="text-muted"><%= payment.customer_phone || '-' %></small>
                                                    </td>
                                                    <td>
                                                        <span class="badge bg-light text-dark fw-normal">
                                                            <%= payment.payment_method || 'Tunai' %>
                                                        </span>
                                                    </td>
                                                    <td class="text-end fw-semibold">
                                                        Rp <%= payment.payment_amount.toLocaleString('id-ID') %>
                                                    </td>
                                                    <td class="text-end text-warning">
                                                        Rp <%= payment.commission_amount.toLocaleString('id-ID') %>
                                                    </td>
                                                    <td class="text-end text-success fw-bold">
                                                        Rp <%= (payment.payment_amount - payment.commission_amount).toLocaleString('id-ID') %>
                                                    </td>
                                                </tr>
                                            <% }); %>
                                        <% } else { %>
                                            <tr>
                                                <td colspan="6" class="text-center py-5">
                                                    <div class="text-muted mb-2"><i class="bi bi-inbox fs-1"></i></div>
                                                    <p class="mb-0">Tidak ada data pembayaran untuk periode ini.</p>
                                                </td>
                                            </tr>
                                        <% } %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Scripts -->
    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script>
        function applyFilters() {
            const dateFrom = document.getElementById('dateFrom').value;
            const dateTo = document.getElementById('dateTo').value;
            
            const params = new URLSearchParams();
            if (dateFrom) params.append('dateFrom', dateFrom);
            if (dateTo) params.append('dateTo', dateTo);
            
            const url = `/admin/billing/collector-details/<%= collector.id %>?${params.toString()}`;
            if (window.fPjax) {
                window.fPjax(url);
            } else {
                window.location.href = url;
            }
        }
        
        function goBack() {
            const url = '/admin/billing/collector-reports';
            if (window.fPjax) {
                window.fPjax(url);
            } else {
                window.location.href = url;
            }
        }
        
        function exportCollectorDetails() {
            const dateFrom = document.getElementById('dateFrom').value;
            const dateTo = document.getElementById('dateTo').value;
            
            const params = new URLSearchParams();
            if (dateFrom) params.append('dateFrom', dateFrom);
            if (dateTo) params.append('dateTo', dateTo);
            
            window.location.href = `/admin/billing/collector-details/<%= collector.id %>/export?${params.toString()}`;
        }

        // Handle sidebar toggle
        document.addEventListener('DOMContentLoaded', () => {
            const sidebarToggle = document.getElementById('sidebarCollapse');
            if (sidebarToggle) {
                sidebarToggle.addEventListener('click', () => {
                    document.querySelector('.f-wrapper').classList.toggle('sidebar-collapsed');
                });
            }
        });
    </script>
</body>
</html>
