<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('../../partials/hard-reload') %>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Detail Kolektor - <%= appSettings.companyHeader %></title>
    
    <!-- Modern Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- Core CSS -->
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link href="/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
    <link href="/css/finance-modern.css" rel="stylesheet">
    <link href="/css/dashboard-modern.css" rel="stylesheet">
    
    <style>
        :root {
            --f-primary: #10b981; /* Emerald for Collector context */
            --f-primary-soft: #ecfdf5;
        }

        .collector-profile-card {
            background: var(--panel-bg, #ffffff);
            border-radius: var(--f-radius-lg);
            padding: 2rem;
            display: flex;
            align-items: center;
            gap: 2rem;
            margin-bottom: 2rem;
            border: 1px solid var(--f-border);
            position: relative;
            overflow: hidden;
        }

        .collector-profile-card::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 4px;
            height: 100%;
            background: var(--f-primary);
        }

        .collector-avatar {
            width: 80px;
            height: 80px;
            background: var(--f-primary-soft);
            color: var(--f-primary);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            font-weight: 700;
        }

        .collector-meta {
            display: flex;
            gap: 2rem;
            margin-top: 1rem;
        }

        .meta-item {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            color: var(--f-text-light);
            font-size: 0.875rem;
        }

        .meta-item i {
            color: var(--f-primary);
        }

        .status-badge-active {
            background: #dcfce7;
            color: #166534;
            padding: 0.25rem 0.75rem;
            border-radius: 99px;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
        }

        @media (max-width: 768px) {
            .collector-profile-card {
                flex-direction: column;
                text-align: center;
                padding: 1.5rem;
            }
            .collector-meta {
                flex-direction: column;
                gap: 0.5rem;
                align-items: center;
            }
        }

        body.collector-details-embed {
            margin: 0;
            overflow-x: hidden;
            min-height: auto;
        }
        .collector-details-embed-main {
            margin-left: 0 !important;
            width: 100% !important;
            max-width: 100% !important;
            min-height: auto !important;
        }
        .collector-embed-compact {
            max-width: 100%;
        }
        .collector-embed-header {
            padding: 0.65rem 1rem !important;
            margin-bottom: 0.5rem !important;
        }
        .collector-embed-header .f-page-title {
            font-size: 1.05rem !important;
        }
    </style>

    <%- include('../../partials/theme-head') %>
</head>
<% var isEmbed = typeof embed !== 'undefined' && embed; %>
<body class="finance-content-area<%= isEmbed ? ' collector-details-embed' : '' %>">
    <% if (!isEmbed) { %>
    <div class="f-wrapper">
        <%- include('../../partials/billing-sidebar') %>
    <% } %>
        <main class="f-main-area main-content<%= isEmbed ? ' collector-details-embed-main' : '' %>">
            <!-- PAGE HEADER (Glass) -->
            <header class="f-header-glass<%= isEmbed ? ' collector-embed-header' : '' %>">
                <div>
                    <% if (isEmbed) { %>
                    <p class="mb-0 small text-muted">Riwayat pembayaran</p>
                    <h1 class="f-page-title f-premium-text mb-0 text-truncate" style="max-width: min(100%, 22rem);"><%= collector.name %></h1>
                    <% } else { %>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mb-1" style="background: transparent; padding: 0;">
                            <li class="breadcrumb-item"><a href="/admin/billing/collector-reports" class="text-muted text-decoration-none small">Laporan Kolektor</a></li>
                            <li class="breadcrumb-item active small" aria-current="page">Detail Kolektor</li>
                        </ol>
                    </nav>
                    <h1 class="f-page-title f-premium-text">Profil Kolektor</h1>
                    <% } %>
                </div>
                <div class="f-actions">
                    <button type="button" class="f-btn f-btn-outline" onclick="window.location.reload()" title="Refresh Content">
                        <i class="bi bi-arrow-clockwise"></i>Refresh
                    </button>
                    <% if (isEmbed) { %>
                    <a class="f-btn f-btn-outline btn-sm py-1 px-2" href="/admin/billing/collector-details/<%= collector.id %>" target="_top" title="Profil &amp; ringkasan lengkap">
                        <i class="bi bi-box-arrow-up-right"></i><span class="d-none d-sm-inline ms-1">Lengkap</span>
                    </a>
                    <button type="button" class="f-btn f-btn-outline btn-sm py-1 px-2" onclick="goBack()">
                        <i class="bi bi-x-lg"></i><span class="d-none d-sm-inline ms-1">Tutup</span>
                    </button>
                    <% } else { %>
                    <button type="button" class="f-btn f-btn-outline" onclick="goBack()">
                        <i class="bi bi-arrow-left me-2"></i>Kembali
                    </button>
                    <% } %>
                    <% if (!isEmbed) { %>
                    <button type="button" class="f-btn f-btn-primary" onclick="exportCollectorDetails()">
                        <i class="bi bi-file-earmark-excel me-2"></i>Export .xlsx
                    </button>
                    <% } %>
                </div>
            </header>

            <div class="f-container<%= isEmbed ? ' collector-embed-compact' : '' %>">

                <% if (!isEmbed) { %>
                <!-- COLLECTOR PROFILE -->
                <div class="collector-profile-card">
                    <div class="collector-avatar">
                        <%= (collector.name && collector.name.length) ? collector.name.charAt(0).toUpperCase() : '?' %>
                    </div>
                    <div>
                        <div class="d-flex align-items-center gap-3">
                            <h2 class="mb-0" style="font-weight: 700; color: var(--f-text-dark);"><%= collector.name %></h2>
                            <span class="status-badge-active bg-success">Aktif</span>
                        </div>
                        <div class="collector-meta">
                            <div class="meta-item">
                                <i class="bi bi-telephone-fill"></i>
                                <%= collector.phone || '-' %>
                            </div>
                            <div class="meta-item">
                                <i class="bi bi-envelope-fill"></i>
                                <%= collector.email || '-' %>
                            </div>
                            <div class="meta-item">
                                <i class="bi bi-percent"></i>
                                Komisi: <strong><%= collector.commission_rate !== null && collector.commission_rate !== undefined ? collector.commission_rate : 5 %>%</strong>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- STATS GRID -->
                <div class="f-grid">
                    <div class="f-stat-card">
                        <div class="f-stat-header">
                            <span class="f-stat-label">Total Tagihan Area</span>
                            <div class="f-stat-icon-wrapper bg-primary-glow">
                                <i class="bi bi-receipt"></i>
                            </div>
                        </div>
                        <div class="f-stat-value f-premium-text">Rp <%= (stats.total_tagihan_area || 0).toLocaleString('id-ID') %></div>
                    </div>
                    <div class="f-stat-card">
                        <div class="f-stat-header">
                            <span class="f-stat-label">Total Lunas</span>
                            <div class="f-stat-icon-wrapper bg-success-glow">
                                <i class="bi bi-check-circle"></i>
                            </div>
                        </div>
                        <div class="f-stat-value f-premium-text text-success">Rp <%= (stats.total_lunas_area || 0).toLocaleString('id-ID') %></div>
                    </div>
                    <div class="f-stat-card">
                        <div class="f-stat-header">
                            <span class="f-stat-label">Belum Lunas</span>
                            <div class="f-stat-icon-wrapper bg-warning-glow">
                                <i class="bi bi-clock-history"></i>
                            </div>
                        </div>
                        <div class="f-stat-value f-premium-text text-warning" style="font-size: 1.5rem;">Rp <%= (stats.total_belum_lunas_amount || 0).toLocaleString('id-ID') %> <small style="font-size: 0.8rem;">(<%= stats.total_belum_lunas_count || 0 %> tgihn)</small></div>
                    </div>
                    <div class="f-stat-card">
                        <div class="f-stat-header">
                            <span class="f-stat-label">Total Komisi</span>
                            <div class="f-stat-icon-wrapper bg-info-glow">
                                <i class="bi bi-cash-stack"></i>
                            </div>
                        </div>
                        <div class="f-stat-value f-premium-text text-info">Rp <%= (stats.total_komisi || 0).toLocaleString('id-ID') %></div>
                    </div>
                </div>
                <% } %>

                <!-- FILTER & HISTORY -->
                <% if (isEmbed) { %>
                <div class="f-card mb-2">
                    <div class="f-card-body py-2 px-3">
                        <div class="d-flex flex-wrap align-items-end gap-2">
                            <div class="flex-grow-1" style="min-width: 8.5rem;">
                                <label class="f-label small mb-1">Bulan</label>
                                <select class="f-select form-select-sm" id="monthFilter">
                                    <% const monthsEmbed = ['Jan', 'Feb', 'Mar', 'Apr', 'Mei', 'Jun', 'Jul', 'Agu', 'Sep', 'Okt', 'Nov', 'Des']; %>
                                    <% for(let m=1; m<=12; m++) { %>
                                        <option value="<%= m %>" <%= filters.month == m ? 'selected' : '' %>><%= monthsEmbed[m-1] %></option>
                                    <% } %>
                                </select>
                            </div>
                            <div style="min-width: 5.5rem;">
                                <label class="f-label small mb-1">Tahun</label>
                                <select class="f-select form-select-sm" id="yearFilter">
                                    <% const currYEmbed = new Date().getFullYear(); %>
                                    <% for(let y=currYEmbed-3; y<=currYEmbed+1; y++) { %>
                                        <option value="<%= y %>" <%= filters.year == y ? 'selected' : '' %>><%= y %></option>
                                    <% } %>
                                </select>
                            </div>
                            <button type="button" class="f-btn f-btn-primary btn-sm py-2" onclick="applyFilters()">
                                <i class="bi bi-search"></i>
                            </button>
                        </div>
                    </div>
                </div>
                <% } else { %>
                <div class="row mt-4">
                    <div class="col-lg-3">
                        <div class="f-card" style="position: sticky; top: 2rem;">
                            <div class="f-card-header">
                                <h3 class="f-card-title"><i class="bi bi-funnel me-2"></i>Filter Data</h3>
                            </div>
                            <div class="f-card-body">
                                <div class="mb-3">
                                    <label class="f-label">Bulan</label>
                                    <select class="f-select" id="monthFilter">
                                        <% const months = ['Januari', 'Februari', 'Maret', 'April', 'Mei', 'Juni', 'Juli', 'Agustus', 'September', 'Oktober', 'November', 'Desember']; %>
                                        <% for(let m=1; m<=12; m++) { %>
                                            <option value="<%= m %>" <%= filters.month == m ? 'selected' : '' %>><%= months[m-1] %></option>
                                        <% } %>
                                    </select>
                                </div>
                                <div class="mb-4">
                                    <label class="f-label">Tahun</label>
                                    <select class="f-select" id="yearFilter">
                                        <% const currY = new Date().getFullYear(); %>
                                        <% for(let y=currY-3; y<=currY+1; y++) { %>
                                            <option value="<%= y %>" <%= filters.year == y ? 'selected' : '' %>><%= y %></option>
                                        <% } %>
                                    </select>
                                </div>
                                <button type="button" class="f-btn f-btn-primary w-100" onclick="applyFilters()">
                                    <i class="bi bi-search me-2"></i>Terapkan
                                </button>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-9">
                <% } %>
                        <div class="f-card">
                            <div class="f-card-header d-flex justify-content-between align-items-center">
                                <h3 class="f-card-title"><i class="bi bi-clock-history me-2"></i>Riwayat Pembayaran</h3>
                                <span class="badge bg-light text-dark fw-normal"><%= payments.length %> Transaksi</span>
                            </div>
                            <div class="table-responsive">
                                <table class="f-table">
                                    <thead>
                                        <tr>
                                            <th>Tanggal</th>
                                            <th>Pelanggan</th>
                                            <th>Metode</th>
                                            <th class="text-end">Jumlah</th>
                                            <th class="text-end">Komisi</th>
                                            <th class="text-end">Setoran</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% if (payments.length > 0) { %>
                                            <% payments.forEach(function(payment) { %>
                                                <tr>
                                                    <td>
                                                        <div class="d-flex flex-column">
                                                            <span class="fw-medium"><%= new Date(payment.collected_at).toLocaleDateString('id-ID', {day:'2-digit', month:'short', year:'numeric'}) %></span>
                                                            <small class="text-muted"><%= new Date(payment.collected_at).toLocaleTimeString('id-ID', {hour:'2-digit', minute:'2-digit'}) %></small>
                                                        </div>
                                                    </td>
                                                    <td>
                                                        <div class="fw-semibold"><%= payment.customer_name || 'Unknown' %></div>
                                                        <small class="text-muted"><%= payment.customer_phone || '-' %></small>
                                                    </td>
                                                    <td>
                                                        <span class="badge bg-light text-dark fw-normal">
                                                            <%= payment.payment_method || 'Tunai' %>
                                                        </span>
                                                    </td>
                                                    <td class="text-end fw-semibold">
                                                        Rp <%= payment.payment_amount.toLocaleString('id-ID') %>
                                                    </td>
                                                    <td class="text-end text-warning">
                                                        Rp <%= payment.commission_amount.toLocaleString('id-ID') %>
                                                    </td>
                                                    <td class="text-end text-success fw-bold">
                                                        Rp <%= (payment.payment_amount - payment.commission_amount).toLocaleString('id-ID') %>
                                                    </td>
                                                </tr>
                                            <% }); %>
                                        <% } else { %>
                                            <tr>
                                                <td colspan="6" class="text-center py-5">
                                                    <div class="text-muted mb-2"><i class="bi bi-inbox fs-1"></i></div>
                                                    <p class="mb-0">Tidak ada data pembayaran untuk periode ini.</p>
                                                </td>
                                            </tr>
                                        <% } %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                <% if (!isEmbed) { %>
                    </div>
                </div>
                <% } %>
            </div>
        </main>
    <% if (!isEmbed) { %>
    </div>
    <% } %>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script>
        var isEmbed = <%= isEmbed ? 'true' : 'false' %>;
        function applyFilters() {
            const month = document.getElementById('monthFilter').value;
            const year = document.getElementById('yearFilter').value;
            
            const params = new URLSearchParams();
            if (month) params.append('month', month);
            if (year) params.append('year', year);
            if (isEmbed) params.append('embed', '1');
            
            window.location.href = `/admin/billing/collector-details/<%= collector.id %>?${params.toString()}`;
        }
        
        function goBack() {
            if (isEmbed) {
                try {
                    window.parent.postMessage({ type: 'billing-close-collector-detail' }, '*');
                } catch (e) {}
                return;
            }
            window.location.href = '/admin/billing/collector-reports';
        }
        
        function exportCollectorDetails() {
            const month = document.getElementById('monthFilter').value;
            const year = document.getElementById('yearFilter').value;
            
            const params = new URLSearchParams();
            if (month) params.append('month', month);
            if (year) params.append('year', year);
            
            window.location.href = `/admin/billing/collector-details/<%= collector.id %>/export?${params.toString()}`;
        }
    </script>
</body>
</html>

