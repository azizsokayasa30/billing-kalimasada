        // PPN Calculation Functions
        function initializePPNCalculation() {
            // Add Package Modal PPN calculation
            $('#price, #tax_rate').on('input', function() {
                calculatePriceWithTax('price', 'tax_rate', 'price_with_tax');
            });

            // Edit Package Modal PPN calculation
            $('#edit_price, #edit_tax_rate').on('input', function() {
                calculatePriceWithTax('edit_price', 'edit_tax_rate', 'edit_price_with_tax');
            });
            
            // Checkbox PPN event handlers
            $('#enable_tax').on('change', function() {
                toggleTaxRateGroup('tax_rate_group', this.checked);
                calculatePriceWithTax('price', 'tax_rate', 'price_with_tax');
            });
            
            $('#edit_enable_tax').on('change', function() {
                toggleTaxRateGroup('edit_tax_rate_group', this.checked);
                calculatePriceWithTax('edit_price', 'edit_tax_rate', 'edit_price_with_tax');
            });
        }

        function toggleTaxRateGroup(groupId, enabled) {
            const group = $('#' + groupId);
            const inputs = group.find('input, select');
            
            if (enabled) {
                group.show();
                inputs.prop('disabled', false);
            } else {
                group.hide();
                inputs.prop('disabled', true);
                // Set tax rate to 0 when disabled
                if (groupId === 'tax_rate_group') {
                    $('#tax_rate').val(0);
                } else {
                    $('#edit_tax_rate').val(0);
                }
            }
        }

        function calculatePriceWithTax(priceId, taxId, resultId) {
            const price = parseFloat($('#' + priceId).val()) || 0;
            let taxRate = 0;
            
            // Check if tax is enabled
            if (priceId === 'price') {
                taxRate = $('#enable_tax').is(':checked') ? (parseFloat($('#' + taxId).val()) || 0) : 0;
            } else {
                taxRate = $('#edit_enable_tax').is(':checked') ? (parseFloat($('#' + taxId).val()) || 0) : 0;
            }
            
            // Jika PPN = 0 atau tidak diaktifkan, harga tidak berubah
            if (taxRate === 0) {
                $('#' + resultId).val(Math.round(price).toLocaleString('id-ID'));
                // Tambahkan class atau style untuk menunjukkan tidak ada PPN
                $('#' + resultId).addClass('text-muted');
                // Tambahkan tooltip atau info
                $('#' + resultId).attr('title', 'Tidak ada PPN (0%)');
            } else {
                const priceWithTax = price * (1 + taxRate / 100);
                $('#' + resultId).val(Math.round(priceWithTax).toLocaleString('id-ID'));
                // Hapus class dan tooltip
                $('#' + resultId).removeClass('text-muted');
                $('#' + resultId).removeAttr('title');
            }
        }

        function setDefaultTaxRate() {
            // Set tax rate to 0 by default (no PPN unless explicitly enabled)
            $('#tax_rate').val(0);
            $('#edit_tax_rate').val(0);
            
            // Don't trigger calculation since checkbox is unchecked by default
            console.log('Tax rate set to 0% by default (no PPN)');
        }

        // Image preview functionality
        function setupImagePreview() {
            // Add package image preview
            $('#image').on('change', function() {
                const file = this.files[0];
                if (file) {
                    if (file.type !== 'image/jpeg' && file.type !== 'image/jpg') {
                        showAlert('danger', 'Hanya file JPG yang diperbolehkan');
                        $(this).val('');
                        $('#imagePreview').hide();
                        return;
                    }
                    
                    if (file.size > 2 * 1024 * 1024) { // 2MB limit
                        showAlert('danger', 'Ukuran file maksimal 2MB');
                        $(this).val('');
                        $('#imagePreview').hide();
                        return;
                    }
                    
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        $('#imagePreview img').attr('src', e.target.result);
                        $('#imagePreview').show();
                    };
                    reader.readAsDataURL(file);
                } else {
                    $('#imagePreview').hide();
                }
            });
            
            // Edit package image preview
            $('#edit_image').on('change', function() {
                const file = this.files[0];
                if (file) {
                    if (file.type !== 'image/jpeg' && file.type !== 'image/jpg') {
                        showAlert('danger', 'Hanya file JPG yang diperbolehkan');
                        $(this).val('');
                        $('#editImagePreview').hide();
                        return;
                    }
                    
                    if (file.size > 2 * 1024 * 1024) { // 2MB limit
                        showAlert('danger', 'Ukuran file maksimal 2MB');
                        $(this).val('');
                        $('#editImagePreview').hide();
                        return;
                    }
                    
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        $('#editImagePreview img').attr('src', e.target.result);
                        $('#editImagePreview').show();
                    };
                    reader.readAsDataURL(file);
                } else {
                    $('#editImagePreview').hide();
                }
            });
        }

        // Store all profiles with NAS info (will be populated from API)
        let allProfiles = [];
        
        // Fetch and populate PPPoE Profiles from Mikrotik with NAS filtering
        function loadPPPoEProfiles(selectSelector, selectedValue = 'default', routerId = null) {
            const sel = document.querySelector(selectSelector);
            if (!sel) return;
            
            console.log('🔍 Loading PPPoE profiles:', { selectSelector, selectedValue, routerId });
            
            // If router_id is provided, filter profiles by NAS
            let url = '/admin/mikrotik/profiles/api';
            if (routerId) {
                url += '?router_id=' + routerId;
            }
            
            // show loading option
            sel.innerHTML = '<option>Loading...</option>';
            sel.disabled = false;
            
            fetch(url)
                .then(r => {
                    console.log('📡 API Response status:', r.status);
                    return r.json();
                })
                .then(data => {
                    console.log('📦 API Response data:', data);
                    let profiles = [];
                    if (data && data.success && Array.isArray(data.profiles)) {
                        profiles = data.profiles;
                        console.log('✅ Profiles received:', profiles.length);
                        
                        // Store all profiles if not router-specific
                        if (!routerId) {
                            allProfiles = profiles;
                        }
                    } else {
                        console.warn('⚠️ Invalid response format:', data);
                    }
                    
                    // Build unique name list from profiles
                    // If routerId is provided, profiles should already be filtered by backend
                    // But we also filter client-side as backup
                    let filteredProfiles = profiles;
                    if (routerId && profiles.length > 0) {
                        filteredProfiles = profiles.filter(p => {
                            // Check if profile has nas_id matching routerId
                            const matches = !p.nas_id || p.nas_id === parseInt(routerId);
                            console.log(`Profile ${p.name}: nas_id=${p.nas_id}, routerId=${routerId}, matches=${matches}`);
                            return matches;
                        });
                        console.log(`🔍 Filtered profiles for router ${routerId}:`, filteredProfiles.length);
                    }
                    
                    // Build unique name list
                    const names = Array.from(new Set(filteredProfiles.map(p => {
                        // Handle both 'name' and 'name' property
                        return (p.name || p['name'] || '').trim();
                    }).filter(Boolean)));
                    
                    console.log('📝 Profile names found:', names);
                    
                    // Fallback ensure 'default' exists if we have profiles
                    if (names.length > 0 && !names.includes('default')) {
                        names.unshift('default');
                    }
                    
                    sel.innerHTML = '';
                    
                    // If no profiles found and routerId is provided
                    if (filteredProfiles.length === 0 && routerId) {
                        const opt = document.createElement('option');
                        opt.value = '';
                        opt.textContent = 'Tidak ada profile untuk NAS ini';
                        sel.appendChild(opt);
                        sel.disabled = false;
                        console.warn('⚠️ No profiles found for router:', routerId);
                        return;
                    }
                    
                    // If no profiles at all
                    if (names.length === 0) {
                        const opt = document.createElement('option');
                        opt.value = 'default';
                        opt.textContent = 'default';
                        sel.appendChild(opt);
                        sel.value = 'default';
                        console.warn('⚠️ No profiles available, using default');
                        return;
                    }
                    
                    // Populate dropdown with profile names
                    names.forEach(name => {
                        const opt = document.createElement('option');
                        opt.value = name;
                        opt.textContent = name;
                        sel.appendChild(opt);
                    });
                    
                    // Set selected value
                    if (selectedValue && names.includes(selectedValue)) {
                        sel.value = selectedValue;
                    } else if (names.length > 0) {
                        sel.value = names[0];
                    }
                    
                    console.log('✅ Profile dropdown populated. Selected:', sel.value);
                    
                    // If selectedValue is not in list but exists, append it
                    if (selectedValue && !names.includes(selectedValue) && selectedValue !== 'default') {
                        const opt = document.createElement('option');
                        opt.value = selectedValue;
                        opt.textContent = selectedValue;
                        sel.appendChild(opt);
                        sel.value = selectedValue;
                        console.log('➕ Added missing profile to dropdown:', selectedValue);
                    }
                })
                .catch(err => {
                    console.error('❌ Error loading PPPoE profiles:', err);
                    if (typeof showAlert === 'function') {
                        showAlert('danger', 'Gagal memuat PPPoE profiles dari Mikrotik: ' + err.message);
                    }
                    // minimal fallback
                    sel.innerHTML = '<option value="default">default</option>';
                    if (selectedValue && selectedValue !== 'default') {
                        const opt = document.createElement('option');
                        opt.value = selectedValue;
                        opt.textContent = selectedValue;
                        sel.appendChild(opt);
                    }
                    sel.value = selectedValue || 'default';
                    sel.disabled = false;
                });
        }
        
        // Function to update profile dropdown based on selected NAS
        function updateProfileDropdownByNAS(routerSelectId, profileSelectId) {
            const routerSelect = document.getElementById(routerSelectId);
            const profileSelect = document.getElementById(profileSelectId);
            
            if (!routerSelect || !profileSelect) return;
            
            const routerId = routerSelect.value;
            if (!routerId) {
                profileSelect.innerHTML = '<option value="">Pilih NAS terlebih dahulu</option>';
                profileSelect.disabled = true;
                return;
            }
            
            profileSelect.disabled = false;
            // Get current selected profile value
            const currentValue = profileSelect.value || 'default';
            loadPPPoEProfiles('#' + profileSelectId, currentValue, parseInt(routerId));
        }
        
