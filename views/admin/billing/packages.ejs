<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('../../partials/hard-reload') %>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kelola Paket Internet - Admin Portal</title>
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link href="/vendor/boxicons/boxicons.min.css" rel="stylesheet">
    <link href="/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
    <link href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" rel="stylesheet">
    <!-- Admin Mobile Optimizations -->
    <link href="/css/admin-mobile.css" rel="stylesheet">
    <style>
        .toast {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 9999;
            min-width: 300px;
        }
    </style>

    <!-- GLOBAL THEME INJECTION -->
    <script>
      (function(){
        if(window.__theme_init) return; window.__theme_init=true;
        var t=localStorage.getItem('kalimasada_theme');
        if(!t) t=window.matchMedia('(prefers-color-scheme: dark)').matches?'dark':'light';
        document.documentElement.setAttribute('data-theme',t);
      })();
    </script>
    <link href="/css/dark-theme-global.css?v=2" rel="stylesheet">
    <link href="/css/theme-system.css?v=2" rel="stylesheet">
    <link href="/css/theme-overrides.css?v=1" rel="stylesheet">
    <!-- END GLOBAL THEME INJECTION -->
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <%- include('../../partials/billing-sidebar') %>

            <!-- Main content -->
            <main class="col-md-10 ms-sm-auto col-lg-10 px-md-4 main-content">
                <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                    <h1 class="h2">
                        <i class="bi bi-box-seam-fill"></i> Kelola Paket Internet
                    </h1>
                    <div>
                        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addPackageModal">
                            <i class="bi bi-plus-lg"></i> Tambah Paket
                        </button>
                    </div>
                </div>

                <!-- Packages Table -->
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0">
                            <i class="bi bi-list-ul"></i> Daftar Paket
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table id="packagesTable" class="table table-striped table-hover">
                                <thead>
                                    <tr>
                                        <th>Nama Paket</th>
                                        <th>Kecepatan</th>
                                        <th>Harga (Sebelum PPN)</th>
                                        <th>PPN</th>
                                        <th>Harga (Setelah PPN)</th>
                                        <th>PPPoE Profile</th>
                                        <th>NAS (Router)</th>
                                        <th>Deskripsi</th>
                                        <th>Status</th>
                                        <th>Aksi</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (packages && packages.length > 0) { %>
                                        <% packages.forEach(function(package) { %>
                                            <tr>
                                                <td>
                                                    <span class="text-body fw-bold"><%= package.name %></span>
                                                </td>
                                                <td><%= package.speed %></td>
                                                <td>Rp <%= parseFloat(package.price).toLocaleString('id-ID') %></td>
                                                <td>
                                                    <% if (package.tax_rate === 0) { %>
                                                        <span class="badge bg-secondary">0% (Tidak Ada PPN)</span>
                                                    <% } else if (package.tax_rate) { %>
                                                        <span class="badge bg-warning"><%= package.tax_rate.toFixed(2) %>%</span>
                                                    <% } else { %>
                                                        <span class="badge bg-warning">11.00%</span>
                                                    <% } %>
                                                </td>
                                                <td class="text-success fw-bold">
                                                    <% if (package.tax_rate === 0) { %>
                                                        Rp <%= parseFloat(package.price).toLocaleString('id-ID') %>
                                                        <small class="text-muted d-block">(Harga sama, tidak ada PPN)</small>
                                                    <% } else if (package.tax_rate) { %>
                                                        Rp <%= ((parseFloat(package.price) * (1 + package.tax_rate / 100)).toFixed(0)).toLocaleString('id-ID') %>
                                                    <% } else { %>
                                                        Rp <%= ((parseFloat(package.price) * 1.11).toFixed(0)).toLocaleString('id-ID') %>
                                                    <% } %>
                                                </td>
                                                <td><span class="badge bg-info"><%= package.pppoe_profile || 'default' %></span></td>
                                                <td>
                                                    <% 
                                                    if (package.nas_ip) {
                                                        // Mode RADIUS: show NAS IP
                                                    %>
                                                        <span class="badge bg-info">RADIUS: <%= package.nas_ip %></span>
                                                    <% 
                                                    } else if (routers && package.router_id) {
                                                        // Mode Mikrotik API: show router
                                                        const router = routers.find(r => r.id === package.router_id);
                                                        if (router) {
                                                    %>
                                                        <span class="badge bg-secondary"><%= router.name %> (<%= router.nas_ip %>)</span>
                                                    <% 
                                                        } else {
                                                    %>
                                                        <span class="badge bg-warning">NAS tidak ditemukan</span>
                                                    <%
                                                        }
                                                    } else {
                                                    %>
                                                        <span class="text-muted">-</span>
                                                    <%
                                                    }
                                                    %>
                                                </td>
                                                <td><%= package.description || '-' %></td>
                                                <td>
                                                    <span class="badge bg-success">Aktif</span>
                                                </td>
                                                <td>
                                                    <div class="btn-group" role="group">
                                                        <button class="btn btn-sm btn-primary" onclick="editPackage('<%= package.id %>')">
                                                            <i class="bi bi-pencil-fill"></i>
                                                        </button>
                                                        <button class="btn btn-sm btn-info" onclick="viewPackage('<%= package.id %>')">
                                                            <i class="bi bi-eye-fill"></i>
                                                        </button>
                                                        <button class="btn btn-sm btn-danger" onclick="deletePackage('<%= package.id %>')">
                                                            <i class="bi bi-trash3-fill"></i>
                                                        </button>
                                                    </div>
                                                </td>
                                            </tr>
                                        <% }); %>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <!-- Add Package Modal -->
    <div class="modal fade" id="addPackageModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Tambah Paket Baru</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form id="addPackageForm">
                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="name" class="form-label">Nama Paket</label>
                            <input type="text" class="form-control" id="name" name="name" required>
                        </div>
                        <div class="mb-3">
                            <label for="speed" class="form-label">Kecepatan</label>
                            <input type="text" class="form-control" id="speed" name="speed" placeholder="Contoh: 10 Mbps" required>
                        </div>
                        <div class="mb-3">
                            <label for="price" class="form-label">Harga (Sebelum PPN)</label>
                            <input type="number" class="form-control" id="price" name="price" required>
                        </div>
                        <div class="mb-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="enable_tax" name="enable_tax">
                                <label class="form-check-label" for="enable_tax">
                                    Aktifkan PPN
                                </label>
                                <small class="form-text text-muted d-block">Centang untuk mengaktifkan PPN, kosongkan untuk tidak ada PPN</small>
                            </div>
                        </div>
                        <div class="mb-3" id="tax_rate_group">
                            <label for="tax_rate" class="form-label">PPN (%)</label>
                            <input type="number" class="form-control" id="tax_rate" name="tax_rate" step="0.01" min="0" max="100" value="0">
                            <small class="form-text text-muted">Persentase PPN yang akan ditambahkan ke harga paket.</small>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Harga Setelah PPN</label>
                            <div class="input-group">
                                <span class="input-group-text">Rp</span>
                                <input type="text" class="form-control" id="price_with_tax" readonly>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label for="description" class="form-label">Deskripsi</label>
                            <textarea class="form-control" id="description" name="description" rows="3"></textarea>
                        </div>
                        <% if (typeof authMode !== 'undefined' && authMode === 'radius') { %>
                            <!-- Mode RADIUS: Input NAS IP -->
                            <div class="mb-3">
                                <label for="nas_ip" class="form-label">NAS IP (RADIUS) *</label>
                                <input type="text" class="form-control" id="nas_ip" name="nas_ip" placeholder="Contoh: 192.168.1.1" required>
                                <small class="form-text text-muted">Masukkan IP address NAS (Mikrotik) yang akan connect ke RADIUS server.</small>
                            </div>
                        <% } else { %>
                            <!-- Mode Mikrotik API: Pilih Router -->
                        <div class="mb-3">
                            <label for="router_id" class="form-label">NAS (Router) *</label>
                            <select class="form-select" id="router_id" name="router_id" required>
                                <% if (routers && routers.length > 0) { %>
                                    <option value="">Pilih NAS</option>
                                    <% routers.forEach(function(router) { %>
                                        <option value="<%= router.id %>"><%= router.name %> (<%= router.nas_ip %>)</option>
                                    <% }); %>
                                <% } else { %>
                                    <option value="">Tidak ada router tersedia</option>
                                <% } %>
                            </select>
                            <small class="form-text text-muted">Pilih router/NAS untuk paket ini. Profile akan difilter berdasarkan NAS yang dipilih.</small>
                        </div>
                        <% } %>
                        <div class="mb-3">
                            <label for="pppoe_profile" class="form-label">PPPoE Profile</label>
                            <div class="input-group">
                                <% if (typeof authMode !== 'undefined' && authMode === 'radius') { %>
                                    <select class="form-select" id="pppoe_profile" name="pppoe_profile" required>
                                        <option value="">Memuat daftar profil...</option>
                                    </select>
                                    <button class="btn btn-outline-secondary" type="button" id="reloadRadiusProfilesAdd" title="Refresh daftar profil">
                                        <i class="bi bi-arrow-clockwise"></i> Refresh
                                    </button>
                                <% } else { %>
                                <select class="form-select" id="pppoe_profile" name="pppoe_profile" required>
                                    <option value="">Pilih NAS terlebih dahulu</option>
                                </select>
                                <button class="btn btn-outline-secondary" type="button" id="reloadProfilesAdd">Reload</button>
                                <% } %>
                            </div>
                            <small class="form-text text-muted">
                                <% if (typeof authMode !== 'undefined' && authMode === 'radius') { %>
                                    <i class="bi bi-info-circle"></i> Pilih profil PPPoE yang sudah ada di RADIUS server (groupname di radusergroup/radgroupreply). 
                                    Atau ketik langsung jika profil belum ada di daftar.
                                    <div id="profileStatusAdd" class="mt-2"></div>
                                <% } else { %>
                                    Pilih profile PPPoE dari Mikrotik. Profile akan muncul setelah memilih NAS.
                                <% } %>
                            </small>
                        </div>
                        
                        <div class="mb-3">
                            <label for="image" class="form-label">Gambar Paket (JPG)</label>
                            <input type="file" class="form-control" id="image" name="image" accept="image/jpeg,image/jpg">
                            <small class="form-text text-muted">Unggah gambar JPG untuk paket ini. Maksimal 2MB.</small>
                            <div id="imagePreview" class="mt-2" style="display: none;">
                                <img src="" alt="Preview" style="max-width: 200px; max-height: 200px; border-radius: 8px;">
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
                        <button type="submit" class="btn btn-primary">Simpan Paket</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Edit Package Modal -->
    <div class="modal fade" id="editPackageModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Edit Paket</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form id="editPackageForm">
                    <div class="modal-body">
                        <input type="hidden" id="edit_package_id" name="package_id">
                        <div class="mb-3">
                            <label for="edit_name" class="form-label">Nama Paket</label>
                            <input type="text" class="form-control" id="edit_name" name="name" required>
                        </div>
                        <div class="mb-3">
                            <label for="edit_speed" class="form-label">Kecepatan</label>
                            <input type="text" class="form-control" id="edit_speed" name="speed" required>
                        </div>
                        <div class="mb-3">
                            <label for="edit_price" class="form-label">Harga (Sebelum PPN)</label>
                            <input type="number" class="form-control" id="edit_price" name="price" required>
                        </div>
                        <div class="mb-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="edit_enable_tax" name="enable_tax">
                                <label class="form-check-label" for="edit_enable_tax">
                                    Aktifkan PPN
                                </label>
                                <small class="form-text text-muted d-block">Centang untuk mengaktifkan PPN, kosongkan untuk tidak ada PPN</small>
                            </div>
                        </div>
                        <div class="mb-3" id="edit_tax_rate_group">
                            <label for="edit_tax_rate" class="form-label">PPN (%)</label>
                            <input type="number" class="form-control" id="edit_tax_rate" name="tax_rate" step="0.01" min="0" max="100">
                            <small class="form-text text-muted">Persentase PPN yang akan ditambahkan ke harga paket.</small>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Harga Setelah PPN</label>
                            <div class="input-group">
                                <span class="input-group-text">Rp</span>
                                <input type="text" class="form-control" id="edit_price_with_tax" readonly>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label for="edit_description" class="form-label">Deskripsi</label>
                            <textarea class="form-control" id="edit_description" name="description" rows="3"></textarea>
                        </div>
                        <% if (typeof authMode !== 'undefined' && authMode === 'radius') { %>
                            <!-- Mode RADIUS: Input NAS IP -->
                            <div class="mb-3">
                                <label for="edit_nas_ip" class="form-label">NAS IP (RADIUS) *</label>
                                <input type="text" class="form-control" id="edit_nas_ip" name="nas_ip" placeholder="Contoh: 192.168.1.1" required>
                                <small class="form-text text-muted">Masukkan IP address NAS (Mikrotik) yang akan connect ke RADIUS server.</small>
                            </div>
                        <% } else { %>
                            <!-- Mode Mikrotik API: Pilih Router -->
                        <div class="mb-3">
                            <label for="edit_router_id" class="form-label">NAS (Router) *</label>
                            <select class="form-select" id="edit_router_id" name="router_id" required>
                                <% if (routers && routers.length > 0) { %>
                                    <option value="">Pilih NAS</option>
                                    <% routers.forEach(function(router) { %>
                                        <option value="<%= router.id %>"><%= router.name %> (<%= router.nas_ip %>)</option>
                                    <% }); %>
                                <% } else { %>
                                    <option value="">Tidak ada router tersedia</option>
                                <% } %>
                            </select>
                            <small class="form-text text-muted">Pilih router/NAS untuk paket ini. Profile akan difilter berdasarkan NAS yang dipilih.</small>
                        </div>
                        <% } %>
                        <div class="mb-3">
                            <label for="edit_pppoe_profile" class="form-label">PPPoE Profile</label>
                            <div class="input-group">
                                <% if (typeof authMode !== 'undefined' && authMode === 'radius') { %>
                                    <select class="form-select" id="edit_pppoe_profile" name="pppoe_profile" required>
                                        <option value="">Memuat daftar profil...</option>
                                    </select>
                                    <button class="btn btn-outline-secondary" type="button" id="reloadRadiusProfilesEdit" title="Refresh daftar profil">
                                        <i class="bi bi-arrow-clockwise"></i> Refresh
                                    </button>
                                <% } else { %>
                                <select class="form-select" id="edit_pppoe_profile" name="pppoe_profile" required>
                                    <option value="">Pilih NAS terlebih dahulu</option>
                                </select>
                                <button class="btn btn-outline-secondary" type="button" id="reloadProfilesEdit">Reload</button>
                                <% } %>
                            </div>
                            <small class="form-text text-muted">
                                <% if (typeof authMode !== 'undefined' && authMode === 'radius') { %>
                                    <i class="bi bi-info-circle"></i> Pilih profil PPPoE yang sudah ada di RADIUS server (groupname di radusergroup/radgroupreply). 
                                    Atau ketik langsung jika profil belum ada di daftar.
                                    <div id="profileStatusEdit" class="mt-2"></div>
                                <% } else { %>
                                    Pilih profile PPPoE dari Mikrotik. Profile akan muncul setelah memilih NAS.
                                <% } %>
                            </small>
                        </div>
                        
                        <div class="mb-3">
                            <label for="edit_image" class="form-label">Gambar Paket (JPG)</label>
                            <input type="file" class="form-control" id="edit_image" name="image" accept="image/jpeg,image/jpg">
                            <small class="form-text text-muted">Unggah gambar JPG untuk paket ini. Maksimal 2MB.</small>
                            <div id="editImagePreview" class="mt-2" style="display: none;">
                                <img src="" alt="Preview" style="max-width: 200px; max-height: 200px; border-radius: 8px;">
                            </div>
                            <div id="currentImageContainer" class="mt-2" style="display: none;">
                                <small class="form-text text-muted">Gambar saat ini:</small>
                                <img id="currentImage" src="" alt="Current Image" style="max-width: 200px; max-height: 200px; border-radius: 8px; display: block; margin-top: 5px;">
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
                        <button type="submit" class="btn btn-primary">Update Paket</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- View Package Modal -->
    <div class="modal fade" id="viewPackageModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Detail Paket</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="packageDetails">
                    <!-- Package details will be loaded here -->
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Tutup</button>
                </div>
            </div>
        </div>
    </div>

    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script>
        $(document).ready(function() {
            $('#packagesTable').DataTable({
                language: {
                    url: 'https://cdn.datatables.net/plug-ins/1.13.6/i18n/id.json',
                    emptyTable: "Tidak ada data yang tersedia",
                    info: "Menampilkan _START_ sampai _END_ dari _TOTAL_ entri",
                    infoEmpty: "Menampilkan 0 sampai 0 dari 0 entri",
                    infoFiltered: "(disaring dari _MAX_ entri keseluruhan)",
                    lengthMenu: "Tampilkan _MENU_ entri",
                    loadingRecords: "Sedang memuat...",
                    processing: "Sedang memproses...",
                    search: "Cari:",
                    zeroRecords: "Tidak ditemukan data yang sesuai",
                    paginate: {
                        first: "Pertama",
                        last: "Terakhir",
                        next: "Selanjutnya",
                        previous: "Sebelumnya"
                    }
                },
                pageLength: 25,
                lengthMenu: [[10, 25, 50, 100], [10, 25, 50, 100]]
            });

            // Setup image preview functionality
            setupImagePreview();

            // Load profiles into Add form on open
            $('#addPackageModal').on('shown.bs.modal', function(){
                console.log('🔍 Modal opened - resetting form...');
                // Reset form and hide tax group
                $('#addPackageForm')[0].reset();
                $('#enable_tax').prop('checked', false);
                $('#tax_rate_group').hide();
                $('#tax_rate_group input').prop('disabled', true);
                $('#tax_rate').val(0);
                // Reset NAS and profile dropdowns
                                <% if (typeof authMode !== 'undefined' && authMode === 'radius') { %>
                $('#nas_ip').val('');
                $('#pppoe_profile').html('<option value="">Memuat daftar profil...</option>');
                loadRadiusGroupnames('#pppoe_profile', '');
                $('#profileStatusAdd').html('');
            <% } else { %>
                $('#router_id').val('');
                $('#pppoe_profile').html('<option value="">Pilih NAS terlebih dahulu</option>').prop('disabled', true);
            <% } %>
                // Ensure price with tax shows base price
                const price = parseFloat($('#price').val()) || 0;
                $('#price_with_tax').val(price.toLocaleString('id-ID'));
                
                console.log('   - Form reset completed');
                console.log('   - Checkbox checked:', $('#enable_tax').is(':checked'));
                console.log('   - Tax rate value:', $('#tax_rate').val());
                console.log('   - Tax rate disabled:', $('#tax_rate').prop('disabled'));
            });
            // Manual reload buttons
            $('#reloadProfilesAdd').on('click', function(){ 
                const routerId = $('#router_id').val();
                if (routerId) {
                    loadPPPoEProfiles('#pppoe_profile', $('#pppoe_profile').val(), parseInt(routerId));
                } else {
                    showAlert('warning', 'Pilih NAS terlebih dahulu');
                }
            });
            $('#reloadProfilesEdit').on('click', function(){ 
                const routerId = $('#edit_router_id').val();
                if (routerId) {
                    loadPPPoEProfiles('#edit_pppoe_profile', $('#edit_pppoe_profile').val(), parseInt(routerId));
                } else {
                    showAlert('warning', 'Pilih NAS terlebih dahulu');
                }
            });
            
            // RADIUS mode: Reload groupnames
            <% if (typeof authMode !== 'undefined' && authMode === 'radius') { %>
            $('#reloadRadiusProfilesAdd').on('click', function(){ 
                loadRadiusGroupnames('#pppoe_profile', $('#pppoe_profile').val());
            });
            $('#reloadRadiusProfilesEdit').on('click', function(){ 
                loadRadiusGroupnames('#edit_pppoe_profile', $('#edit_pppoe_profile').val());
            });
            
            // Function to load RADIUS groupnames from /admin/mikrotik/profiles/api
            function loadRadiusGroupnames(selectSelector, selectedValue = '') {
                const sel = $(selectSelector);
                if (!sel || sel.length === 0) {
                    console.error('Selector not found:', selectSelector);
                    return;
                }
                
                sel.html('<option value="">Memuat daftar profil...</option>');
                
                // Fetch dari /admin/mikrotik/profiles/api (otomatis detect RADIUS atau Mikrotik API)
                fetch('/admin/mikrotik/profiles/api')
                    .then(response => {
                        if (!response.ok) {
                            throw new Error('HTTP error! status: ' + response.status);
                        }
                        return response.json();
                    })
                    .then(data => {
                        if (data.success && data.profiles && data.profiles.length > 0) {
