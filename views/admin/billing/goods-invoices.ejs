<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Admin Portal</title>
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link href="/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
    <link href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" rel="stylesheet">
    <link href="/css/admin-mobile.css" rel="stylesheet">
    <%- include('../../partials/theme-head') %>
    <style>
        html[data-theme="light"] .modal-content {
            background-color: #ffffff !important;
            color: #0f172a !important;
            border: 1px solid #dee2e6 !important;
        }
        .item-row {
            background-color: rgba(0,0,0,0.02);
            padding: 10px;
            border-radius: 5px;
            margin-bottom: 10px;
            border: 1px solid var(--bs-border-color);
        }
        html[data-theme="dark"] .item-row {
            background-color: rgba(255,255,255,0.05);
            color: #e2e8f0;
        }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <%- include('../../partials/billing-sidebar') %>

            <main class="col-md-10 ms-sm-auto col-lg-10 px-md-4 main-content">
                <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                    <h1 class="h2">
                        <i class="bi bi-cart"></i> <%= title %>
                    </h1>
                    <div class="d-flex gap-2">
                        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addGoodsInvoiceModal">
                            <i class="bi bi-plus-lg"></i> Buat Invoice Penjualan
                        </button>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Daftar Invoice Penjualan</h5>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table id="goodsInvoicesTable" class="table table-striped table-hover">
                                <thead>
                                    <tr>
                                        <th>No. Invoice</th>
                                        <th>Tanggal</th>
                                        <th>Customer</th>
                                        <th>Total</th>
                                        <th>Status</th>
                                        <th>Aksi</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% invoices.forEach(function(invoice) { %>
                                    <tr>
                                        <td><%= invoice.invoice_number %></td>
                                        <td><%= new Date(invoice.created_at).toLocaleDateString('id-ID') %></td>
                                        <td>
                                            <%= invoice.customer_name %><br>
                                            <small class="text-muted"><%= invoice.customer_phone || '-' %></small>
                                        </td>
                                        <td>Rp <%= invoice.total_amount.toLocaleString('id-ID') %></td>
                                        <td>
                                            <% if(invoice.status === 'paid') { %>
                                                <span class="badge bg-success">Lunas</span>
                                            <% } else { %>
                                                <span class="badge bg-danger">Belum Lunas</span>
                                            <% } %>
                                        </td>
                                        <td>
                                            <a href="/admin/billing/goods-invoices/<%= invoice.id %>/detail" class="btn btn-sm btn-info text-white" title="Detail">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a href="/admin/billing/goods-invoices/<%= invoice.id %>/print" target="_blank" class="btn btn-sm btn-secondary" title="Print">
                                                <i class="bi bi-printer"></i>
                                            </a>
                                            <% if(invoice.status !== 'paid') { %>
                                            <button class="btn btn-sm btn-success btn-pay" data-id="<%= invoice.id %>" title="Tandai Lunas">
                                                <i class="bi bi-check-circle"></i>
                                            </button>
                                            <% } %>
                                            <button class="btn btn-sm btn-danger btn-delete" data-id="<%= invoice.id %>" title="Hapus">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <!-- Modal Create Goods Invoice -->
    <div class="modal fade" id="addGoodsInvoiceModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Buat Invoice Penjualan</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="addGoodsInvoiceForm">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label">No. Invoice</label>
                                <input type="text" class="form-control" id="invoiceNumber" readonly>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Nama Customer <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="customerName" required>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label">Nomor HP</label>
                                <input type="text" class="form-control" id="customerPhone">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Alamat</label>
                                <input type="text" class="form-control" id="customerAddress">
                            </div>
                        </div>
                        
                        <hr>
                        <h6>Daftar Item</h6>
                        <div id="itemsContainer">
                            <div class="item-row row align-items-end">
                                <div class="col-md-5">
                                    <label class="form-label">Nama Item <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control item-name" required>
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label">Qty <span class="text-danger">*</span></label>
                                    <input type="number" class="form-control item-qty" value="1" min="1" required>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Harga Satuan (Rp) <span class="text-danger">*</span></label>
                                    <input type="number" class="form-control item-price" required>
                                </div>
                                <div class="col-md-1">
                                    <button type="button" class="btn btn-danger btn-remove-item" disabled><i class="bi bi-x"></i></button>
                                </div>
                            </div>
                        </div>
                        <div class="mb-3">
                            <button type="button" class="btn btn-sm btn-outline-primary" id="btnAddItem"><i class="bi bi-plus"></i> Tambah Item</button>
                        </div>
                        
                        <div class="row mb-3 mt-4">
                            <div class="col-md-8 text-end">
                                <h5>Total:</h5>
                            </div>
                            <div class="col-md-4">
                                <h5 id="displayTotal">Rp 0</h5>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Catatan Tambahan</label>
                            <textarea class="form-control" id="invoiceNotes" rows="2"></textarea>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
                    <button type="button" class="btn btn-primary" id="btnSaveInvoice">Simpan Invoice</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal Pay -->
    <div class="modal fade" id="payModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Konfirmasi Pembayaran</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Metode Pembayaran</label>
                        <select class="form-select" id="paymentMethod">
                            <option value="Cash">Cash</option>
                            <option value="Transfer Bank">Transfer Bank</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
                    <button type="button" class="btn btn-success" id="btnConfirmPay">Tandai Lunas</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function() {
            $('#goodsInvoicesTable').DataTable({
                order: [[0, 'desc']],
                language: { url: 'https://cdn.datatables.net/plug-ins/1.13.6/i18n/id.json' }
            });

            // Generate Number when Modal Opens
            $('#addGoodsInvoiceModal').on('show.bs.modal', function () {
                $.get('/admin/billing/goods-invoices/api/generate-number', function(data) {
                    $('#invoiceNumber').val(data.invoice_number);
                });
            });

            // Add new item row
            $('#btnAddItem').click(function() {
                const row = `
                <div class="item-row row align-items-end">
                    <div class="col-md-5">
                        <label class="form-label">Nama Item <span class="text-danger">*</span></label>
                        <input type="text" class="form-control item-name" required>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Qty <span class="text-danger">*</span></label>
                        <input type="number" class="form-control item-qty" value="1" min="1" required>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Harga Satuan (Rp) <span class="text-danger">*</span></label>
                        <input type="number" class="form-control item-price" required>
                    </div>
                    <div class="col-md-1">
                        <button type="button" class="btn btn-danger btn-remove-item"><i class="bi bi-x"></i></button>
                    </div>
                </div>`;
                $('#itemsContainer').append(row);
            });

            // Remove item row
            $(document).on('click', '.btn-remove-item', function() {
                $(this).closest('.item-row').remove();
                calculateTotal();
            });

            // Auto calculate total
            $(document).on('input', '.item-qty, .item-price', function() {
                calculateTotal();
            });

            function calculateTotal() {
                let total = 0;
                $('.item-row').each(function() {
                    const qty = parseInt($(this).find('.item-qty').val()) || 0;
                    const price = parseFloat($(this).find('.item-price').val()) || 0;
                    total += (qty * price);
                });
                $('#displayTotal').text('Rp ' + total.toLocaleString('id-ID'));
            }

            // Save Invoice
            $('#btnSaveInvoice').click(function() {
                const customer_name = $('#customerName').val();
                if (!customer_name) return Swal.fire('Error', 'Nama Customer wajib diisi', 'error');

                const items = [];
                let valid = true;
                $('.item-row').each(function() {
                    const name = $(this).find('.item-name').val();
                    const qty = $(this).find('.item-qty').val();
                    const price = $(this).find('.item-price').val();
                    
                    if (!name || !qty || !price) valid = false;
                    
                    items.push({ name, qty, unit_price: price });
                });

                if (!valid || items.length === 0) return Swal.fire('Error', 'Data item tidak lengkap', 'error');

                const data = {
                    invoice_number: $('#invoiceNumber').val(),
                    customer_name: customer_name,
                    customer_phone: $('#customerPhone').val(),
                    customer_address: $('#customerAddress').val(),
                    notes: $('#invoiceNotes').val(),
                    items: items
                };

                $.ajax({
                    url: '/admin/billing/goods-invoices/api/create',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(data),
                    success: function() {
                        Swal.fire('Sukses', 'Invoice Penjualan berhasil dibuat', 'success').then(() => {
                            window.location.reload();
                        });
                    },
                    error: function(xhr) {
                        Swal.fire('Error', xhr.responseJSON?.error || 'Gagal menyimpan invoice', 'error');
                    }
                });
            });

            // Delete
            $('.btn-delete').click(function() {
                const id = $(this).data('id');
                Swal.fire({
                    title: 'Hapus Invoice?',
                    text: "Data yang dihapus tidak bisa dikembalikan!",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#3085d6',
                    confirmButtonText: 'Ya, hapus!'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $.ajax({
                            url: '/admin/billing/goods-invoices/api/' + id,
                            type: 'DELETE',
                            success: function() {
                                Swal.fire('Terhapus!', 'Invoice telah dihapus.', 'success').then(()=>location.reload());
                            }
                        });
                    }
                });
            });

            // Pay
            let payInvoiceId = null;
            $('.btn-pay').click(function() {
                payInvoiceId = $(this).data('id');
                $('#payModal').modal('show');
            });

            $('#btnConfirmPay').click(function() {
                if(!payInvoiceId) return;
                const method = $('#paymentMethod').val();
                $.ajax({
                    url: '/admin/billing/goods-invoices/api/' + payInvoiceId + '/status',
                    type: 'PUT',
                    contentType: 'application/json',
                    data: JSON.stringify({ status: 'paid', payment_method: method }),
                    success: function() {
                        Swal.fire('Sukses', 'Pembayaran berhasil dicatat', 'success').then(()=>location.reload());
                    }
                });
            });
        });
    </script>
</body>
</html>