<% var isAllPayments = (typeof page !== 'undefined' && page === 'all-payments'); %>
<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('../../partials/hard-reload') %>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <% if (isAllPayments) { %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <% } %>
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <% if (isAllPayments) { %>
    <link href="/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
    <% } %>
    <link href="/css/admin-mobile.css" rel="stylesheet">
    <% if (isAllPayments) { %>
    <link href="/css/finance-modern.css" rel="stylesheet">
    <style>
        .mini-stat-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 0.75rem;
            margin: 1rem 0;
            padding: 0.75rem;
            background-color: var(--f-muted);
            border-radius: var(--f-radius-sm);
        }
        .animate-in { animation: f-in 0.4s ease-out forwards; }
        html[data-theme="light"] .f-card .f-card-title,
        html[data-theme="light"] .f-card .f-card-description,
        html[data-theme="light"] .mini-stat-grid .f-stat-label,
        html[data-theme="light"] .mini-stat-grid .f-mono {
            color: var(--f-foreground) !important;
        }
        html[data-theme="light"] .mini-stat-grid .text-info { color: var(--f-info) !important; }
        html[data-theme="light"] .mini-stat-grid .text-warning { color: var(--f-warning) !important; }
        html[data-theme="light"] .mini-stat-grid .text-success { color: var(--f-success) !important; }

        /* Riwayat pembayaran — toolbar & layout padat */
        .all-payments-header {
            margin: -0.75rem -1rem 1rem -1rem !important;
            padding: 0.75rem 1rem !important;
        }
        .all-payments-header .all-pay-actions {
            display: flex;
            align-items: stretch;
            flex-wrap: wrap;
            gap: 0.5rem;
        }
        .all-pay-btn {
            min-height: 2.75rem;
            height: 2.75rem;
            padding: 0 1rem;
            border: none;
            border-radius: 10px;
            font-weight: 600;
            font-size: 0.875rem;
            color: #fff !important;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.35rem;
            white-space: nowrap;
            transition: filter 0.15s ease, transform 0.1s ease;
        }
        .all-pay-btn:hover { filter: brightness(1.08); color: #fff !important; }
        .all-pay-btn:active { transform: scale(0.98); }
        .all-pay-btn--refresh {
            background: linear-gradient(180deg, #5c6578 0%, #3d4454 100%);
            box-shadow: 0 1px 2px rgba(0,0,0,0.2);
        }
        .all-pay-btn--export {
            background: linear-gradient(180deg, #4f9cf9 0%, #2b7fd9 100%);
            box-shadow: 0 1px 2px rgba(43, 127, 217, 0.35);
        }
        .all-pay-btn--input {
            background: linear-gradient(180deg, #4ade80 0%, #22a34a 100%);
            box-shadow: 0 1px 2px rgba(34, 163, 74, 0.35);
        }
        .all-payments-compact .f-grid.f-grid-4 { margin-bottom: 0.65rem !important; }
        .all-payments-compact .f-stat-card { padding: 0.65rem 0.85rem !important; }
        .all-payments-compact .f-stat-desc { margin-top: 0.15rem !important; font-size: 0.7rem !important; }
        .all-payments-compact .f-stat-value { font-size: 1.15rem !important; line-height: 1.2 !important; }
        .all-payments-compact .all-payments-filter-card { margin-bottom: 0.65rem !important; }
        .all-payments-compact .all-payments-filter-card .f-card-body { padding: 0.65rem 0.85rem !important; }
        .all-payments-compact .all-payments-filter-card .f-label { margin-bottom: 0.2rem !important; font-size: 0.65rem !important; }
        .all-payments-compact .all-payments-table-card { margin-bottom: 0.5rem !important; }
        .all-payments-compact .all-payments-table-card .table { font-size: 0.875rem; }
        .all-payments-compact .all-payments-table-card .table > :not(caption) > * > * { padding-top: 0.45rem; padding-bottom: 0.45rem; }
        .all-payments-compact .all-payments-footer { margin-top: 0.35rem !important; margin-bottom: 0.75rem !important; }
    </style>
    <% } %>

    <%- include('../../partials/theme-head') %>
    <style>
      html[data-theme="light"] #paymentInputModal .modal-content,
      html[data-theme="light"] #paymentInputModal .modal-header,
      html[data-theme="light"] #paymentInputModal .modal-body,
      html[data-theme="light"] #paymentInputModal .modal-footer {
        background-color: #ffffff !important;
        color: #0f172a !important;
      }

      html[data-theme="light"] #paymentInputModal .modal-content {
        border: 1px solid #dee2e6 !important;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15) !important;
      }
    </style>
</head>
<body class="<%= isAllPayments ? 'finance-content-area' : '' %>">
<% 
  var currentMonth = new Date().getMonth() + 1;
  var currentYear = new Date().getFullYear();
  var filters = (typeof filters !== 'undefined') ? filters : { month: String(currentMonth), year: String(currentYear), from: '', to: '', collector_id: '', status: '', q: '' };
  var payments = (typeof payments !== 'undefined') ? payments : [];
  var collectors = (typeof collectors !== 'undefined') ? collectors : [];
  var paySummary = (typeof summary !== 'undefined' && summary) ? summary : { transaction_count: 0, total_amount: 0, total_tagihan: 0, total_commission: 0, total_net: 0, total_discount: 0 };
  function displayPaymentNote(notes) {
    if (notes == null || notes === '') return '';
    var s = String(notes).trim();
    if (!s) return '';
    if (/^collector\s+\d+(\s|$|\[)/i.test(s)) return '';
    return s;
  }
%>
<div class="container-fluid">
    <div class="row">
        <%- include('../../partials/billing-sidebar') %>
        <main class="col-md-10 ms-sm-auto col-lg-10 px-md-4 main-content <%= isAllPayments ? '' : 'py-4' %>" style="<%= isAllPayments ? 'padding-top: 1rem;' : '' %>">
    <% if (isAllPayments) { %>
    <div class="f-main-area" style="padding: 0;">
            <header class="all-payments-header d-flex flex-wrap justify-content-between align-items-center pb-2 border-bottom">
                <div class="mb-2 mb-md-0 pe-md-3">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mb-0" style="background: transparent; padding: 0;">
                            <li class="breadcrumb-item"><a href="/admin/dashboard" class="text-muted text-decoration-none small">Dashboard</a></li>
                            <li class="breadcrumb-item active small" aria-current="page">Riwayat Pembayaran</li>
                        </ol>
                    </nav>
                    <h1 class="f-page-title f-premium-text m-0 mt-1" style="font-size: 1.35rem;">Riwayat Pembayaran</h1>
                    <p class="text-muted small mb-0 mt-1" style="font-size: 0.8rem;">Semua pembayaran masuk</p>
                </div>
                <div class="all-pay-actions ms-md-auto">
                    <button type="button" class="all-pay-btn all-pay-btn--input" id="openPaymentModalBtn" title="Input pembayaran">
                        <i class="bi bi-cash-coin"></i>Input pembayaran
                    </button>
                    <button type="button" class="all-pay-btn all-pay-btn--export" id="exportPayments" title="Export CSV">
                        <i class="bi bi-filetype-csv"></i>Export CSV
                    </button>
                    <button type="button" class="all-pay-btn all-pay-btn--refresh" onclick="window.location.reload()" title="Refresh">
                        <i class="bi bi-arrow-clockwise"></i>Refresh
                    </button>
                </div>
            </header>

            <div class="f-container all-payments-compact">
                <div class="f-grid f-grid-4 mb-2">
                    <div class="f-stat-card animate-in" style="animation-delay: 0.1s;">
                        <div class="f-stat-header">
                            <span class="f-stat-label">Jumlah transaksi</span>
                            <div class="f-stat-icon-wrapper bg-primary-glow"><i class="bi bi-list-check"></i></div>
                        </div>
                        <div class="f-stat-value f-premium-text"><%= (paySummary.transaction_count || 0).toLocaleString('id-ID') %></div>
                        <div class="f-stat-desc">Sesuai filter periode</div>
                    </div>
                    <div class="f-stat-card animate-in" style="animation-delay: 0.2s;">
                        <div class="f-stat-header">
                            <span class="f-stat-label">Total tagihan (invoice)</span>
                            <div class="f-stat-icon-wrapper bg-success-glow"><i class="bi bi-receipt"></i></div>
                        </div>
                        <div class="f-stat-value f-premium-text text-success">Rp <%= Number(paySummary.total_tagihan != null ? paySummary.total_tagihan : paySummary.total_amount || 0).toLocaleString('id-ID') %></div>
                        <div class="f-stat-desc">Jumlah tagihan per baris</div>
                    </div>
                    <div class="f-stat-card animate-in" style="animation-delay: 0.3s;">
                        <div class="f-stat-header">
                            <span class="f-stat-label">Total diskon pelanggan</span>
                            <div class="f-stat-icon-wrapper bg-warning-glow"><i class="bi bi-tag"></i></div>
                        </div>
                        <div class="f-stat-value f-premium-text text-warning">Rp <%= Number(paySummary.total_discount || 0).toLocaleString('id-ID') %></div>
                        <div class="f-stat-desc">Potongan saat pelunasan (input pembayaran)</div>
                    </div>
                    <div class="f-stat-card animate-in" style="animation-delay: 0.4s;">
                        <div class="f-stat-header">
                            <span class="f-stat-label">Total bersih</span>
                            <div class="f-stat-icon-wrapper bg-info-glow"><i class="bi bi-wallet2"></i></div>
                        </div>
                        <div class="f-stat-value f-premium-text">Rp <%= Number(paySummary.total_net || 0).toLocaleString('id-ID') %></div>
                        <div class="f-stat-desc">Tagihan − diskon − komisi · komisi Rp <%= Number(paySummary.total_commission || 0).toLocaleString('id-ID') %></div>
                    </div>
                </div>

                <div class="f-card all-payments-filter-card mb-2">
                    <div class="f-card-body">
                        <form method="GET" action="/admin/billing/all-payments" class="row g-2 align-items-end">
                            <div class="col-md-3">
                                <label class="f-label">BULAN</label>
                                <select class="f-select" name="month">
                                    <% const monthsAll = ['Januari', 'Februari', 'Maret', 'April', 'Mei', 'Juni', 'Juli', 'Agustus', 'September', 'Oktober', 'November', 'Desember']; %>
                                    <% for (let m = 1; m <= 12; m++) { %>
                                        <option value="<%= m %>" <%= String(filters.month) === String(m) ? 'selected' : '' %>><%= monthsAll[m - 1] %></option>
                                    <% } %>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="f-label">TAHUN</label>
                                <select class="f-select" name="year">
                                    <% for (let y = currentYear - 3; y <= currentYear + 1; y++) { %>
                                        <option value="<%= y %>" <%= String(filters.year) === String(y) ? 'selected' : '' %>><%= y %></option>
                                    <% } %>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="f-label">KOLEKTOR</label>
                                <select class="f-select" name="collector_id">
                                    <option value="">Semua kolektor</option>
                                    <% (collectors || []).forEach(function (col) { %>
                                        <option value="<%= col.id %>" <%= String(filters.collector_id) === String(col.id) ? 'selected' : '' %>><%= col.name %></option>
                                    <% }); %>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <button type="submit" class="f-btn f-btn-primary w-100">
                                    <i class="bi bi-filter"></i>Terapkan Filter
                                </button>
                            </div>
                            <div class="col-12 col-md-9">
                                <label class="f-label">Cari (nama / telepon / invoice / catatan)</label>
                                <input type="text" class="f-input" name="q" value="<%= filters.q %>" placeholder="Opsional…" autocomplete="off">
                            </div>
                            <div class="col-12 col-md-3 d-flex align-items-end">
                                <a href="/admin/billing/all-payments" class="f-btn f-btn-outline w-100 text-center text-decoration-none">Reset filter</a>
                            </div>
                        </form>
                    </div>
                </div>

                <div class="f-card all-payments-table-card mb-2">
                    <div class="f-card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover table-sm mb-0 align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Tanggal</th>
                                        <th>Kolektor</th>
                                        <th>Pelanggan</th>
                                        <th>Tagihan</th>
                                        <th>Komisi</th>
                                        <th>Diskon</th>
                                        <th>Jumlah</th>
                                        <th>Metode</th>
                                        <th>Status</th>
                                        <th>Catatan</th>
                                        <th class="text-end" style="white-space:nowrap;">Aksi</th>
                                    </tr>
                                </thead>
                                <tbody>
                                <% (payments || []).forEach(function (p) {
                                    var invSt = String(p.invoice_status || '').toLowerCase();
                                    var statusLabel = invSt === 'paid' ? 'Lunas' : (invSt ? invSt : '—');
                                    var statusClass = invSt === 'paid' ? 'success' : 'secondary';
                                    var cancelTitle = 'Batalkan pembayaran: baris ini dihapus; invoice kembali belum lunas jika tidak ada pembayaran lain yang mencukupi.';
                                    var tagInv = Number(p.invoice_tagihan != null ? p.invoice_tagihan : p.invoice_amount || 0);
                                    var jmlSet = Number(p.jumlah_setelah_diskon != null ? p.jumlah_setelah_diskon : 0);
                                %>
                                    <tr>
                                        <td><%= p.payment_date ? new Date(p.payment_date).toLocaleDateString('id-ID') : '' %></td>
                                        <td><%= p.collector_name ? p.collector_name : 'Admin kantor' %></td>
                                        <td><%= p.customer_name %> <% if (p.customer_phone) { %><small class="text-muted d-block"><%= p.customer_phone %></small><% } %></td>
                                        <td>Rp <%= tagInv.toLocaleString('id-ID') %></td>
                                        <td>Rp <%= Number(p.commission_amount || 0).toLocaleString('id-ID') %></td>
                                        <td><% var dDisc = Number(p.discount_amount || 0); %><%= dDisc > 0 ? ('Rp ' + dDisc.toLocaleString('id-ID')) : '—' %></td>
                                        <td class="fw-semibold">Rp <%= jmlSet.toLocaleString('id-ID') %></td>
                                        <td><%= p.payment_method || '' %></td>
                                        <td><span class="badge bg-<%= statusClass %>"><%= statusLabel %></span></td>
                                        <td class="text-muted small"><%= displayPaymentNote(p.notes) %></td>
                                        <td class="text-end">
                                            <button type="button"
                                                class="btn btn-sm btn-outline-danger btn-cancel-payment"
                                                data-payment-id="<%= p.id %>"
                                                data-invoice="<%= String(p.invoice_number || ('#' + p.invoice_id)).replace(/"/g, '&quot;') %>"
                                                data-customer="<%= String(p.customer_name || '—').replace(/"/g, '&quot;') %>"
                                                data-amount="<%= jmlSet %>"
                                                title="<%= cancelTitle %>">Batalkan</button>
                                        </td>
                                    </tr>
                                <% }); %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="all-payments-footer">
                    <small class="text-muted" style="font-size: 0.8rem;">
                        Menampilkan <%= payments.length %> pembayaran
                        <% if (filters.month || filters.year || filters.collector_id || filters.q) { %>(difilter)<% } %>
                    </small>
                </div>
            </div>
    </div>

    <div class="modal fade" id="cancelPaymentModal" tabindex="-1" aria-labelledby="cancelPaymentModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header border-danger border-opacity-25">
                    <h5 class="modal-title text-danger" id="cancelPaymentModalLabel"><i class="bi bi-shield-lock me-1"></i>Batalkan pembayaran</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Tutup"></button>
                </div>
                <div class="modal-body">
                    <p class="small text-muted mb-2" id="cancelPaymentSummary"></p>
                    <p class="small mb-3">Baris pembayaran akan dihapus. Jika tidak ada lagi pembayaran yang mencukupi tagihan, status invoice menjadi <strong>belum lunas</strong>.</p>
                    <input type="hidden" id="cancelPaymentId" value="">
                    <label for="cancelPaymentPassword" class="form-label">Konfirmasi password super admin</label>
                    <input type="password" class="form-control" id="cancelPaymentPassword" autocomplete="current-password" placeholder="Password super admin">
                    <p class="form-text small text-muted mt-2 mb-0">Gunakan password login panel admin. Jika Anda sudah mengatur password khusus super admin di pengaturan sistem, gunakan password itu.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Tutup</button>
                    <button type="button" class="btn btn-danger" id="cancelPaymentConfirmBtn">Batalkan pembayaran</button>
                </div>
            </div>
        </div>
    </div>
    <% } else { %>
    <h3 class="mb-3">Transaksi Kolektor</h3>

    <form class="row g-2 align-items-end mb-3" method="GET" action="/admin/billing/payments">
        <div class="col-auto">
            <label class="form-label">Bulan</label>
            <select class="form-select" name="month">
                <% const monthNames = ['Januari','Februari','Maret','April','Mei','Juni','Juli','Agustus','September','Oktober','November','Desember']; %>
                <% for (let m = 1; m <= 12; m++) { %>
                    <option value="<%= m %>" <%= String(filters.month) === String(m) ? 'selected' : '' %>><%= monthNames[m - 1] %></option>
                <% } %>
            </select>
        </div>
        <div class="col-auto">
            <label class="form-label">Tahun</label>
            <select class="form-select" name="year">
                <% for (let y = currentYear - 3; y <= currentYear + 1; y++) { %>
                    <option value="<%= y %>" <%= String(filters.year) === String(y) ? 'selected' : '' %>><%= y %></option>
                <% } %>
            </select>
        </div>
        <div class="col-auto">
            <label class="form-label">Kolektor</label>
            <select class="form-select" name="collector_id">
                <option value="">Semua</option>
                <% (collectors||[]).forEach(function(col){ %>
                    <option value="<%= col.id %>" <%= String(filters.collector_id)===String(col.id)?'selected':'' %>><%= col.name %></option>
                <% }) %>
            </select>
        </div>
        <div class="col-auto">
            <label class="form-label">Status</label>
            <select class="form-select" name="status">
                <option value="">Semua</option>
                <option value="completed" <%= filters.status==='completed'?'selected':'' %>>Completed</option>
                <option value="received" <%= filters.status==='received'?'selected':'' %>>Remitted</option>
            </select>
        </div>
        <div class="col-auto">
            <label class="form-label">Cari</label>
            <input type="text" class="form-control" name="q" value="<%= filters.q %>" placeholder="Nama/No/Notes">
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary">Terapkan</button>
            <button type="button" class="btn btn-outline-secondary" onclick="resetFilters()">Reset</button>
            <button class="btn btn-outline-secondary" type="button" id="exportPayments">Export CSV</button>
        </div>
    </form>

    <div class="mb-3">
        <button type="button" class="btn btn-success" id="openPaymentModalBtn">
            <i class="bi bi-cash-coin me-1"></i> Input Pembayaran Invoice
        </button>
    </div>

    <div class="table-responsive">
        <table class="table table-hover">
            <thead>
            <tr>
                <th>Tanggal</th>
                <th>Kolektor</th>
                <th>Pelanggan</th>
                <th>Amount</th>
                <th>Komisi</th>
                <th>Metode</th>
                <th>Status</th>
                <th>Remittance</th>
                <th>Catatan</th>
            </tr>
            </thead>
            <tbody>
            <% (payments||[]).forEach(function(p){ %>
                <tr>
                    <td><%= p.payment_date ? new Date(p.payment_date).toLocaleDateString('id-ID') : '' %></td>
                    <td><%= p.collector_name || 'Admin' %></td>
                    <td><%= p.customer_name %> <small class="text-muted d-block"><%= p.customer_phone || '' %></small></td>
                    <td>Rp <%= Number(p.amount||0).toLocaleString('id-ID') %></td>
                    <td>Rp <%= Number(p.commission_amount||0).toLocaleString('id-ID') %></td>
                    <td><%= p.payment_method || '' %></td>
                    <td><span class="badge bg-primary">completed</span></td>
                    <td><span class="badge bg-<%= (p.remittance_status==='received' || !p.collector_id)?'primary':'warning' %>"><%= (p.remittance_status && p.collector_id) ? p.remittance_status : (!p.collector_id ? 'N/A (Admin)' : 'pending') %></span></td>
                    <td><%= displayPaymentNote(p.notes) %></td>
                </tr>
            <% }) %>
            </tbody>
        </table>
    </div>
    
    <div class="mt-3">
        <small class="text-muted">
            Menampilkan <%= payments.length %> transaksi
            <% if (filters.month || filters.year || filters.collector_id || filters.status || filters.q) { %>
                (difilter)
            <% } %>
        </small>
    </div>
    <% } %>
    </main>
    </div>
</div>

<!-- Payment Input Modal -->
<div class="modal fade" id="paymentInputModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-cash-coin text-success"></i> Input Pembayaran Invoice</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form id="paymentInputForm">
        <div class="modal-body">
          <div class="mb-3 position-relative">
            <label class="form-label">Nama Pelanggan</label>
            <input type="text" class="form-control" id="customerSearchInput" placeholder="Ketik nama/telepon pelanggan..." autocomplete="off" required>
            <input type="hidden" id="selectedCustomerId" required>
            <div id="customerSuggestions" class="list-group position-absolute w-100" style="z-index:1060; max-height:220px; overflow:auto; display:none;"></div>
          </div>

          <div class="mb-3">
            <label class="form-label">Invoice Belum Lunas</label>
            <select class="form-select" id="invoiceSelect" required>
              <option value="">Pilih invoice</option>
            </select>
          </div>

          <div class="mb-3">
            <label class="form-label">Jumlah Invoice</label>
            <input type="number" class="form-control" id="invoiceAmount" readonly>
          </div>

          <div class="mb-3">
            <label class="form-label">Diskon (Rp)</label>
            <input type="number" class="form-control" id="discountAmount" min="0" step="1" value="0" required>
          </div>

          <div class="mb-3">
            <label class="form-label">Metode Pembayaran</label>
            <select class="form-select" id="paymentMethod" required>
              <option value="">Pilih metode pembayaran</option>
              <option value="manual_admin" selected>Admin Kantor (Manual)</option>
              <option value="cash">Tunai</option>
              <option value="transfer_bank">Transfer Bank</option>
              <option value="qris">QRIS</option>
            </select>
          </div>

          <div class="mb-3">
            <label class="form-label">Tanggal Pembayaran</label>
            <input type="date" class="form-control" id="paymentDate" required>
          </div>

          <div class="alert alert-info mb-0">
            Total dibayar: <strong id="finalPaymentText">Rp 0</strong>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
          <button type="submit" class="btn btn-success">Submit Pembayaran</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>

<script>
        const isAllPaymentsPage = <%= isAllPayments ? 'true' : 'false' %>;

        function resetFilters() {
            window.location.href = isAllPaymentsPage ? '/admin/billing/all-payments' : '/admin/billing/payments';
        }

        function csvNoteDisplay(notes) {
            if (notes == null || notes === '') return '';
            const s = String(notes).trim();
            if (!s) return '';
            if (/^collector\s+\d+(\s|$|\[)/i.test(s)) return '';
            return s.replace(/\n/g, ' ');
        }

        document.getElementById('exportPayments').addEventListener('click', function () {
            const paymentsData = <%- JSON.stringify(payments || []) %>;
            let headers;
            let rows;
            if (isAllPaymentsPage) {
                headers = ['Tanggal', 'Kolektor', 'Pelanggan', 'Telepon', 'Tagihan', 'Komisi', 'Diskon', 'Jumlah', 'Metode', 'Status', 'Catatan'];
                rows = paymentsData.map(function (p) {
                    const invSt = String(p.invoice_status || '').toLowerCase();
                    const statusLabel = invSt === 'paid' ? 'Lunas' : (invSt || '');
                    const dDisc = Number(p.discount_amount || 0) || 0;
                    const tagInv = Number(p.invoice_tagihan != null ? p.invoice_tagihan : p.invoice_amount || 0);
                    const jmlSet = Number(p.jumlah_setelah_diskon != null ? p.jumlah_setelah_diskon : 0);
                    return [
                        p.payment_date || '',
                        p.collector_name ? p.collector_name : 'Admin kantor',
                        p.customer_name || '',
                        p.customer_phone || '',
                        tagInv,
                        p.commission_amount || 0,
                        dDisc,
                        jmlSet,
                        p.payment_method || '',
                        statusLabel,
                        csvNoteDisplay(p.notes)
                    ];
                });
            } else {
                headers = ['Date', 'Collector', 'Customer', 'Phone', 'Amount', 'Commission', 'Method', 'Status', 'Remittance', 'Notes'];
                rows = paymentsData.map(function (p) {
                    return [
                        p.payment_date || '',
                        p.collector_name || 'Admin',
                        p.customer_name || '',
                        p.customer_phone || '',
                        p.amount || 0,
                        p.commission_amount || 0,
                        p.payment_method || '',
                        'completed',
                        p.remittance_status || (!p.collector_id ? 'N/A (Admin)' : 'pending'),
                        csvNoteDisplay(p.notes)
                    ];
                });
            }
            const csv = [headers].concat(rows).map(function (r) {
                return r.map(function (x) { return '"' + String(x).replace(/"/g, '""') + '"'; }).join(',');
            }).join('\n');
            const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = isAllPaymentsPage ? 'riwayat-pembayaran.csv' : 'payments.csv';
            a.click();
            URL.revokeObjectURL(url);
        });

        if (isAllPaymentsPage) {
            let cancelPaymentModalInstance = null;
            let cancelPaymentTargetBtn = null;
            const cancelModalEl = document.getElementById('cancelPaymentModal');
            const cancelPwdInput = document.getElementById('cancelPaymentPassword');
            const cancelIdInput = document.getElementById('cancelPaymentId');
            const cancelSummaryEl = document.getElementById('cancelPaymentSummary');
            const cancelConfirmBtn = document.getElementById('cancelPaymentConfirmBtn');

            document.addEventListener('click', function (ev) {
                const btn = ev.target.closest('.btn-cancel-payment');
                if (!btn || !cancelModalEl) return;
                const id = btn.getAttribute('data-payment-id');
                const inv = btn.getAttribute('data-invoice') || '';
                const cust = btn.getAttribute('data-customer') || '';
                const amt = Number(btn.getAttribute('data-amount') || 0);
                const rp = 'Rp ' + Math.round(amt).toLocaleString('id-ID');
                cancelPaymentTargetBtn = btn;
                cancelIdInput.value = id || '';
                cancelSummaryEl.innerHTML =
                    '<strong>Invoice:</strong> ' + inv + '<br>' +
                    '<strong>Pelanggan:</strong> ' + cust + '<br>' +
                    '<strong>Jumlah:</strong> ' + rp;
                cancelPwdInput.value = '';
                if (!cancelPaymentModalInstance) {
                    cancelPaymentModalInstance = new bootstrap.Modal(cancelModalEl);
                }
                cancelPaymentModalInstance.show();
                setTimeout(function () { cancelPwdInput.focus(); }, 400);
            });

            cancelConfirmBtn.addEventListener('click', async function () {
                const id = cancelIdInput.value;
                const pwd = cancelPwdInput.value;
                if (!id) return;
                if (!String(pwd || '').trim()) {
                    alert('Masukkan password super admin.');
                    cancelPwdInput.focus();
                    return;
                }
                cancelConfirmBtn.disabled = true;
                try {
                    const resp = await fetch('/admin/billing/api/payments/' + encodeURIComponent(id) + '/cancel', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        credentials: 'same-origin',
                        body: JSON.stringify({ confirm_password: pwd })
                    });
                    const data = await resp.json().catch(function () { return {}; });
                    if (!resp.ok || !data.success) {
                        alert(data.message || 'Gagal membatalkan pembayaran');
                        cancelConfirmBtn.disabled = false;
                        return;
                    }
                    if (cancelPaymentModalInstance) cancelPaymentModalInstance.hide();
                    alert(data.message || 'Pembayaran dibatalkan.');
                    window.location.reload();
                } catch (err) {
                    alert('Gagal membatalkan pembayaran (jaringan atau server).');
                    cancelConfirmBtn.disabled = false;
                }
            });

            cancelModalEl.addEventListener('hidden.bs.modal', function () {
                cancelConfirmBtn.disabled = false;
                cancelPwdInput.value = '';
                if (cancelPaymentTargetBtn) cancelPaymentTargetBtn = null;
            });
        }

        let paymentModal;
        let customersCache = [];
        let currentInvoices = [];

        function openPaymentInputModal() {
            if (!paymentModal) {
                paymentModal = new bootstrap.Modal(document.getElementById('paymentInputModal'));
            }
            document.getElementById('paymentDate').value = new Date().toISOString().slice(0, 10);
            document.getElementById('customerSearchInput').value = '';
            document.getElementById('selectedCustomerId').value = '';
            document.getElementById('invoiceSelect').innerHTML = '<option value="">Pilih invoice</option>';
            document.getElementById('invoiceAmount').value = '';
            document.getElementById('discountAmount').value = 0;
            updateFinalPayment();
            paymentModal.show();
        }

        function updateFinalPayment() {
            const invoiceAmount = parseFloat(document.getElementById('invoiceAmount').value || '0');
            const discount = parseFloat(document.getElementById('discountAmount').value || '0');
            const finalAmount = Math.max(invoiceAmount - discount, 0);
            document.getElementById('finalPaymentText').textContent = `Rp ${Math.round(finalAmount).toLocaleString('id-ID')}`;
            return { invoiceAmount, discount, finalAmount };
        }

        async function ensureCustomersLoaded() {
            if (customersCache.length > 0) return;
            const resp = await fetch('/admin/billing/customers/list');
            const data = await resp.json();
            customersCache = Array.isArray(data?.customers) ? data.customers : [];
        }

        function renderCustomerSuggestions(keyword) {
            const box = document.getElementById('customerSuggestions');
            const q = String(keyword || '').toLowerCase().trim();
            if (q.length < 2) {
                box.style.display = 'none';
                box.innerHTML = '';
                return;
            }
            const matches = customersCache.filter(c =>
                String(c.name || '').toLowerCase().includes(q) ||
                String(c.phone || '').toLowerCase().includes(q) ||
                String(c.username || '').toLowerCase().includes(q)
            ).slice(0, 8);

            if (!matches.length) {
                box.innerHTML = '<div class="list-group-item text-muted">Pelanggan tidak ditemukan</div>';
                box.style.display = 'block';
                return;
            }

            box.innerHTML = matches.map(c => (
                `<button type="button" class="list-group-item list-group-item-action customer-suggestion" data-id="${c.id}" data-name="${String(c.name || '').replace(/"/g, '&quot;')}" data-phone="${String(c.phone || '').replace(/"/g, '&quot;')}">` +
                `<strong>${c.name || '-'}</strong><br><small>${c.phone || '-'} | ${c.username || '-'}</small>` +
                `</button>`
            )).join('');
            box.style.display = 'block';
        }

        async function loadUnpaidInvoices(customerId) {
            const select = document.getElementById('invoiceSelect');
            select.innerHTML = '<option value="">Memuat invoice...</option>';
            const resp = await fetch(`/admin/billing/api/customer-invoices/${customerId}`);
            const data = await resp.json();
            currentInvoices = Array.isArray(data?.data) ? data.data : [];
            if (!currentInvoices.length) {
                select.innerHTML = '<option value="">Tidak ada invoice belum lunas</option>';
                document.getElementById('invoiceAmount').value = '';
                updateFinalPayment();
                return;
            }
            select.innerHTML = '<option value="">Pilih invoice</option>' + currentInvoices.map(inv =>
                `<option value="${inv.id}">${inv.invoice_number || ('INV-' + inv.id)} - Rp ${Math.round(Number(inv.amount || 0)).toLocaleString('id-ID')}</option>`
            ).join('');
        }

        document.getElementById('openPaymentModalBtn').addEventListener('click', async function() {
            await ensureCustomersLoaded();
            openPaymentInputModal();
        });

        document.getElementById('customerSearchInput').addEventListener('input', async function() {
            await ensureCustomersLoaded();
            document.getElementById('selectedCustomerId').value = '';
            document.getElementById('invoiceSelect').innerHTML = '<option value="">Pilih invoice</option>';
            document.getElementById('invoiceAmount').value = '';
            renderCustomerSuggestions(this.value);
            updateFinalPayment();
        });

        document.addEventListener('click', async function(e) {
            const btn = e.target.closest('.customer-suggestion');
            if (btn) {
                const customerId = btn.getAttribute('data-id');
                const customerName = btn.getAttribute('data-name') || '';
                const customerPhone = btn.getAttribute('data-phone') || '';
                document.getElementById('customerSearchInput').value = `${customerName} (${customerPhone})`;
                document.getElementById('selectedCustomerId').value = customerId;
                document.getElementById('customerSuggestions').style.display = 'none';
                await loadUnpaidInvoices(customerId);
                return;
            }
            if (!e.target.closest('#customerSuggestions') && !e.target.closest('#customerSearchInput')) {
                document.getElementById('customerSuggestions').style.display = 'none';
            }
        });

        document.getElementById('invoiceSelect').addEventListener('change', function() {
            const id = String(this.value || '');
            const inv = currentInvoices.find(v => String(v.id) === id);
            document.getElementById('invoiceAmount').value = inv ? Number(inv.amount || 0) : '';
            updateFinalPayment();
        });

        document.getElementById('discountAmount').addEventListener('input', updateFinalPayment);

        document.getElementById('paymentInputForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            const customerId = document.getElementById('selectedCustomerId').value;
            const invoiceId = document.getElementById('invoiceSelect').value;
            const paymentMethod = document.getElementById('paymentMethod').value;
            const paymentDate = document.getElementById('paymentDate').value;
            const { invoiceAmount, discount, finalAmount } = updateFinalPayment();

            if (!customerId) return alert('Silakan pilih pelanggan dari rekomendasi.');
            if (!invoiceId) return alert('Silakan pilih invoice.');
            if (!paymentMethod) return alert('Silakan pilih metode pembayaran.');
            if (!paymentDate) return alert('Silakan pilih tanggal pembayaran.');
            if (discount > invoiceAmount) return alert('Diskon tidak boleh melebihi jumlah invoice.');

            const notes = `Pelunasan oleh Admin Kantor | Diskon: Rp ${Math.round(discount).toLocaleString('id-ID')} | Tanggal Bayar: ${paymentDate}`;

            const resp = await fetch('/admin/billing/payments', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    invoice_id: invoiceId,
                    amount: finalAmount,
                    payment_method: paymentMethod,
                    payment_date: paymentDate,
                    reference_number: '',
                    notes,
                    discount_amount: Math.round(Number(discount) || 0)
                })
            });
            const result = await resp.json();
            if (!result?.success) {
                alert(result?.message || 'Gagal menyimpan pembayaran');
                return;
            }
            if (paymentModal) paymentModal.hide();
            window.location.href = isAllPaymentsPage ? '/admin/billing/all-payments' : '/admin/billing/payments';
        });

        const quickAction = new URLSearchParams(window.location.search).get('quickAction');
        if (quickAction === 'input-pembayaran') {
            ensureCustomersLoaded().then(() => {
                openPaymentInputModal();
                const url = new URL(window.location.href);
                url.searchParams.delete('quickAction');
                window.history.replaceState({}, '', url.toString());
            });
        }
    </script>

    <!-- Mobile Bottom Navbar -->
    <%- include('../../partials/admin-mobile-navbar', { currentPage: 'payments' }) %>
</body>
</html>
