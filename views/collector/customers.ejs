<!DOCTYPE html>
<html lang="id" class="h-full">
<head>
  <%- include('../partials/collector-field-head', { pageTitle: 'Pelanggan', appSettings: appSettings }) %>
</head>
<body class="bg-background text-on-surface min-h-screen pb-24 font-body-md text-body-md antialiased">
  <%- include('../partials/collector-field-topbar', { topbarTitle: 'Field Collector' }) %>

  <main class="pt-14 px-margin-page flex flex-col gap-stack-lg max-w-md mx-auto">
    <div class="sticky top-14 z-30 bg-background pt-stack-md pb-stack-sm flex flex-col gap-stack-md -mx-margin-page px-margin-page shadow-[0_4px_10px_-10px_rgba(0,0,0,0.1)]">
      <form method="get" action="/collector/customers" class="relative w-full flex gap-2">
        <% if (currentStatusFilter) { %>
          <input type="hidden" name="status" value="<%= currentStatusFilter %>">
        <% } %>
        <div class="relative flex-1">
          <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline text-[20px]">search</span>
          <input name="q" value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>" class="w-full bg-surface-container-high border border-outline-variant rounded-full py-3 pl-10 pr-4 text-body-lg font-body-lg text-on-surface placeholder:text-outline focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" placeholder="Cari nama atau ID pelanggan..." type="search"/>
        </div>
        <button type="submit" class="shrink-0 px-3 rounded-full bg-primary-container text-on-primary text-label-caps uppercase">Cari</button>
      </form>
      <div class="flex overflow-x-auto gap-stack-sm pb-1 scrollbar-hide snap-x">
        <% const sq = typeof searchQuery !== 'undefined' ? searchQuery : ''; %>
        <% const tabs = [ { key: '', label: 'Semua' }, { key: 'unpaid', label: 'Belum Bayar' }, { key: 'paid', label: 'Lunas' }, { key: 'isolir', label: 'Isolir' }, { key: 'baru', label: 'Baru' } ]; %>
        <% tabs.forEach(function(t) {
             const active = (currentStatusFilter || '') === t.key;
             const qp = [];
             if (t.key) qp.push('status=' + encodeURIComponent(t.key));
             if (sq) qp.push('q=' + encodeURIComponent(sq));
             const thref = '/collector/customers' + (qp.length ? '?' + qp.join('&') : '');
        %>
          <a href="<%= thref %>" class="snap-start shrink-0 px-4 py-2 rounded-full font-label-caps text-label-caps uppercase tracking-wider <%= active ? 'bg-primary text-on-primary' : 'bg-surface text-on-surface border border-outline-variant' %>">
            <%= t.label %>
          </a>
        <% }); %>
      </div>
    </div>

    <div class="flex flex-col gap-gutter-card pb-4">
      <% if (!customers || customers.length === 0) { %>
        <p class="text-center text-on-surface-variant py-8">Tidak ada pelanggan untuk filter ini.</p>
      <% } %>
      <% (customers || []).forEach(function(c) {
           const ps = c.payment_status || '';
           let stripe = 'bg-error', badgeBg = 'bg-error-container text-on-error-container', badgeText = 'Belum Bayar';
           if (c.status === 'suspended') { stripe = 'bg-tertiary-fixed-dim'; badgeBg = 'bg-tertiary-fixed text-on-tertiary-fixed'; badgeText = 'Isolir'; }
           else if (ps === 'paid') { stripe = 'bg-secondary'; badgeBg = 'bg-secondary-container text-on-secondary-container'; badgeText = 'Lunas'; }
           else if (ps === 'overdue') { stripe = 'bg-error'; badgeBg = 'bg-error-container text-on-error-container'; badgeText = 'Belum Bayar'; }
           else if (ps === 'no_invoice') { stripe = 'bg-primary-fixed-dim'; badgeBg = 'bg-primary-fixed text-on-primary-fixed'; badgeText = 'Baru'; }
           const amt = Math.round(parseFloat(c.package_price || 0));
           const amtLabel = (ps === 'overdue') ? 'Tunggakan' : (ps === 'no_invoice' ? 'Estimasi' : 'Tagihan');
      %>
        <div class="customer-row bg-surface-container-lowest border border-outline-variant rounded-xl p-padding-interactive shadow-sm flex flex-col gap-stack-sm relative overflow-hidden cursor-pointer"
             role="button" tabindex="0"
             data-id="<%= c.id %>" data-name="<%= (c.name || '').replace(/"/g, '&quot;').replace(/'/g, '&#39;') %>" data-address="<%= (c.address || '-').replace(/"/g, '&quot;').replace(/'/g, '&#39;') %>"
             data-badge="<%= badgeText %>" data-badge-class="<%= badgeBg %>"
             data-amount="<%= amt %>" data-status="<%= ps %>" data-phone="<%= (c.phone || '').replace(/"/g, '&quot;').replace(/'/g, '&#39;') %>">
          <div class="absolute left-0 top-0 bottom-0 w-1 <%= stripe %>"></div>
          <div class="flex justify-between items-start pl-2">
            <h3 class="font-h2 text-h2 text-on-surface"><%= c.name %></h3>
            <span class="<%= badgeBg %> font-label-caps text-label-caps px-2.5 py-1 rounded-full uppercase"><%= badgeText %></span>
          </div>
          <div class="flex items-center gap-2 pl-2 text-on-surface-variant font-body-md text-body-md">
            <span class="material-symbols-outlined text-[18px] shrink-0">home_pin</span>
            <p class="truncate"><%= c.address || '-' %></p>
          </div>
          <div class="flex justify-between items-end pl-2 mt-1">
            <div class="flex flex-col">
              <span class="text-outline text-[12px] font-medium uppercase tracking-wide"><%= amtLabel %></span>
              <span class="font-numeric-data text-numeric-data <%= ps === 'overdue' ? 'text-error' : 'text-on-surface' %>">Rp <%= amt.toLocaleString('id-ID') %></span>
            </div>
            <span class="h-10 w-10 flex items-center justify-center rounded-full bg-surface-container-high text-on-surface">
              <span class="material-symbols-outlined">chevron_right</span>
            </span>
          </div>
        </div>
      <% }); %>
    </div>
  </main>

  <div id="detailSheet" class="fixed inset-0 bg-on-surface/40 z-[60] flex flex-col justify-end hidden" aria-hidden="true">
    <div id="sheetBackdrop" class="flex-1 w-full"></div>
    <div class="bg-surface w-full rounded-t-2xl shadow-[0_-8px_30px_rgba(0,0,0,0.12)] pb-24 pt-2 px-margin-page flex flex-col max-h-[85vh] overflow-y-auto">
      <div class="w-12 h-1.5 bg-outline-variant rounded-full mx-auto mb-4"></div>
      <div class="flex justify-between items-start mb-4 gap-2">
        <div>
          <h2 id="sheetName" class="font-h1 text-h1 text-on-surface mb-1">—</h2>
          <p id="sheetId" class="font-body-md text-body-md text-on-surface-variant">ID: —</p>
        </div>
        <span id="sheetBadge" class="font-label-caps text-label-caps px-3 py-1.5 rounded-full uppercase shrink-0">—</span>
      </div>
      <div class="bg-surface-container-lowest border border-outline-variant rounded-xl p-4 mb-4 flex flex-col gap-4">
        <div class="flex gap-3">
          <span class="material-symbols-outlined text-outline shrink-0">home_pin</span>
          <div>
            <p class="font-label-caps text-label-caps text-outline mb-0.5">ALAMAT</p>
            <p id="sheetAddress" class="font-body-md text-body-md text-on-surface">—</p>
          </div>
        </div>
        <div class="h-px w-full bg-outline-variant/50"></div>
        <div class="flex gap-3">
          <span class="material-symbols-outlined text-outline shrink-0">receipt_long</span>
          <div class="w-full">
            <p class="font-label-caps text-label-caps text-outline mb-1">TAGIHAN (PAKET)</p>
            <div class="flex justify-between items-center mb-1">
              <span id="sheetPkg" class="font-body-md text-body-md text-on-surface-variant truncate pr-2"><%= '' %></span>
              <span id="sheetAmt" class="font-body-md text-body-md text-on-surface shrink-0">—</span>
            </div>
            <div class="flex justify-between items-center mt-2 pt-2 border-t border-dashed border-outline-variant">
              <span class="font-h2 text-h2 text-on-surface">Total</span>
              <span id="sheetTotal" class="font-numeric-data text-numeric-data text-error text-[20px]">—</span>
            </div>
          </div>
        </div>
      </div>
      <div class="grid grid-cols-2 gap-3 mb-2">
        <a id="sheetPay" href="#" class="col-span-2 bg-primary text-on-primary py-4 rounded-xl font-h2 text-[16px] flex items-center justify-center gap-2 text-center">
          <span class="material-symbols-outlined">payments</span>
          Terima Pembayaran
        </a>
        <a id="sheetCall" href="#" class="bg-surface-container-lowest border border-outline text-on-surface py-3 rounded-xl font-h2 text-[14px] flex items-center justify-center gap-2 text-center">
          <span class="material-symbols-outlined">call</span>
          Hubungi
        </a>
        <span class="bg-surface-container-lowest border border-outline text-on-surface py-3 rounded-xl font-h2 text-[14px] flex items-center justify-center gap-2 text-center opacity-50 cursor-not-allowed select-none" title="Isolir dari panel admin">
          <span class="material-symbols-outlined">block</span>
          Isolir
        </span>
      </div>
    </div>
  </div>

  <%- include('../partials/collector-bottom-nav', { currentPage: 'customers' }) %>
  <script src="/js/collector-pwa.js"></script>
  <script>
(function() {
  var sheet = document.getElementById('detailSheet');
  var backdrop = document.getElementById('sheetBackdrop');
  function closeSheet() {
    sheet.classList.add('hidden');
    sheet.setAttribute('aria-hidden', 'true');
  }
  backdrop.addEventListener('click', closeSheet);
  document.querySelectorAll('.customer-row').forEach(function(row) {
    row.addEventListener('click', function() {
      var id = row.getAttribute('data-id');
      var name = row.getAttribute('data-name');
      var address = row.getAttribute('data-address');
      var badge = row.getAttribute('data-badge');
      var badgeClass = row.getAttribute('data-badge-class');
      var amount = row.getAttribute('data-amount');
      var phone = row.getAttribute('data-phone') || '';
      document.getElementById('sheetName').textContent = name;
      document.getElementById('sheetId').textContent = 'ID: ' + id;
      var b = document.getElementById('sheetBadge');
      b.textContent = badge;
      b.className = 'font-label-caps text-label-caps px-3 py-1.5 rounded-full uppercase shrink-0 ' + badgeClass;
      document.getElementById('sheetAddress').textContent = address;
      document.getElementById('sheetPkg').textContent = 'Paket / layanan';
      document.getElementById('sheetAmt').textContent = 'Rp ' + Number(amount).toLocaleString('id-ID');
      document.getElementById('sheetTotal').textContent = 'Rp ' + Number(amount).toLocaleString('id-ID');
      document.getElementById('sheetPay').href = '/collector/payment?customer_id=' + encodeURIComponent(id);
      document.getElementById('sheetCall').href = phone ? 'tel:' + phone.replace(/\s/g, '') : '#';
      sheet.classList.remove('hidden');
      sheet.setAttribute('aria-hidden', 'false');
    });
  });
})();
  </script>
</body>
</html>
