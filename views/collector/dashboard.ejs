<!DOCTYPE html>
<html lang="id" class="h-full">
<head>
  <%- include('../partials/collector-field-head', { pageTitle: 'Dashboard Kolektor', appSettings: appSettings }) %>
</head>
<body class="bg-background text-on-background pb-24 pt-14 min-h-screen relative">
  <%- include('../partials/collector-field-topbar', { topbarTitle: 'Field Collector' }) %>

  <main class="max-w-md mx-auto p-margin-page space-y-stack-lg mt-stack-md">
    <form method="get" action="/collector/dashboard" class="flex gap-2 items-center justify-end flex-wrap">
      <select name="month" class="text-body-md rounded-lg border border-outline-variant bg-surface-container-high px-2 py-1.5 text-on-surface">
        <% const months = ['Jan','Feb','Mar','Apr','Mei','Jun','Jul','Agu','Sep','Okt','Nov','Des']; %>
        <% const cm = (filters && filters.month) ? parseInt(filters.month, 10) : new Date().getMonth() + 1; %>
        <% for (let m = 1; m <= 12; m++) { %>
          <option value="<%= m %>" <%= cm === m ? 'selected' : '' %>><%= months[m-1] %></option>
        <% } %>
      </select>
      <select name="year" class="text-body-md rounded-lg border border-outline-variant bg-surface-container-high px-2 py-1.5 text-on-surface">
        <% const cy = new Date().getFullYear(); const sy = (filters && filters.year) ? parseInt(filters.year, 10) : cy; %>
        <% for (let y = cy - 2; y <= cy + 1; y++) { %>
          <option value="<%= y %>" <%= sy === y ? 'selected' : '' %>><%= y %></option>
        <% } %>
      </select>
      <button type="submit" class="text-label-caps uppercase bg-primary-container text-on-primary px-3 py-1.5 rounded-lg">Terapkan</button>
    </form>

    <section class="bg-surface-container-lowest p-gutter-card rounded-xl shadow-sm border border-outline-variant flex justify-between items-center">
      <div>
        <h1 class="font-h1 text-h1 text-on-surface"><%= collector.name || 'Kolektor' %></h1>
        <p class="font-body-md text-body-md text-on-surface-variant flex items-center gap-1 mt-1">
          <span class="material-symbols-outlined text-[16px]">calendar_today</span>
          <%= fieldUi.displayDate %>
        </p>
        <p class="font-body-md text-body-md text-on-surface-variant flex items-center gap-1 mt-1">
          <span class="material-symbols-outlined text-[16px]">location_on</span>
          <%= fieldUi.areaLabel %>
        </p>
      </div>
      <div class="h-12 w-12 shrink-0 rounded-full bg-primary-container text-on-primary-container flex items-center justify-center font-numeric-data text-numeric-data text-sm">
        <%= (collector.name || 'K').split(/\s+/).map(w => w[0]).slice(0,2).join('').toUpperCase() %>
      </div>
    </section>

    <section class="bg-primary-container text-on-primary p-gutter-card rounded-xl shadow-md relative overflow-hidden">
      <div class="absolute -right-10 -top-10 w-40 h-40 bg-white/10 rounded-full blur-2xl pointer-events-none"></div>
      <div class="flex justify-between items-end mb-4 relative z-10">
        <div>
          <p class="font-label-caps text-label-caps text-primary-fixed-dim uppercase opacity-80">Target tagihan (bulan)</p>
          <p class="font-h1 text-h1 text-on-primary mt-1">Rp <%= fieldUi.targetMonth.toLocaleString('id-ID') %></p>
        </div>
        <div class="text-right">
          <span class="font-numeric-data text-numeric-data text-secondary-fixed"><%= fieldUi.progressPct %>%</span>
          <p class="font-body-md text-body-md text-primary-fixed-dim">Terkumpul</p>
        </div>
      </div>
      <div class="w-full bg-on-primary-container/30 rounded-full h-2.5 mt-stack-sm overflow-hidden relative z-10">
        <div class="bg-secondary-fixed h-2.5 rounded-full transition-all" style="width: <%= fieldUi.progressPct %>%"></div>
      </div>
      <div class="flex justify-between mt-stack-sm text-body-md font-body-md text-primary-fixed-dim relative z-10">
        <span>Rp <%= fieldUi.terkumpul.toLocaleString('id-ID') %></span>
        <span>Sisa: Rp <%= fieldUi.sisaTarget.toLocaleString('id-ID') %></span>
      </div>
    </section>

    <section class="grid grid-cols-2 gap-stack-sm">
      <a href="/collector/customers?status=unpaid" class="bg-primary text-on-primary py-padding-interactive px-4 rounded-lg font-h2 text-h2 flex items-center justify-center gap-2 active:scale-95 transition-transform text-center">
        <span class="material-symbols-outlined fill">payments</span>
        Tagih Sekarang
      </a>
      <a href="/collector/payment" class="bg-surface-container-high text-on-surface border border-outline py-padding-interactive px-4 rounded-lg font-h2 text-h2 flex items-center justify-center gap-2 active:scale-95 transition-transform text-center">
        <span class="material-symbols-outlined">edit_document</span>
        Input Pembayaran
      </a>
    </section>

    <section class="grid grid-cols-2 gap-stack-sm">
      <div class="col-span-2 bg-surface-container-lowest p-gutter-card rounded-xl border border-outline-variant shadow-sm flex items-center justify-between">
        <div class="flex items-center gap-3">
          <div class="p-2 bg-primary-fixed rounded-lg text-on-primary-fixed">
            <span class="material-symbols-outlined fill">group</span>
          </div>
          <span class="font-body-lg text-body-lg font-semibold text-on-surface">Total Pelanggan</span>
        </div>
        <span class="font-numeric-data text-numeric-data text-primary"><%= fieldUi.totalPelangganAktif %></span>
      </div>
      <div class="bg-error-container p-gutter-card rounded-xl border border-error/20 flex flex-col justify-between">
        <div class="flex items-center gap-2 text-on-error-container">
          <span class="material-symbols-outlined text-[20px] fill">warning</span>
          <span class="font-body-md text-body-md font-medium">Belum Bayar</span>
        </div>
        <div class="mt-stack-sm">
          <span class="font-numeric-data text-numeric-data text-[28px] text-on-error-container"><%= fieldUi.belumBayarCount %></span>
        </div>
      </div>
      <div class="bg-secondary-container p-gutter-card rounded-xl border border-secondary/20 flex flex-col justify-between">
        <div class="flex items-center gap-2 text-on-secondary-container">
          <span class="material-symbols-outlined text-[20px] fill">check_circle</span>
          <span class="font-body-md text-body-md font-medium">Lunas</span>
        </div>
        <div class="mt-stack-sm">
          <span class="font-numeric-data text-numeric-data text-[28px] text-on-secondary-container"><%= fieldUi.lunasCount %></span>
        </div>
      </div>
      <div class="col-span-2 bg-tertiary-fixed p-gutter-card rounded-xl border border-tertiary-container/20 flex items-center justify-between">
        <div class="flex items-center gap-3 text-on-tertiary-fixed">
          <span class="material-symbols-outlined fill">wifi_off</span>
          <span class="font-body-md text-body-md font-medium">Terisolir</span>
        </div>
        <span class="font-numeric-data text-numeric-data text-[24px] text-on-tertiary-fixed"><%= fieldUi.isolirCount %></span>
      </div>
    </section>

    <section>
      <div class="flex justify-between items-center mb-stack-sm">
        <h2 class="font-h2 text-h2 text-on-surface">Prioritas Penagihan</h2>
        <a href="/collector/customers?status=unpaid" class="font-body-md text-body-md text-primary font-medium flex items-center gap-1">
          Lihat Semua <span class="material-symbols-outlined text-[16px]">arrow_forward</span>
        </a>
      </div>
      <div class="space-y-stack-sm">
        <% if (fieldUi.priorityCustomers && fieldUi.priorityCustomers.length) { %>
          <% fieldUi.priorityCustomers.forEach(function(pc) { %>
            <div class="bg-surface-container-lowest p-gutter-card rounded-xl shadow-sm border border-outline-variant flex flex-col gap-3">
              <div class="flex justify-between items-start">
                <div>
                  <h3 class="font-body-lg text-body-lg font-bold text-on-surface"><%= pc.name %></h3>
                  <p class="font-body-md text-body-md text-on-surface-variant flex items-start gap-1 mt-1">
                    <span class="material-symbols-outlined text-[16px] mt-0.5 shrink-0">home_pin</span>
                    <span class="line-clamp-2"><%= pc.address %></span>
                  </p>
                </div>
                <span class="bg-error-container text-on-error-container px-2 py-1 rounded font-label-caps text-label-caps shrink-0">Belum Bayar</span>
              </div>
              <div class="flex justify-between items-center border-t border-outline-variant pt-3 mt-1">
                <span class="font-numeric-data text-numeric-data text-on-surface">Rp <%= pc.amount.toLocaleString('id-ID') %></span>
                <a href="/collector/payment?customer_id=<%= pc.id %>" class="bg-primary text-on-primary px-4 py-2 rounded-lg font-body-md text-body-md font-medium flex items-center gap-2">
                  Tagih <span class="material-symbols-outlined text-[16px]">chevron_right</span>
                </a>
              </div>
            </div>
          <% }); %>
        <% } else { %>
          <p class="text-center text-on-surface-variant font-body-md py-6">Tidak ada prioritas penagihan saat ini.</p>
        <% } %>
      </div>
    </section>
  </main>

  <%- include('../partials/collector-bottom-nav', { currentPage: 'dashboard' }) %>
  <script src="/js/collector-pwa.js"></script>
</body>
</html>
