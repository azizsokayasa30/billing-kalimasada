<!DOCTYPE html>
<html lang="id" class="h-full">
<head>
  <%- include('../partials/collector-field-head', { pageTitle: 'Setoran', appSettings: appSettings }) %>
</head>
<body class="bg-background text-on-background font-body-md h-full min-h-screen w-full flex flex-col pb-24">
  <%- include('../partials/collector-field-topbar', { topbarTitle: 'Field Collector' }) %>

  <main class="flex-1 overflow-y-auto pt-[72px] pb-4 px-margin-page flex flex-col gap-stack-lg w-full max-w-md mx-auto">
    <section class="bg-surface rounded-xl p-stack-md shadow-[0_4px_24px_rgba(0,0,0,0.04)] border border-outline-variant flex flex-col gap-stack-md relative overflow-hidden">
      <div class="absolute -top-10 -right-10 w-32 h-32 bg-primary-fixed opacity-30 rounded-full blur-2xl pointer-events-none"></div>
      <div class="flex flex-col gap-1 z-10">
        <h2 class="font-label-caps text-label-caps text-outline uppercase">Total harus disetor (neto bulan ini)</h2>
        <p class="font-numeric-data text-[28px] leading-tight text-primary-container tracking-tight">Rp <%= setoranUi.totalHarusSetor.toLocaleString('id-ID') %></p>
      </div>
      <div class="flex flex-col gap-base z-10 pt-stack-sm">
        <div class="flex justify-between items-end">
          <span class="font-label-caps text-[10px] text-primary-container uppercase font-bold">Progress setoran</span>
          <span class="font-numeric-data text-body-md text-primary-container"><%= setoranUi.setoranProgressPct %>%</span>
        </div>
        <div class="h-2.5 w-full bg-surface-container-highest rounded-full overflow-hidden shadow-inner">
          <div class="h-full bg-primary-container rounded-full transition-all" style="width: <%= setoranUi.setoranProgressPct %>%"></div>
        </div>
      </div>
      <div class="flex justify-between items-center border-t border-surface-variant pt-stack-sm mt-stack-sm z-10">
        <div class="flex flex-col gap-1">
          <span class="font-label-caps text-[10px] text-outline uppercase flex items-center gap-1">
            <span class="material-symbols-outlined text-[12px] text-secondary">arrow_downward</span>
            Sudah disetor
          </span>
          <span class="font-numeric-data text-body-lg text-secondary">Rp <%= setoranUi.sudahSetor.toLocaleString('id-ID') %></span>
        </div>
        <div class="w-px h-8 bg-surface-variant"></div>
        <div class="flex flex-col gap-1 items-end">
          <span class="font-label-caps text-[10px] text-outline uppercase flex items-center gap-1">
            Sisa setoran
            <span class="material-symbols-outlined text-[12px] text-error">priority_high</span>
          </span>
          <span class="font-numeric-data text-body-lg text-error">Rp <%= setoranUi.belumSetor.toLocaleString('id-ID') %></span>
        </div>
      </div>
    </section>

    <section class="flex flex-col w-full">
      <button type="button" onclick="alert('Serahkan uang tunai ke kasir dan minta konfirmasi setoran di sistem admin.')" class="w-full bg-primary-container text-on-primary-container py-padding-interactive rounded-xl font-h2 text-[16px] flex items-center justify-center gap-stack-sm shadow-[0_8px_16px_rgba(0,31,63,0.15)] active:scale-[0.98] active:shadow-sm transition-all duration-200">
        <span class="material-symbols-outlined fill">account_balance_wallet</span>
        Setor sekarang
      </button>
    </section>

    <section class="flex flex-col gap-stack-sm pb-stack-lg">
      <div class="flex justify-between items-end mb-stack-sm px-1">
        <h3 class="font-h2 text-h2 text-on-surface">Riwayat pembayaran</h3>
      </div>
      <div class="flex flex-col gap-gutter-card">
        <% const plist = (payments || []).slice(0, 30); %>
        <% if (!plist.length) { %>
          <p class="text-center text-on-surface-variant py-6">Belum ada riwayat.</p>
        <% } %>
        <% plist.forEach(function(p) {
             const done = (p.status || '') === 'completed';
             const when = p.collected_at ? new Date(p.collected_at) : null;
             const whenStr = when ? when.toLocaleString('id-ID', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' }) : '-';
        %>
          <div class="bg-surface p-stack-md rounded-xl border border-surface-variant flex justify-between items-center shadow-[0_2px_8px_rgba(0,0,0,0.02)]">
            <div class="flex items-center gap-stack-md min-w-0">
              <div class="w-12 h-12 rounded-full shrink-0 <%= done ? 'bg-secondary-container text-on-secondary-container' : 'bg-surface-container-high text-on-surface-variant' %> flex items-center justify-center">
                <span class="material-symbols-outlined fill text-[22px]"><%= done ? 'check' : 'schedule' %></span>
              </div>
              <div class="flex flex-col gap-0.5 min-w-0">
                <span class="font-numeric-data text-body-lg text-on-surface truncate">Rp <%= (p.payment_amount || 0).toLocaleString('id-ID') %></span>
                <span class="font-body-md text-[13px] text-on-surface-variant truncate"><%= p.customer_name || 'Pelanggan' %> · <%= whenStr %></span>
              </div>
            </div>
            <div class="flex flex-col items-end gap-1 shrink-0">
              <span class="font-label-caps text-[10px] uppercase <%= done ? 'text-secondary' : 'text-on-surface-variant' %>"><%= done ? 'Selesai' : 'Pending' %></span>
              <span class="material-symbols-outlined text-outline text-[18px]">chevron_right</span>
            </div>
          </div>
        <% }); %>
      </div>
    </section>
  </main>

  <%- include('../partials/collector-bottom-nav', { currentPage: 'payments' }) %>
  <script src="/js/collector-pwa.js"></script>
</body>
</html>
