<!DOCTYPE html>
<html lang="id" class="h-full">
<head>
  <%- include('../partials/collector-field-head', { pageTitle: 'Profil', appSettings: appSettings }) %>
</head>
<body class="bg-background text-on-background min-h-screen antialiased pb-24">
  <%- include('../partials/collector-field-topbar', { topbarTitle: 'Field Collector' }) %>

  <main class="pt-[72px] pb-8 px-margin-page max-w-2xl mx-auto flex flex-col gap-stack-lg">
    <section class="flex flex-col items-center justify-center mt-stack-md gap-stack-sm text-center">
      <div class="relative w-24 h-24 rounded-full overflow-hidden border-4 border-surface-container-lowest shadow-sm mb-2 bg-primary-fixed flex items-center justify-center">
        <span class="material-symbols-outlined text-5xl text-on-primary-fixed">person</span>
      </div>
      <h2 class="font-h1 text-h1 text-on-surface"><%= collector.name || 'Kolektor' %></h2>
      <div class="inline-flex items-center px-3 py-1 bg-surface-container rounded-full border border-outline-variant">
        <span class="font-label-caps text-label-caps text-on-surface-variant">ID: <%= collector.id %></span>
      </div>
    </section>

    <section class="grid grid-cols-2 gap-gutter-card">
      <div class="bg-surface-container-lowest rounded-xl p-padding-interactive border border-outline-variant shadow-[0_2px_8px_rgba(0,0,0,0.02)] flex flex-col gap-stack-sm">
        <div class="flex items-center gap-2 text-primary">
          <span class="material-symbols-outlined fill text-[20px]">account_balance_wallet</span>
          <span class="font-label-caps text-label-caps text-on-surface-variant">Komisi bulan ini</span>
        </div>
        <div class="font-numeric-data text-numeric-data text-on-surface tracking-tight">
          Rp <%= (profileStats.monthlyCommission || 0).toLocaleString('id-ID') %>
        </div>
      </div>
      <div class="bg-surface-container-lowest rounded-xl p-padding-interactive border border-outline-variant shadow-[0_2px_8px_rgba(0,0,0,0.02)] flex flex-col gap-stack-sm">
        <div class="flex items-center gap-2 text-secondary">
          <span class="material-symbols-outlined fill text-[20px]">trending_up</span>
          <span class="font-label-caps text-label-caps text-on-surface-variant">Transaksi selesai</span>
        </div>
        <div class="font-numeric-data text-numeric-data text-on-surface tracking-tight">
          <%= profileStats.totalCollections || 0 %>
        </div>
      </div>
    </section>

    <section class="bg-surface-container-lowest rounded-xl border border-outline-variant shadow-[0_2px_8px_rgba(0,0,0,0.02)] overflow-hidden">
      <div class="p-padding-interactive border-b border-surface-variant bg-surface-bright">
        <h3 class="font-h2 text-h2 text-on-surface">Statistik singkat</h3>
      </div>
      <div class="p-padding-interactive flex flex-col gap-stack-md">
        <div class="flex justify-between items-end">
          <div class="flex flex-col gap-1">
            <span class="font-label-caps text-label-caps text-on-surface-variant">Pembayaran tercatat</span>
            <span class="font-numeric-data text-numeric-data text-on-surface"><%= profileStats.totalCollections %></span>
          </div>
          <div class="flex flex-col gap-1 text-right">
            <span class="font-label-caps text-label-caps text-on-surface-variant">Rasio lunas / tagihan</span>
            <span class="font-numeric-data text-numeric-data text-secondary"><%= profileStats.successRate %>%</span>
          </div>
        </div>
        <div class="w-full bg-surface-container-highest rounded-full h-2.5 overflow-hidden">
          <div class="bg-secondary-fixed-dim h-2.5 rounded-full transition-all" style="width: <%= profileStats.successRate %>%"></div>
        </div>
      </div>
    </section>

    <section class="bg-surface-container-lowest rounded-xl border border-outline-variant shadow-[0_2px_8px_rgba(0,0,0,0.02)] overflow-hidden flex flex-col">
      <a href="/collector/profile/edit" class="flex items-center gap-4 p-padding-interactive border-b border-surface-variant hover:bg-surface-container-low active:bg-surface-container-high transition-colors w-full text-left">
        <span class="material-symbols-outlined text-on-surface-variant">settings</span>
        <span class="font-body-lg text-body-lg text-on-surface flex-1">Pengaturan akun</span>
        <span class="material-symbols-outlined text-outline-variant">chevron_right</span>
      </a>
      <span class="flex items-center gap-4 p-padding-interactive border-b border-surface-variant opacity-60 w-full text-left cursor-default">
        <span class="material-symbols-outlined text-on-surface-variant">help_center</span>
        <span class="font-body-lg text-body-lg text-on-surface flex-1">Pusat bantuan</span>
        <span class="material-symbols-outlined text-outline-variant">chevron_right</span>
      </span>
      <span class="flex items-center gap-4 p-padding-interactive border-b border-surface-variant opacity-60 w-full text-left cursor-default">
        <span class="material-symbols-outlined text-on-surface-variant">policy</span>
        <span class="font-body-lg text-body-lg text-on-surface flex-1">Kebijakan privasi</span>
        <span class="material-symbols-outlined text-outline-variant">chevron_right</span>
      </span>
      <button type="button" onclick="collectorLogout()" class="flex items-center gap-4 p-padding-interactive hover:bg-error-container/20 active:bg-error-container/40 transition-colors w-full text-left">
        <span class="material-symbols-outlined text-error">logout</span>
        <span class="font-body-lg text-body-lg text-error flex-1 font-medium">Keluar</span>
      </button>
    </section>
  </main>

  <%- include('../partials/collector-bottom-nav', { currentPage: 'profile' }) %>
  <script src="/js/collector-pwa.js"></script>
  <script>
    function collectorLogout() {
      if (!confirm('Keluar dari akun kolektor?')) return;
      fetch('/collector/logout', { method: 'POST', headers: { 'Content-Type': 'application/json' } })
        .then(function() { window.location.href = '/collector/login'; })
        .catch(function() { window.location.href = '/collector/logout'; });
    }
  </script>
</body>
</html>
