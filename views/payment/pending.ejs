<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('../partials/hard-reload') %>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - <%= appSettings.companyHeader %></title>
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link href="/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
    
    <link href="/css/theme.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/customer-responsive.css">
    <style>
        body { background: #f8f9fa; }
        .payment-card { border: none; border-radius: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); }
        .pending-icon { font-size: 4rem; color: #ffc107; }
        .spinner { animation: spin 1s linear infinite; }
        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
    </style>

    <!-- GLOBAL THEME INJECTION -->
    <script>
      (function(){
        if(window.__theme_init) return; window.__theme_init=true;
        var t=localStorage.getItem('kalimasada_theme');
        if(!t) t=window.matchMedia('(prefers-color-scheme: dark)').matches?'dark':'light';
        document.documentElement.setAttribute('data-theme',t);
      })();
    </script>
    <link href="/css/dark-theme-global.css?v=2" rel="stylesheet">
    <link href="/css/theme-system.css?v=2" rel="stylesheet">
    <link href="/css/theme-overrides.css?v=1" rel="stylesheet">
    <!-- END GLOBAL THEME INJECTION -->
</head>
<body>
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card payment-card">
                    <div class="card-body text-center p-5">
                        <i class="bi bi-clock-fill pending-icon mb-3"></i>
                        <h3 class="text-warning mb-3">Pembayaran Pending</h3>
                        <p class="text-muted mb-4">
                            Pembayaran Anda sedang diproses. 
                            Mohon tunggu beberapa saat untuk konfirmasi.
                        </p>

                        <div class="payment-alert alert-warning">
                            <i class="bi bi-info-circle"></i>
                            <strong>Status:</strong> Menunggu konfirmasi pembayaran
                        </div>

                        <% if (order_id) { %>
                            <div class="payment-order-id">
                                <strong>Order ID:</strong> <%= order_id %>
                            </div>
                        <% } %>

                        <div class="d-grid gap-2 payment-buttons">
                            <button class="btn btn-warning" onclick="checkPaymentStatus()">
                                <i class="bi bi-arrow-clockwise"></i> Cek Status Pembayaran
                            </button>
                            <a href="/customer" class="btn btn-primary">
                                <i class="bi bi-house"></i> Kembali ke Dashboard
                            </a>
                            <a href="/customer/billing/invoices" class="btn btn-outline-secondary">
                                <i class="bi bi-receipt"></i> Lihat Tagihan
                            </a>
                        </div>

                        <div class="payment-contact">
                            <small>
                                <i class="bi bi-telephone"></i> <%= appSettings.contact_phone || '0812-3456-7890' %> | 
                                <i class="bi bi-whatsapp"></i> <%= appSettings.contact_whatsapp || '0813-6888-8498' %>
                            </small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="/js/customer-mobile.js"></script>
    <script>
        function checkPaymentStatus() {
            // Auto refresh after 5 seconds
            setTimeout(() => {
                window.location.reload();
            }, 5000);
            
            // Show loading state
            const button = event.target;
            const originalText = button.innerHTML;
            button.innerHTML = '<i class="bi bi-arrow-clockwise spinner"></i> Mengecek...';
            button.disabled = true;
            
            setTimeout(() => {
                button.innerHTML = originalText;
                button.disabled = false;
            }, 5000);
        }
    </script>
</body>
</html> 