<script>
document.addEventListener('DOMContentLoaded', function () {
    const sidebar = document.getElementById('billingSidebar');
    const hamburgerBtn = document.getElementById('hamburgerBtn');
    const sidebarClose = document.getElementById('sidebarClose');
    const overlay = document.getElementById('sidebarOverlay');
    const sidebarToggle = document.getElementById('sidebarToggle');
    const mainContent = document.querySelector('.main-content');

    // Desktop sidebar collapse logic
    if (hamburgerBtn) {
        hamburgerBtn.addEventListener('click', function() {
            sidebar.classList.toggle('collapsed');
            if (mainContent) {
                if (sidebar.classList.contains('collapsed')) {
                    mainContent.classList.remove('sidebar-expanded');
                    mainContent.classList.add('sidebar-collapsed');
                    localStorage.setItem('sidebarState', 'collapsed');
                } else {
                    mainContent.classList.remove('sidebar-collapsed');
                    mainContent.classList.add('sidebar-expanded');
                    localStorage.setItem('sidebarState', 'expanded');
                }
            }
        });
    }

    // Mobile sidebar toggle logic
    if (sidebarToggle) {
        sidebarToggle.addEventListener('click', function() {
            sidebar.classList.add('show');
            overlay.classList.add('show');
            document.body.style.overflow = 'hidden';
        });
    }

    // Initial state set
    if (window.innerWidth >= 768) {
        const savedState = localStorage.getItem('sidebarState');
        if (savedState === 'collapsed') {
            sidebar.classList.add('collapsed');
            if (mainContent) {
                mainContent.classList.remove('sidebar-expanded');
                mainContent.classList.add('sidebar-collapsed');
            }
        } else {
            sidebar.classList.remove('collapsed');
            if (mainContent) {
                mainContent.classList.add('sidebar-expanded');
                mainContent.classList.remove('sidebar-collapsed');
            }
        }
    } else {
        if (mainContent) {
            mainContent.classList.remove('sidebar-expanded', 'sidebar-collapsed');
        }
    }
    
    function closeSidebar() {
        sidebar.classList.remove('show');
        overlay.classList.remove('show');
        document.body.style.overflow = '';
    }
    
    if (sidebarClose) sidebarClose.addEventListener('click', closeSidebar);
    if (overlay) overlay.addEventListener('click', closeSidebar);
    
    window.addEventListener('resize', function() {
        if (window.innerWidth >= 768) closeSidebar();
    });

    // Function to handle collapse toggle icons
    function setupCollapseToggle(collapseId) {
        var toggler = document.querySelector('[data-target-id="' + collapseId + '"]');
        var collapseEl = document.getElementById(collapseId);
        
        if (toggler && collapseEl && typeof bootstrap !== 'undefined') {
            var icon = toggler.querySelector('.toggle-arrow');
            
            // Sync initial state
            if (collapseEl.classList.contains('show')) {
                if (icon) icon.classList.replace('bi-chevron-down', 'bi-chevron-up');
                toggler.setAttribute('aria-expanded', 'true');
            }

            // Manual toggle on click
            toggler.addEventListener('click', function(e) {
                e.preventDefault();
                e.stopPropagation();
                const bsCollapse = bootstrap.Collapse.getOrCreateInstance(collapseEl, { toggle: false });
                bsCollapse.toggle();
            });

            collapseEl.addEventListener('show.bs.collapse', function () {
                if (icon) icon.classList.replace('bi-chevron-down', 'bi-chevron-up');
                toggler.setAttribute('aria-expanded', 'true');
            });
            
            collapseEl.addEventListener('hide.bs.collapse', function () {
                if (icon) icon.classList.replace('bi-chevron-up', 'bi-chevron-down');
                toggler.setAttribute('aria-expanded', 'false');
            });
            
            // Ensure Bootstrap instance exists
            bootstrap.Collapse.getOrCreateInstance(collapseEl, { toggle: false });
        }
    }
    
    ['customerCollapse','invoiceCollapse','financeCollapse', 'settingCollapse'].forEach(setupCollapseToggle);

    // Restart Billing System
    const restartBillingBtn = document.getElementById('btnRestartBilling');
    const restartResultBox = document.getElementById('billingRestartResult');
    const serverTimeValue = document.getElementById('serverTimeValue');
    let serverTimeOffset = null;

    function showRestartResult(text, success = true) {
        if (!restartResultBox) return;
        restartResultBox.style.display = 'block';
        restartResultBox.style.color = success ? '#c8e6c9' : '#ffcdd2';
        restartResultBox.textContent = text;
    }

    function renderServerTime() {
        if (serverTimeOffset === null || !serverTimeValue) return;
        const current = new Date(Date.now() + serverTimeOffset);
        serverTimeValue.textContent = current.toLocaleString('id-ID', {
            timeZone: 'Asia/Jakarta', year: 'numeric', month: '2-digit', day: '2-digit',
            hour: '2-digit', minute: '2-digit', second: '2-digit'
        });
    }

    async function fetchServerInfo() {
        try {
            const res = await fetch('/admin/billing/system/server-info');
            const data = await res.json();
            if (data.serverTimeIso) {
                serverTimeOffset = new Date(data.serverTimeIso).getTime() - Date.now();
                renderServerTime();
            }
        } catch (error) {
            if (serverTimeValue) serverTimeValue.textContent = 'Gagal memuat waktu';
        }
    }

    if (restartBillingBtn) {
        restartBillingBtn.addEventListener('click', async () => {
            if (!confirm('Restart layanan billing sekarang?')) return;
            try {
                restartBillingBtn.disabled = true;
                restartBillingBtn.innerHTML = '<i class="bi bi-hourglass-split"></i> Restarting...';
                showRestartResult('Memproses restart...', true);
                const res = await fetch('/admin/billing/system/restart', { method: 'POST', headers: { 'Content-Type': 'application/json' } });
                const data = await res.json();
                if (!data.success) {
                    showRestartResult('Restart gagal: ' + (data.message || 'Error'), false);
                } else {
                    showRestartResult('Restart berhasil.', true);
                    await fetchServerInfo();
                }
            } catch (error) {
                showRestartResult('Restart error: ' + error.message, false);
            } finally {
                restartBillingBtn.disabled = false;
                restartBillingBtn.innerHTML = '<i class="bi bi-arrow-repeat"></i> Restart Billing System';
            }
        });
    }

    fetchServerInfo();
    setInterval(renderServerTime, 1000);
    
    function refreshLogo() {
        const logo = document.getElementById('logoImage');
        if (logo) {
            const timestamp = new Date().getTime();
            const src = logo.src.split('?')[0];
            logo.src = `${src}?v=${timestamp}`;
        }
    }
    if (document.getElementById('logoImage')) setInterval(refreshLogo, 5000);

    // --- SMOOTH AJAX NAVIGATION (PJAX) ---
    function executeScripts(container) {
        const scripts = container.querySelectorAll('script');
        scripts.forEach(oldScript => {
            const newScript = document.createElement('script');
            Array.from(oldScript.attributes).forEach(attr => newScript.setAttribute(attr.name, attr.value));
            newScript.appendChild(document.createTextNode(oldScript.innerHTML));
            oldScript.parentNode.replaceChild(newScript, oldScript);
        });
    }

    function updateSidebarActive(url) {
        const path = new URL(url, window.location.origin).pathname;
        sidebar.querySelectorAll('a').forEach(link => {
            const linkPath = new URL(link.getAttribute('href'), window.location.origin).pathname;
            const isActive = (path === linkPath);
            link.classList.toggle('active', isActive);
            
            if (isActive) {
                let parent = link.closest('.collapse');
                while (parent) {
                    if (typeof bootstrap !== 'undefined') {
                        const bsCollapse = bootstrap.Collapse.getOrCreateInstance(parent, { toggle: false });
                        if (!parent.classList.contains('show')) {
                            bsCollapse.show();
                        }
                    }
                    const toggler = document.querySelector('[data-target-id="' + parent.id + '"]');
                    if (toggler) {
                        const arrow = toggler.querySelector('.toggle-arrow');
                        if (arrow) arrow.classList.replace('bi-chevron-down', 'bi-chevron-up');
                        toggler.setAttribute('aria-expanded', 'true');
                    }
                    parent = parent.parentElement.closest('.collapse');
                }
            }
        });
    }

    function loadPjaxContent(url, pushState = true) {
        const loader = document.getElementById('pjax-loader');
        if (loader) loader.style.width = '30%';
        
        fetch(url)
            .then(res => { if (!res.ok) throw new Error(); return res.text(); })
            .then(html => {
                const doc = new DOMParser().parseFromString(html, 'text/html');
                const newContent = doc.querySelector('#pjax-container') || doc.querySelector('.main-content');
                const current = document.getElementById('pjax-container') || document.querySelector('.main-content');
                
                if (newContent && current) {
                    current.innerHTML = newContent.innerHTML;
                    Array.from(newContent.attributes).forEach(attr => current.setAttribute(attr.name, attr.value));
                    document.title = doc.title;
                    if (pushState) history.pushState({ url }, doc.title, url);
                    updateSidebarActive(url);
                    executeScripts(current);
                    if (window.innerWidth < 768) closeSidebar();
                    window.scrollTo(0, 0);
                    if (loader) loader.style.width = '100%';
                    setTimeout(() => { if(loader) loader.style.width = '0'; }, 300);
                } else { window.location.href = url; }
            })
            .catch(() => { window.location.href = url; });
    }

    // Helper: check if URL belongs to billing sidebar
    function isBillingUrl(url) {
        return url.startsWith('/admin/billing') || url.startsWith('/admin/collectors') || url.startsWith('/admin/member');
    }

    document.addEventListener('click', e => {
        const link = e.target.closest('a');
        if (!link) return;
        const url = link.getAttribute('href');
        if (!url || url.startsWith('#') || url.startsWith('javascript:') || url.includes('logout') || link.target === '_blank' || link.hasAttribute('data-no-pjax')) return;
        if (url.startsWith('/admin')) {
            e.preventDefault();
            // If navigating to non-billing admin pages, force full reload so admin sidebar loads
            if (!isBillingUrl(url)) {
                window.location.href = url;
            } else {
                loadPjaxContent(url);
            }
        }
    });

    window.addEventListener('popstate', e => {
        loadPjaxContent(e.state && e.state.url ? e.state.url : window.location.pathname, false);
    });
});
</script>

<div id="pjax-loader" style="position: fixed; top: 0; left: 0; height: 3px; background: #fff; width: 0; z-index: 10005; transition: width 0.4s ease;"></div>

<style>
/* CSS copied from original for consistency */
