    const restartResultBox = document.getElementById('billingRestartResult');
    const serverTimeValue = document.getElementById('serverTimeValue');
    const serverBranchValue = document.getElementById('serverBranchValue');
    const btnCheckUpdate = document.getElementById('btnCheckUpdate');
    const btnRunUpdate = document.getElementById('btnRunUpdate');
    const updateResult = document.getElementById('updateResult');
    let serverTimeOffset = null;
    function showUpdateResult(text, success = true) {
        if (!updateResult) return;
        updateResult.style.display = 'block';
        updateResult.style.color = success ? '#c8e6c9' : '#ffcdd2';
        updateResult.textContent = text;
    }

    function showRestartResult(text, success = true) {
        if (!restartResultBox) return;
        restartResultBox.style.display = 'block';
        restartResultBox.style.color = success ? '#c8e6c9' : '#ffcdd2';
        restartResultBox.textContent = text;
    }

    function renderServerTime() {
        if (serverTimeOffset === null || !serverTimeValue) return;
        const current = new Date(Date.now() + serverTimeOffset);
        serverTimeValue.textContent = current.toLocaleString('id-ID', {
            timeZone: 'Asia/Jakarta',
            year: 'numeric',
            month: '2-digit',
            day: '2-digit',
            hour: '2-digit',
            minute: '2-digit',
            second: '2-digit'
        });
    }

    async function fetchServerInfo() {
        try {
            const res = await fetch('/admin/billing/system/server-info');
            const data = await res.json();
            if (!data.success && !data.serverTimeIso) {
                throw new Error(data.message || 'Gagal mengambil info server');
            }
            if (serverBranchValue && data.branch) {
                serverBranchValue.textContent = `Branch: ${data.branch}`;
            }
            if (gitBranchInput && (!gitBranchInput.value || gitBranchInput.dataset.autofilled !== 'false') && data.branch) {
                gitBranchInput.value = data.branch;
                gitBranchInput.dataset.autofilled = 'true';
            }
            if (data.serverTimeIso) {
                serverTimeOffset = new Date(data.serverTimeIso).getTime() - Date.now();
                renderServerTime();
            }
        } catch (error) {
            if (serverTimeValue) {
                serverTimeValue.textContent = 'Gagal memuat waktu';
            }
            console.error('Failed to fetch server info:', error);
        }
    }

    if (gitBranchInput) {
        gitBranchInput.addEventListener('input', () => {
            gitBranchInput.dataset.autofilled = 'false';
        });
    }

    if (btnCheckUpdate) {
        btnCheckUpdate.addEventListener('click', async () => {
            try {
                showUpdateResult('Checking updates...', true);
                const branch = (gitBranchInput && gitBranchInput.value.trim()) || '';
                const url = branch ? `/admin/billing/system/check-update?branch=${encodeURIComponent(branch)}` : '/admin/billing/system/check-update';
                const res = await fetch(url);
                const data = await res.json();
                if (!data.success) {
                    showUpdateResult('Check update failed: ' + (data.message || 'Unknown error'), false);
                    return;
                }
                const summary = data.hasUpdate
                    ? `Update tersedia di branch ${data.branch}.\nLocal: ${data.local}\nRemote: ${data.remote}\nCommits:\n${data.commits || '(tidak ada daftar)'}`
                    : `Tidak ada update.\nBranch: ${data.branch}\nLocal == Remote: ${data.local}`;
                showUpdateResult(summary, true);
            } catch (error) {
                showUpdateResult('Check update error: ' + error.message, false);
            }
        });
    }

    if (btnRunUpdate) {
        btnRunUpdate.addEventListener('click', async () => {
            if (!confirm('Peringatan: pastikan file konfigurasi penting sudah dicadangkan. Lanjutkan update & restart?')) return;
            try {
                showUpdateResult('Menjalankan update... mohon tunggu.', true);
                const branch = (gitBranchInput && gitBranchInput.value.trim()) || '';
                const res = await fetch('/admin/billing/system/update', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ branch: branch || undefined })
                });
                const data = await res.json();
                if (!data.success) {
                    showUpdateResult('Update gagal: ' + (data.message || 'Unknown error') + '\n' + (data.error || '') + '\n' + (data.log || ''), false);
                    return;
                }
                showUpdateResult('Update selesai. Aplikasi akan direload oleh PM2.\n' + (data.log || ''), true);
            } catch (error) {
                showUpdateResult('Update error: ' + error.message, false);
            }
        });
    }

    if (restartBillingBtn) {
        restartBillingBtn.addEventListener('click', async () => {
            if (!confirm('Restart layanan billing sekarang?')) return;
            try {
                restartBillingBtn.disabled = true;
                restartBillingBtn.innerHTML = '<i class="bi bi-hourglass-split"></i> Restarting...';
                showRestartResult('Memproses restart...', true);
                const res = await fetch('/admin/billing/system/restart', { method: 'POST', headers: { 'Content-Type': 'application/json' } });
                const data = await res.json();
                if (!data.success) {
                    showRestartResult('Restart gagal: ' + (data.message || 'Unknown error') + '\n' + (data.error || ''), false);
                } else {
                    showRestartResult('Restart berhasil dijalankan.', true);
                    await fetchServerInfo();
                }
            } catch (error) {
                showRestartResult('Restart error: ' + error.message, false);
            } finally {
                restartBillingBtn.disabled = false;
                restartBillingBtn.innerHTML = '<i class="bi bi-arrow-repeat"></i> Restart Billing System';
            }
        });
    }

    fetchServerInfo();
    setInterval(renderServerTime, 1000);
    const sidebarToggle = document.getElementById('sidebarToggle'); // Mobile
    const hamburgerBtn = document.getElementById('hamburgerBtn'); // Desktop
    const sidebarClose = document.getElementById('sidebarClose');
    const sidebar = document.getElementById('sidebar');
    const overlay = document.getElementById('sidebarOverlay');
    
    // Toggle sidebar on hamburger click (mobile)
    if (sidebarToggle) {
        sidebarToggle.addEventListener('click', function() {
            if (window.innerWidth < 768) {
                // For mobile: use existing show/hide
                sidebar.classList.add('show');
                overlay.classList.add('show');
                document.body.style.overflow = 'hidden'; // Prevent background scrolling
            }
        });
    }
    
    // Desktop hamburger toggle
    if (hamburgerBtn) {
        hamburgerBtn.addEventListener('click', function() {
            if (window.innerWidth >= 768) {
                const isCollapsed = sidebar.classList.contains('collapsed');
                const mainContent = document.querySelector('.main-content');
                
                if (isCollapsed) {
                    sidebar.classList.remove('collapsed');
                    if (mainContent) {
                        mainContent.classList.remove('sidebar-collapsed');
                        mainContent.classList.add('sidebar-expanded');
                    }
                    localStorage.setItem('sidebarCollapsed', 'false');
                } else {
                    sidebar.classList.add('collapsed');
                    if (mainContent) {
                        mainContent.classList.remove('sidebar-expanded');
                        mainContent.classList.add('sidebar-collapsed');
                    }
                    localStorage.setItem('sidebarCollapsed', 'true');
                }
            }
        });
    }
    
    // Restore sidebar state from localStorage on page load (desktop only)
    if (window.innerWidth >= 768) {
        const sidebarState = localStorage.getItem('sidebarCollapsed');
        const mainContent = document.querySelector('.main-content');
        if (sidebarState === 'true') {
            sidebar.classList.add('collapsed');
            if (mainContent) {
                mainContent.classList.remove('sidebar-expanded');
                mainContent.classList.add('sidebar-collapsed');
            }
        } else {
            sidebar.classList.remove('collapsed');
            if (mainContent) {
                mainContent.classList.add('sidebar-expanded');
                mainContent.classList.remove('sidebar-collapsed');
            }
        }
    } else {
        // On mobile, ensure main content has no margin
        const mainContent = document.querySelector('.main-content');
        if (mainContent) {
            mainContent.classList.remove('sidebar-expanded', 'sidebar-collapsed');
        }
    }
    
    // Hide sidebar section headers when collapsed
    function updateSidebarCollapsedState() {
        if (sidebar.classList.contains('collapsed')) {
            sidebar.querySelectorAll('.sidebar-section-header').forEach(header => {
                header.style.display = 'none';
            });
        } else {
            sidebar.querySelectorAll('.sidebar-section-header').forEach(header => {
                header.style.display = 'flex';
            });
        }
    }
    
    // Call on initial load and when collapsed state changes
    updateSidebarCollapsedState();
    hamburgerBtn?.addEventListener('click', updateSidebarCollapsedState);
    
    // Close sidebar functions
    function closeSidebar() {
        sidebar.classList.remove('show');
        overlay.classList.remove('show');
        document.body.style.overflow = ''; // Restore scrolling
    }
    
    // Close sidebar on close button click
    if (sidebarClose) {
        sidebarClose.addEventListener('click', closeSidebar);
    }
    
    // Close sidebar on overlay click
    if (overlay) {
        overlay.addEventListener('click', closeSidebar);
    }
    
    // Close sidebar when clicking on nav links (mobile)
    const navLinks = sidebar.querySelectorAll('a');
    navLinks.forEach(link => {
        link.addEventListener('click', function() {
            if (window.innerWidth < 768) {
                setTimeout(closeSidebar, 100); // Small delay for better UX
            }
        });
    });
    
    // Handle window resize
    window.addEventListener('resize', function() {
        if (window.innerWidth >= 768) {
            closeSidebar();
        }
    });
    
    // Prevent body scroll when sidebar is open on mobile
    sidebar.addEventListener('touchmove', function(e) {
        if (sidebar.classList.contains('show')) {
            e.stopPropagation();
        }
    });
});
</script> 