<%
/**
 * Format datetime dari DB ke tampilan Asia/Jakarta:
 * - nilai berakhiran +07:00 / Z: dipakai apa adanya;
 * - datetime tanpa zona: dianggap UTC (legacy SQLite CURRENT_TIMESTAMP), ditambah Z;
 * - tanggal saja YYYY-MM-DD: tengah malam UTC.
 */
formatDbUtcToJakartaDate = function (dt) {
    if (dt == null || dt === '') return 'N/A';
    const s = String(dt).trim();
    if (!s) return 'N/A';
    let iso;
    if (/^\d{4}-\d{2}-\d{2}$/.test(s)) iso = s + 'T00:00:00Z';
    else {
        iso = s.includes('T') ? s : s.replace(/ /, 'T');
        if (!/[zZ]|[+-]\d{2}:?\d{2}$/.test(iso)) iso += 'Z';
    }
    const d = new Date(iso);
    if (isNaN(d.getTime())) return 'N/A';
    return d.toLocaleDateString('id-ID', { timeZone: 'Asia/Jakarta', day: 'numeric', month: 'long', year: 'numeric' });
};
formatDbUtcToJakartaDateTime = function (dt) {
    if (dt == null || dt === '') return 'N/A';
    const s = String(dt).trim();
    if (!s) return 'N/A';
    let iso;
    if (/^\d{4}-\d{2}-\d{2}$/.test(s)) iso = s + 'T00:00:00Z';
    else {
        iso = s.includes('T') ? s : s.replace(/ /, 'T');
        if (!/[zZ]|[+-]\d{2}:?\d{2}$/.test(iso)) iso += 'Z';
    }
    const d = new Date(iso);
    if (isNaN(d.getTime())) return 'N/A';
    return d.toLocaleString('id-ID', {
        timeZone: 'Asia/Jakarta',
        day: 'numeric',
        month: 'long',
        year: 'numeric',
        hour: '2-digit',
        minute: '2-digit'
    });
};
%>
