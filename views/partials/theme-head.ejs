<!-- THEME HEAD PARTIAL — Kalimasada Theme System v1.0 -->
<script>
(function(){
  try {
    if (window.__km_theme_init) return;
    window.__km_theme_init = true;
    var stored = localStorage.getItem('kalimasada_theme');
    var theme = (stored === 'dark' || stored === 'light') ? stored
      : (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
    localStorage.setItem('kalimasada_theme', theme);
    document.documentElement.setAttribute('data-theme', theme);
    window.KALIMASADA_THEME = theme;
  } catch(e) {
    document.documentElement.setAttribute('data-theme', 'light');
  }
})();
</script>
<!-- Browser tab favicon (explicit links so Chrome does not keep an old implicit /favicon.ico cache) -->
<link rel="icon" href="/favicon.ico?v=3" sizes="any">
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png?v=3">
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png?v=3">
<link rel="apple-touch-icon" href="/icons/icon-192x192.png?v=3">
<link rel="stylesheet" href="/css/theme-system.css?v=6">
<link rel="stylesheet" href="/css/kalimasada-theme.css?v=1.0.2">

<!-- Badge Color System CSS -->
<style>
/* ── Custom Badge Colors ─────────────────────────────────── */
/* Brown / Cokelat = Nonaktif */
.badge.bg-brown {
  background-color: #92400e !important;
  color: #fef3c7 !important;
}
html[data-theme='light'] .badge.bg-brown,
html:not([data-theme='dark']) .badge.bg-brown {
  background-color: #fef3c7 !important;
  color: #78350f !important;
  border: 1px solid #f59e0b44;
}

/* ── Light Mode: semua badge teks harus gelap ───────────── */
html[data-theme='light'] .badge,
html:not([data-theme='dark']) .badge {
  color: #0f172a !important;
  font-weight: 600 !important;
}

/* Pengecualian: badge yang isi teksnya butuh kontras berbeda */
html[data-theme='light'] .badge.bg-danger,
html:not([data-theme='dark']) .badge.bg-danger {
  background-color: #fee2e2 !important;
  color: #991b1b !important;
  border: 1px solid #fca5a544;
}
html[data-theme='light'] .badge.bg-success,
html:not([data-theme='dark']) .badge.bg-success {
  background-color: #dcfce7 !important;
  color: #166534 !important;
  border: 1px solid #86efac44;
}
html[data-theme='light'] .badge.bg-warning,
html:not([data-theme='dark']) .badge.bg-warning {
  background-color: #fef9c3 !important;
  color: #713f12 !important;
  border: 1px solid #fde04744;
}
html[data-theme='light'] .badge.bg-primary,
html:not([data-theme='dark']) .badge.bg-primary {
  background-color: #dbeafe !important;
  color: #1e40af !important;
  border: 1px solid #93c5fd44;
}
html[data-theme='light'] .badge.bg-info,
html:not([data-theme='dark']) .badge.bg-info {
  background-color: #cffafe !important;
  color: #155e75 !important;
  border: 1px solid #67e8f944;
}
html[data-theme='light'] .badge.bg-secondary,
html:not([data-theme='dark']) .badge.bg-secondary {
  background-color: #f1f5f9 !important;
  color: #475569 !important;
  border: 1px solid #cbd5e144;
}

/* ── Dark Mode: badge tetap pakai warna Bootstrap default ─ */
html[data-theme='dark'] .badge.bg-success { background-color: #16a34a !important; color: #fff !important; }
html[data-theme='dark'] .badge.bg-danger  { background-color: #dc2626 !important; color: #fff !important; }
html[data-theme='dark'] .badge.bg-warning { background-color: #d97706 !important; color: #fff !important; }
html[data-theme='dark'] .badge.bg-primary { background-color: #2563eb !important; color: #fff !important; }
html[data-theme='dark'] .badge.bg-info    { background-color: #0891b2 !important; color: #fff !important; }
html[data-theme='dark'] .badge.bg-secondary { background-color: #475569 !important; color: #fff !important; }
html[data-theme='dark'] .badge.bg-brown   { background-color: #92400e !important; color: #fef3c7 !important; }
/* ── Global Toast Opacity & Background Fix ────────────────── */
.toast {
  --bs-toast-bg-opacity: 1 !important;
  background-color: rgba(var(--bs-body-bg-rgb), 1) !important;
}
.toast.bg-success { background-color: #198754 !important; color: #fff !important; }
.toast.bg-danger { background-color: #dc3545 !important; color: #fff !important; }
.toast.bg-warning { background-color: #ffc107 !important; color: #000 !important; }
.toast.bg-info { background-color: #0dcaf0 !important; color: #000 !important; }
.toast.bg-primary { background-color: #0d6efd !important; color: #fff !important; }
</style>

