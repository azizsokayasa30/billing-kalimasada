<!-- Sidebar Admin -->
<div class="d-flex flex-column flex-shrink-0 p-3 bg-light" style="width: 250px; min-height: 100vh;">
  <a href="/admin/dashboard" class="d-flex align-items-center mb-3 mb-md-0 me-md-auto link-dark text-decoration-none">
    <span class="fs-4">Admin Panel</span>
  </a>
  <hr>
  <ul class="nav nav-pills flex-column mb-auto">
    <li class="nav-item">
      <a href="/admin/dashboard" class="nav-link <%= page === 'dashboard' ? 'active' : 'link-dark' %>">
        <i class="bi bi-speedometer2"></i> Dashboard
      </a>
    </li>
    <li>
      <a href="/admin/genieacs" class="nav-link <%= page === 'genieacs' ? 'active' : 'link-dark' %>">
        <i class="bi bi-hdd-network"></i> GenieACS
      </a>
    </li>
    <li>
      <a href="/admin/mikrotik" class="nav-link <%= page === 'mikrotik' ? 'active' : 'link-dark' %>">
        <i class="bi bi-router"></i> Mikrotik
      </a>
    </li>
    <li>
      
    </li>
    <% const hotspotPages = ['hotspot-settings','hotspot-master','hotspot-users','hotspot-profiles','hotspot-server-profiles']; %>
    <% const hotspotExpanded = hotspotPages.includes(page); %>
    <li class="nav-item mt-2">
      <button class="nav-link text-uppercase text-muted small border-0 bg-transparent d-flex justify-content-between align-items-center w-100"
              type="button"
              data-bs-toggle="collapse"
              data-bs-target="#sidebarHotspotCollapse"
              aria-expanded="<%= hotspotExpanded ? 'true' : 'false' %>"
              aria-controls="sidebarHotspotCollapse"
              style="cursor:pointer;">
        <span><i class="bi bi-wifi me-2"></i>Hotspot</span>
        <i class="bi <%= hotspotExpanded ? 'bi-chevron-up' : 'bi-chevron-down' %> toggle-arrow"></i>
      </button>
      <div class="collapse <%= hotspotExpanded ? 'show' : '' %>" id="sidebarHotspotCollapse">
        <ul class="nav flex-column ms-3">
          <li class="nav-item">
            <a href="/admin/mikrotik/hotspot-server-profiles" class="nav-link <%= page === 'hotspot-server-profiles' ? 'active' : 'link-dark' %>">
              <i class="bi bi-server"></i> Server Profile
            </a>
          </li>
          <li class="nav-item">
            <a href="/admin/mikrotik/hotspot-profiles" class="nav-link <%= page === 'hotspot-profiles' ? 'active' : 'link-dark' %>">
              <i class="bi bi-wifi"></i> Voucher Profiles
            </a>
          </li>
          <li class="nav-item">
            <a href="/admin/hotspot/voucher" class="nav-link <%= page === 'hotspot-settings' ? 'active' : 'link-dark' %>">
              <i class="bi bi-sliders"></i> Manajemen Voucher
            </a>
          </li>
          <li class="nav-item">
            <a href="/admin/hotspot" class="nav-link <%= page === 'hotspot-master' ? 'active' : 'link-dark' %>">
              <i class="bi bi-collection"></i> Voucher Online
            </a>
          </li>
          <li class="nav-item">
            <a href="/admin/hotspot/users" class="nav-link <%= page === 'hotspot-users' ? 'active' : 'link-dark' %>">
              <i class="bi bi-people"></i> Daftar Voucher
            </a>
          </li>
        </ul>
      </div>
    </li>
    <li>
      <a href="/admin/settings" class="nav-link <%= page === 'setting' ? 'active' : 'link-dark' %>">
        <i class="bi bi-gear"></i> Setting
      </a>
    </li>
    <li>
      <a href="/admin/logout" class="nav-link link-dark">
        <i class="bi bi-box-arrow-right"></i> Logout
      </a>
    </li>
  </ul>
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      var toggler = document.querySelector('[data-bs-target="#sidebarHotspotCollapse"]');
      var collapseEl = document.getElementById('sidebarHotspotCollapse');
      if (toggler && collapseEl && typeof bootstrap !== 'undefined') {
        var icon = toggler.querySelector('.toggle-arrow');
        collapseEl.addEventListener('show.bs.collapse', function () {
          if (icon) {
            icon.classList.remove('bi-chevron-down');
            icon.classList.add('bi-chevron-up');
          }
        });
        collapseEl.addEventListener('hide.bs.collapse', function () {
          if (icon) {
            icon.classList.remove('bi-chevron-up');
            icon.classList.add('bi-chevron-down');
          }
        });
      }
    });
  </script>
  <hr>
  <div class="dropdown">
    <a href="#" class="d-flex align-items-center link-dark text-decoration-none dropdown-toggle" id="dropdownUser" data-bs-toggle="dropdown" aria-expanded="false">
      <img src="/public/img/admin.png" alt="" width="32" height="32" class="rounded-circle me-2">
      <strong>Admin</strong>
    </a>
    <ul class="dropdown-menu text-small shadow" aria-labelledby="dropdownUser">
      <li><a class="dropdown-item" href="/admin/settings">Settings</a></li>
      <li><hr class="dropdown-divider"></li>
      <li><a class="dropdown-item" href="/admin/logout">Sign out</a></li>
    </ul>
  </div>
</div>
