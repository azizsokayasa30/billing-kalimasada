<nav class="col-md-2 sidebar d-flex flex-column" id="adminSidebar">
    <style>
        #adminSidebar .sidebar-section-label {
            font-size: 0.95rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: rgba(255,255,255,0.7);
            padding: 8px 24px 4px 24px;
            margin-top: 10px;
        }
        #adminSidebar .sidebar-subitem {
            padding-left: 48px;
            font-size: 0.95rem;
        }
        #adminSidebar .sidebar-subitem i {
            margin-right: 8px;
        }
    </style>
    <div class="sidebar-header mb-4 text-center">
        <img src="/img/<%= typeof settings !== 'undefined' && settings.logo_filename ? settings.logo_filename : 'logo.png' %>?ts=<%= Date.now() %>" alt="Logo" style="max-width:120px;max-height:60px;">
    </div>
    <a href="/admin/dashboard" class="<%= typeof page !== 'undefined' && page === 'dashboard' ? 'active' : '' %>"><i class="bi bi-house"></i> Dashboard</a>
    <a href="/admin/billing/dashboard" class="<%= typeof page !== 'undefined' && page === 'billing' ? 'active' : '' %>"><i class="bi bi-receipt"></i> Billing</a>
    <a href="/admin/installations" class="<%= typeof page !== 'undefined' && page === 'installations' ? 'active' : '' %>"><i class="bi bi-tools"></i> Installation Jobs</a>
    <a href="/admin/technicians" class="<%= typeof page !== 'undefined' && page === 'technicians' ? 'active' : '' %>"><i class="bi bi-people-fill"></i> Kelola Teknisi</a>
    <a href="/admin/cable-network/odp" class="<%= typeof page !== 'undefined' && page === 'cable-network-odp' ? 'active' : '' %>"><i class="bi bi-broadcast"></i> ODP Management</a>
    <a href="/admin/cable-network/cables" class="<%= typeof page !== 'undefined' && page === 'cable-network-cables' ? 'active' : '' %>"><i class="bi bi-diagram-3"></i> Cable Routes</a>
    <a href="/admin/cable-network/analytics" class="<%= typeof page !== 'undefined' && page === 'cable-network-analytics' ? 'active' : '' %>"><i class="bi bi-bar-chart-alt-2"></i> Network Analytics</a>
    <a href="/admin/billing/mapping-new" class="<%= typeof page !== 'undefined' && page === 'mapping-new' ? 'active' : '' %>"><i class="bi bi-map"></i> Network Mapping</a>
    <a href="/admin/genieacs" class="<%= typeof page !== 'undefined' && page === 'genieacs' ? 'active' : '' %>"><i class="bi bi-hdd-network"></i> GenieACS</a>
    <a href="/admin/mikrotik" class="<%= typeof page !== 'undefined' && page === 'mikrotik' ? 'active' : '' %>"><i class="bi bi-router"></i> PPPoE</a>
    <a href="/admin/mikrotik/profiles" class="<%= typeof page !== 'undefined' && page === 'mikrotik-profiles' ? 'active' : '' %>"><i class="bi bi-person-badge"></i> Profile PPPoE</a>
    <% const hotspotPages = ['hotspot-settings','hotspot-master','hotspot-users','hotspot-profiles','hotspot-server-profiles']; %>
    <% const hotspotExpanded = typeof page !== 'undefined' && hotspotPages.includes(page); %>
    <div class="sidebar-section-label d-flex justify-content-between align-items-center"
         data-bs-toggle="collapse"
         data-bs-target="#adminHotspotCollapse"
         aria-expanded="<%= hotspotExpanded ? 'true' : 'false' %>"
         aria-controls="adminHotspotCollapse"
         style="cursor:pointer;">
        <span><i class="bi bi-wifi me-2"></i>Hotspot</span>
        <i class="bi <%= hotspotExpanded ? 'bi-chevron-up' : 'bi-chevron-down' %> toggle-arrow"></i>
    </div>
    <div class="collapse <%= hotspotExpanded ? 'show' : '' %>" id="adminHotspotCollapse">
        <a href="/admin/mikrotik/hotspot-server-profiles" class="sidebar-subitem <%= typeof page !== 'undefined' && page === 'hotspot-server-profiles' ? 'active' : '' %>"><i class="bi bi-server"></i> Server Profile</a>
        <a href="/admin/mikrotik/hotspot-profiles" class="sidebar-subitem <%= typeof page !== 'undefined' && page === 'hotspot-profiles' ? 'active' : '' %>"><i class="bi bi-wifi"></i> Voucher Profiles</a>
        <a href="/admin/hotspot/voucher" class="sidebar-subitem <%= typeof page !== 'undefined' && page === 'hotspot-settings' ? 'active' : '' %>"><i class="bi bi-sliders"></i> Manajemen Voucher</a>
        <a href="/admin/hotspot" class="sidebar-subitem <%= typeof page !== 'undefined' && page === 'hotspot-master' ? 'active' : '' %>"><i class="bi bi-collection"></i> Voucher Online</a>
        <a href="/admin/hotspot/users" class="sidebar-subitem <%= typeof page !== 'undefined' && page === 'hotspot-users' ? 'active' : '' %>"><i class="bi bi-people"></i> Daftar Voucher</a>
    </div>
    <a href="/admin/trouble" class="<%= typeof page !== 'undefined' && page === 'trouble' ? 'active' : '' %>"><i class="bi bi-exclamation-triangle"></i> Trouble Report</a>
    <a href="/admin/settings" class="<%= typeof page !== 'undefined' && page === 'setting' ? 'active' : '' %>"><i class="bi bi-gear"></i> Setting</a>
    <a href="/admin/radius" class="<%= typeof page !== 'undefined' && page === 'setting-radius' ? 'active' : '' %>"><i class="bi bi-gear-wide-connected"></i> Setting RADIUS</a>
    <a href="/admin/cache" class="<%= typeof page !== 'undefined' && page === 'cache' ? 'active' : '' %>"><i class="bi bi-database"></i> Cache Management</a>
    <a href="#" id="restartMikrotikBtn"><i class="bi bi-arrow-repeat"></i> Restart Mikrotik</a>
    <a href="/admin/logout"><i class="bi bi-box-arrow-right"></i> Logout</a>
</nav>
<script>
document.addEventListener('DOMContentLoaded', function () {
    var toggler = document.querySelector('[data-bs-target="#adminHotspotCollapse"]');
    var collapseEl = document.getElementById('adminHotspotCollapse');
    if (toggler && collapseEl && typeof bootstrap !== 'undefined') {
        var icon = toggler.querySelector('.toggle-arrow');
        collapseEl.addEventListener('show.bs.collapse', function () {
            if (icon) {
                icon.classList.remove('bi-chevron-down');
                icon.classList.add('bi-chevron-up');
            }
        });
        collapseEl.addEventListener('hide.bs.collapse', function () {
            if (icon) {
                icon.classList.remove('bi-chevron-up');
                icon.classList.add('bi-chevron-down');
            }
        });
    }
});
</script>
