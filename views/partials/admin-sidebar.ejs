.sb-app-option { display: flex; align-items: center; gap: 8px; padding: 8px 10px; border-radius: 6px; color: var(--sb-muted); font-size: 13px; font-weight: 500; text-decoration: none; transition: all 150ms; }
.sb-app-option:hover { background: var(--sb-item-hover); color: var(--sb-text); text-decoration: none; }
.sb-app-option.active { color: var(--sb-primary); background: #eff6ff; }
.sb-app-option i { font-size: 14px; }

.sb-item { display: flex; align-items: center; gap: 10px; padding: 8px 12px; border-radius: var(--sb-radius); color: var(--sb-muted); font-size: 13px; font-weight: 500; cursor: pointer; transition: all 150ms; border: 1px solid transparent; position: relative; text-decoration: none; white-space: nowrap; margin-bottom: 2px; }
.sb-item i { width: 16px; font-size: 14px; flex-shrink: 0; opacity: 0.7; }
