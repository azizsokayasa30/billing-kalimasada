.sb-item.active { color: var(--sb-text); background: var(--sb-item-active); border-color: var(--sb-item-active-border); }
.sb-item.active::before { content: ''; position: absolute; left: -8px; top: 50%; transform: translateY(-50%); width: 3px; height: 18px; background: var(--sb-primary); border-radius: 99px; }
.sb-item.active i { opacity: 1; color: var(--sb-primary); }
.sb-item.sb-sub { padding-left: 2.5rem; font-size: 12.5px; }

.sb-footer { padding: 8px; border-top: 1px solid var(--sb-border); }
.sb-actions { display: flex; gap: 6px; padding: 4px 0; }
.sb-action-btn { flex: 1; display: inline-flex; align-items: center; justify-content: center; gap: 6px; padding: 7px 10px; border-radius: var(--sb-radius); font-size: 12px; font-weight: 500; font-family: 'Inter', sans-serif; cursor: pointer; transition: all 150ms; border: 1px solid var(--sb-border); background: transparent; color: var(--sb-muted); text-decoration: none; white-space: nowrap; }
.sb-action-btn:hover { background: var(--sb-item-hover); color: var(--sb-primary); border-color: #bfdbfe; text-decoration: none; }
