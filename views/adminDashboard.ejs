<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('partials/hard-reload') %>
    <meta charset="UTF-8">
    <title><% if (typeof isTechnicianView !== 'undefined' && isTechnicianView) { %>Dashboard Teknisi<% } else { %>Dashboard Admin<% } %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link href="/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
    <link href="/css/responsive-admin.css" rel="stylesheet">
    <link href="/css/dashboard-modern.css" rel="stylesheet">
</head>
<body>
<div class="container-fluid">
    <div class="row">
        <!-- Include Responsive Sidebar (Admin or Technician based on context) -->
        <% if (typeof isTechnicianView !== 'undefined' && isTechnicianView) { %>
        <%- include('partials/technician-responsive-sidebar', { page: page || 'dashboard', settings: settings, technician: technician }) %>
        <% } else { %>
        <%- include('partials/admin-responsive-sidebar', { page: 'dashboard', settings: settings }) %>
        <% } %>
        
        <main id="pjax-container" class="col-md-10 ms-sm-auto main-content">
            <!-- CONFIGURATION VALIDATION ALERTS -->
            <% if (configValidation && configValidation.hasValidationRun) { %>
                <% if (configValidation.summary && configValidation.summary.status !== 'valid') { %>
                <div class="alert alert-warning alert-dismissible fade show mb-3 auto-dismiss" role="alert" data-auto-dismiss="12000">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
                        <div class="flex-grow-1">
                            <strong>Konfigurasi Sistem Perlu Diperbaiki</strong>
                            <div class="mt-1">
                                <%= configValidation.summary.message %>
                            </div>
                            <div class="mt-2">
                                <strong>Solusi:</strong> Silakan periksa dan perbaiki konfigurasi GenieACS dan Mikrotik di halaman pengaturan.
                            </div>
                            <div class="mt-2">
                                <a href="/admin/settings" class="btn btn-warning btn-sm">
                                    <i class="bi bi-gear-fill me-1"></i>Perbaiki Konfigurasi Sekarang
                                </a>
                                <button type="button" class="btn btn-outline-warning btn-sm ms-2" onclick="clearConfigWarning()">
                                    <i class="bi bi-eye-slash me-1"></i>Sembunyikan
                                </button>
                            </div>
                        </div>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
                <% } %>
                
                <% if (configValidation.defaultSettingsWarnings && configValidation.defaultSettingsWarnings.length > 0) { %>
                <div class="alert alert-info alert-dismissible fade show mb-3 auto-dismiss" role="alert" data-auto-dismiss="6000">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-info-circle-fill me-2 fs-5"></i>
                        <div class="flex-grow-1">
                            <strong>Rekomendasi Keamanan:</strong>
                            <ul class="mb-2 mt-1">
                                <% configValidation.defaultSettingsWarnings.forEach(function(warning) { %>
                                <li><%= warning %></li>
                                <% }); %>
                            </ul>
                            <div>
                                <a href="/admin/settings" class="btn btn-outline-info btn-sm">
                                    <i class="bi bi-shield-check me-1"></i>Update Pengaturan Keamanan
                                </a>
                                <button type="button" class="btn btn-outline-secondary btn-sm ms-2" onclick="clearConfigWarning()">
                                    <i class="bi bi-eye-slash me-1"></i>Sembunyikan
                                </button>
                            </div>
                        </div>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
                <% } %>
                
                <% if (configValidation.results && configValidation.results.genieacs && !configValidation.results.genieacs.isValid) { %>
                <div class="alert alert-danger alert-dismissible fade show mb-3 auto-dismiss" role="alert" data-auto-dismiss="10000">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-x-circle-fill me-2 fs-5"></i>
                        <div class="flex-grow-1">
                            <strong>GenieACS Bermasalah:</strong>
                            <div class="mt-1">
                                <% if (configValidation.results.genieacs.errors.length > 0) { %>
                                    <ul class="mb-2">
                                        <% configValidation.results.genieacs.errors.forEach(function(error) { %>
                                        <li><%= error %></li>
                                        <% }); %>
                                    </ul>
                                <% } %>
                            </div>
                            <div>
                                <a href="/admin/settings" class="btn btn-outline-danger btn-sm">
                                    <i class="bi bi-wrench me-1"></i>Perbaiki Konfigurasi GenieACS
                                </a>
                                <button type="button" class="btn btn-outline-secondary btn-sm ms-2" onclick="clearConfigWarning()">
                                    <i class="bi bi-eye-slash me-1"></i>Sembunyikan
                                </button>
                            </div>
                        </div>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
                <% } %>
                
                <% if (configValidation.results && configValidation.results.mikrotik && !configValidation.results.mikrotik.isValid) { %>
                <div class="alert alert-danger alert-dismissible fade show mb-3 auto-dismiss" role="alert" data-auto-dismiss="10000">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-x-circle-fill me-2 fs-5"></i>
                        <div class="flex-grow-1">
                            <strong>Mikrotik Bermasalah:</strong>
                            <div class="mt-1">
                                <% if (configValidation.results.mikrotik.errors.length > 0) { %>
                                    <ul class="mb-2">
                                        <% configValidation.results.mikrotik.errors.forEach(function(error) { %>
                                        <li><%= error %></li>
                                        <% }); %>
                                    </ul>
                                <% } %>
                                <% if (configValidation.results.mikrotik.routerResults && configValidation.results.mikrotik.routerResults.length > 0) { %>
                                    <div class="mt-2">
                                        <strong>Detail Router:</strong>
                                        <ul class="mb-0 mt-1">
                                            <% configValidation.results.mikrotik.routerResults.forEach(function(router) { %>
                                            <li>
                                                <% if (router.success) { %>
                                                    <i class="bi bi-check-circle text-success me-1"></i>
                                                    <strong><%= router.router %></strong>: <%= router.message || 'Terhubung' %>
                                                <% } else { %>
                                                    <i class="bi bi-x-circle text-danger me-1"></i>
                                                    <strong><%= router.router %></strong>: <%= router.error || 'Koneksi gagal' %>
                                                    <% if (router.details) { %>
                                                        <small class="text-muted d-block ms-4">(<%= router.details %>)</small>
                                                    <% } %>
                                                <% } %>
                                            </li>
                                            <% }); %>
                                        </ul>
                                    </div>
                                <% } %>
                            </div>
                            <div class="mt-2">
                                <a href="/admin/routers" class="btn btn-outline-danger btn-sm">
                                    <i class="bi bi-router me-1"></i>Kelola Router Mikrotik
                                </a>
                                <button type="button" class="btn btn-outline-secondary btn-sm ms-2" onclick="clearConfigWarning()">
                                    <i class="bi bi-eye-slash me-1"></i>Sembunyikan
                                </button>
                            </div>
                        </div>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
                <% } %>
                
                <% if (configValidation.summary && configValidation.summary.status === 'valid') { %>
                <div class="alert alert-success alert-dismissible fade show mb-3 auto-dismiss" role="alert" data-auto-dismiss="4000">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-check-circle-fill me-2 fs-5"></i>
                        <div class="flex-grow-1">
                            <strong>Sistem Siap Digunakan!</strong>
                            <div class="mt-1">
                                <%= configValidation.summary.message %>
                                <% if (configValidation.results && configValidation.results.mikrotik && configValidation.results.mikrotik.routerResults && configValidation.results.mikrotik.routerResults.length > 0) { %>
                                    <div class="mt-2">
                                        <strong>Router Mikrotik:</strong>
                                        <ul class="mb-0 mt-1">
                                            <% configValidation.results.mikrotik.routerResults.forEach(function(router) { %>
                                            <li>
                                                <i class="bi bi-check-circle text-success me-1"></i>
                                                <strong><%= router.router %></strong>: <%= router.message || 'Terhubung' %>
                                            </li>
                                            <% }); %>
                                        </ul>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
                <% } %>
            <% } %>

            <!-- LICENSE STATUS CARD (Trial & Expired only - Active moved to top) -->
            <% if (typeof licenseStatus !== 'undefined' && licenseStatus) { %>
            <div class="row mb-4">
                <div class="col-md-12">
                    <% if (licenseStatus.status === 'trial') { %>
                        <div class="alert alert-warning d-flex align-items-center mb-0">
                            <i class="bi bi-clock-history fs-3 me-3"></i>
                            <div class="flex-grow-1">
                                <strong>Mode Trial Aktif</strong>
                                <div class="small">
                                    <span class="badge bg-warning text-dark me-2"><%= licenseStatus.days_remaining || 0 %> hari tersisa</span>
                                    Trial berakhir: <strong><%= licenseStatus.trial_end_date ? new Date(licenseStatus.trial_end_date).toLocaleDateString('id-ID', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) : '-' %></strong>
                                </div>
                                <div class="small mt-1">
                                    <a href="/admin/license" class="btn btn-sm btn-warning">
                                        <i class="bi bi-shield-lock me-1"></i>Aktivasi License Key
                                    </a>
                                </div>
                            </div>
                        </div>
                    <% } else if (licenseStatus.status === 'expired') { %>
                        <div class="alert alert-danger d-flex align-items-center mb-0">
                            <i class="bi bi-exclamation-triangle fs-3 me-3"></i>
                            <div class="flex-grow-1">
                                <strong>Trial Period Telah Berakhir!</strong>
                                <div class="small">Trial berakhir: <%= licenseStatus.trial_end_date ? new Date(licenseStatus.trial_end_date).toLocaleDateString('id-ID', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) : '-' %></div>
                                <div class="small mt-2">
                                    <a href="/admin/license" class="btn btn-sm btn-danger">
                                        <i class="bi bi-shield-lock me-1"></i>Aktivasi License Key Sekarang
                                    </a>
                                </div>
                            </div>
                        </div>
                    <% } %>
                </div>
            </div>
            <% } %>

            <!-- DASHBOARD HEADER -->
            <div class="dashboard-header">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h5>Dashboard Sistem</h5>
                        <p class="page-desc">Overview monitoring perangkat, koneksi, dan performa sistem.</p>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <!-- LICENSE STATUS -->
                        <% if (typeof licenseStatus !== 'undefined' && licenseStatus && licenseStatus.status === 'active') { %>
                        <div class="license-badge-gold d-flex align-items-center px-3 py-2">
                            <i class="bi bi-shield-check fs-5 me-2"></i>
                            <strong>License Aktif</strong>
                        </div>
                        <% } %>
                        <button type="button" class="btn btn-sm" id="validateConfigBtn">
                            <i class="bi bi-gear me-1"></i>Validasi
                        </button>
                        <a href="/admin/settings" class="btn btn-sm">
                            <i class="bi bi-sliders me-1"></i>Pengaturan
                        </a>
                        <button type="button" class="btn btn-sm" id="refreshDashboardBtn">
                            <i class="bi bi-arrow-clockwise me-1"></i>Refresh
                        </button>
                    </div>
                </div>
            </div>

            <!-- GENIEACS CARDS -->
            <div class="row mb-2">
              <div class="col-md-4 mb-2">
                <div class="metric-card metric-card-primary">
                  <div class="metric-card-icon">
                    <i class="bi bi-hdd-network"></i>
                  </div>
                  <div class="metric-card-value" id="genieacs-total">
                    <% if (typeof genieacsTotal !== 'undefined' && genieacsTotal !== null) { %>
                      <%= genieacsTotal %>
                    <% } else { %>
                      <i class="bi bi-hourglass-split"></i>
                    <% } %>
                  </div>
                  <div class="metric-card-label">Total Device GenieACS</div>
                </div>
              </div>
              <div class="col-md-4 mb-2">
                <div class="metric-card metric-card-success">
                  <div class="metric-card-icon">
                    <i class="bi bi-wifi"></i>
                  </div>
                  <div class="metric-card-value" id="genieacs-online">
                    <% if (typeof genieacsOnline !== 'undefined' && genieacsOnline !== null) { %>
                      <%= genieacsOnline %>
                    <% } else { %>
                      <i class="bi bi-hourglass-split"></i>
                    <% } %>
                  </div>
                  <div class="metric-card-label">Device Online</div>
                </div>
              </div>
              <div class="col-md-4 mb-2">
                <div class="metric-card metric-card-danger">
                  <div class="metric-card-icon">
                    <i class="bi bi-wifi-off"></i>
                  </div>
                  <div class="metric-card-value" id="genieacs-offline">
                    <% if (typeof genieacsOffline !== 'undefined' && genieacsOffline !== null) { %>
                      <%= genieacsOffline %>
                    <% } else { %>
                      <i class="bi bi-hourglass-split"></i>
                    <% } %>
                  </div>
                  <div class="metric-card-label">Device Offline</div>
                </div>
              </div>
            </div>
            <!-- MIKROTIK CARDS -->
            <div class="row mb-2">
              <div class="col-md-4 mb-2">
                <div class="metric-card metric-card-pink">
                  <div class="metric-card-icon">
                    <i class="bi bi-people"></i>
                  </div>
                  <div class="metric-card-value" id="mikrotik-total"><%= typeof mikrotikTotal !== 'undefined' ? mikrotikTotal : '-' %></div>
                  <div class="metric-card-label">Total User PPPoE</div>
                </div>
              </div>
              <div class="col-md-4 mb-2">
                <div class="metric-card metric-card-info">
                  <div class="metric-card-icon">
                    <i class="bi bi-person-check"></i>
                  </div>
                  <div class="metric-card-value" id="mikrotik-aktif"><%= typeof mikrotikAktif !== 'undefined' ? mikrotikAktif : '-' %></div>
                  <div class="metric-card-label">PPPoE Aktif</div>
                </div>
              </div>
              <div class="col-md-4 mb-2">
                <div class="metric-card metric-card-danger">
                  <div class="metric-card-icon">
                    <i class="bi bi-person-x"></i>
                  </div>
                  <div class="metric-card-value" id="mikrotik-offline"><%= typeof mikrotikOffline !== 'undefined' ? mikrotikOffline : '-' %></div>
                  <div class="metric-card-label">PPPoE Offline</div>
                </div>
              </div>
            </div>
            <!-- GRAFIK INTERNET -->
            <!-- NAS Monitoring Dashboard -->
            <div class="row mb-4">
              <div class="col-md-12">
                <div class="card">
                  <div class="card-header section-card-header">
                    <div class="d-flex justify-content-between align-items-center">
                      <div class="fw-bold" style="font-size: 0.95rem;"><i class="bi bi-cpu me-1"></i>Monitoring NAS</div>
                      <div class="d-flex align-items-center gap-2">
                        <div id="nasSelect1Container">
                          <label for="nasSelect1" class="form-label mb-0" style="font-size: 0.9rem;">NAS 1:</label>
                          <select id="nasSelect1" class="form-select form-select-sm" style="width: 200px; font-size: 0.9rem;">
                            <option value="">-- Pilih NAS --</option>
                          </select>
                        </div>
                        <div id="nasSelect2Container">
                          <label for="nasSelect2" class="form-label mb-0" style="font-size: 0.9rem;">NAS 2:</label>
                          <select id="nasSelect2" class="form-select form-select-sm" style="width: 200px; font-size: 0.9rem;">
                            <option value="">-- Pilih NAS --</option>
                          </select>
                        </div>
                        <button id="refreshMonitoring" class="btn btn-sm btn-light"><i class="bi bi-arrow-clockwise"></i></button>
                        <span id="lastUpdate" style="font-size: 0.75rem; opacity: 0.7;"></span>
                      </div>
                    </div>
                  </div>
                  <div class="card-body">
                    <div id="monitoringContainer" class="row">
                      <div class="col-12 text-center text-muted py-5">
                        <i class="bi bi-router" style="font-size: 3rem;"></i>
                        <p class="mt-3">Pilih NAS untuk memulai monitoring</p>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            
            <!-- System Information Dashboard -->
            <div class="row mb-4">
              <div class="col-md-12">
                <div class="card">
                  <div class="card-header section-card-header">
                    <div class="d-flex justify-content-between align-items-center">
                      <div class="fw-bold" style="font-size: 0.95rem;"><i class="bi bi-info-circle me-1"></i>System Information</div>
                      <button id="refreshSystemInfo" class="btn btn-sm btn-light"><i class="bi bi-arrow-clockwise"></i></button>
                    </div>
                  </div>
                  <div class="card-body">
                    <!-- Circular Gauges -->
                    <div class="row mb-4">
                      <div class="col-md-3 text-center">
                        <div class="system-gauge">
                          <canvas id="cpuGauge" width="150" height="150"></canvas>
                          <div class="gauge-label">CPU</div>
                          <div class="gauge-value" id="cpuValue">0%</div>
                        </div>
                      </div>
                      <div class="col-md-3 text-center">
                        <div class="system-gauge">
                          <canvas id="memoryGauge" width="150" height="150"></canvas>
                          <div class="gauge-label">REAL MEMORY</div>
                          <div class="gauge-value" id="memoryValue">0%</div>
                        </div>
                      </div>
                      <div class="col-md-3 text-center">
                        <div class="system-gauge">
                          <canvas id="virtualMemoryGauge" width="150" height="150"></canvas>
                          <div class="gauge-label">VIRTUAL MEMORY</div>
                          <div class="gauge-value" id="virtualMemoryValue">0%</div>
                        </div>
                      </div>
                      <div class="col-md-3 text-center">
                        <div class="system-gauge">
                          <canvas id="diskGauge" width="150" height="150"></canvas>
                          <div class="gauge-label">LOCAL DISK SPACE</div>
                          <div class="gauge-value" id="diskValue">0%</div>
                        </div>
                      </div>
                    </div>
                    
                    <!-- Detailed System Information -->
                    <div class="row mb-4">
                      <div class="col-md-6">
                        <h6 class="fw-bold mb-3">System Information</h6>
                        <table class="table table-sm table-borderless">
                          <tr>
                            <td class="text-muted" style="width: 40%;">System hostname:</td>
                            <td id="sysHostname">-</td>
                          </tr>
                          <tr>
                            <td class="text-muted">Application version:</td>
                            <td id="sysVersion">-</td>
                          </tr>
                          <tr>
                            <td class="text-muted">Time on system:</td>
                            <td id="sysTime">-</td>
                          </tr>
                          <tr>
                            <td class="text-muted">Processor information:</td>
                            <td id="sysProcessor">-</td>
                          </tr>
                          <tr>
                            <td class="text-muted">Running processes:</td>
                            <td id="sysProcesses">-</td>
                          </tr>
                          <tr>
                            <td class="text-muted">Real memory:</td>
                            <td id="sysRealMemory">-</td>
                          </tr>
                          <tr>
                            <td class="text-muted">Local disk space:</td>
                            <td id="sysDiskSpace">-</td>
                          </tr>
                        </table>
                      </div>
                      <div class="col-md-6">
                        <h6 class="fw-bold mb-3">System Details</h6>
                        <table class="table table-sm table-borderless">
                          <tr>
                            <td class="text-muted" style="width: 40%;">Operating system:</td>
                            <td id="sysOS">-</td>
                          </tr>
                          <tr>
                            <td class="text-muted">Kernel and CPU:</td>
                            <td id="sysKernel">-</td>
                          </tr>
                          <tr>
                            <td class="text-muted">System uptime:</td>
                            <td id="sysUptime">-</td>
                          </tr>
                          <tr>
                            <td class="text-muted">CPU load averages:</td>
                            <td id="sysLoadAvg">-</td>
                          </tr>
                          <tr>
                            <td class="text-muted">Virtual memory:</td>
                            <td id="sysVirtualMemory">-</td>
                          </tr>
                        </table>
                      </div>
                    </div>
                    
                    <!-- Stats History Charts -->
                    <div class="row mb-4">
                      <div class="col-md-12">
                        <h6 class="fw-bold mb-3">Stats History</h6>
                        
                        <!-- CPU Chart -->
                        <div class="row mb-3 align-items-center">
                          <div class="col-md-2">
                            <div class="stats-info">
                              <h6 class="mb-2 fw-bold">CPU</h6>
                              <div class="small text-muted mb-1">Current: <span id="cpuCurrent" class="fw-bold text-primary">0%</span></div>
                              <div class="small text-muted mb-1">Min: <span id="cpuMin" class="text-success">0%</span></div>
                              <div class="small text-muted mb-1">Max: <span id="cpuMax" class="text-danger">0%</span></div>
                              <div class="small text-muted">Avg: <span id="cpuAvg" class="text-info">0%</span></div>
                            </div>
                          </div>
                          <div class="col-md-10">
                            <canvas id="cpuChart" height="100"></canvas>
                          </div>
                        </div>
                        
                        <!-- Real Memory Chart -->
                        <div class="row mb-3 align-items-center">
                          <div class="col-md-2">
                            <div class="stats-info">
                              <h6 class="mb-2 fw-bold">Real Memory</h6>
                              <div class="small text-muted mb-1">Current: <span id="memoryCurrent" class="fw-bold text-primary">0%</span></div>
                              <div class="small text-muted mb-1">Min: <span id="memoryMin" class="text-success">0%</span></div>
                              <div class="small text-muted mb-1">Max: <span id="memoryMax" class="text-danger">0%</span></div>
                              <div class="small text-muted">Avg: <span id="memoryAvg" class="text-info">0%</span></div>
                            </div>
                          </div>
                          <div class="col-md-10">
                            <canvas id="memoryChart" height="100"></canvas>
                          </div>
                        </div>
                        
                        <!-- Virtual Memory Chart -->
                        <div class="row mb-3 align-items-center">
                          <div class="col-md-2">
                            <div class="stats-info">
                              <h6 class="mb-2 fw-bold">Virtual Memory</h6>
                              <div class="small text-muted mb-1">Current: <span id="virtualMemoryCurrent" class="fw-bold text-primary">0%</span></div>
                              <div class="small text-muted mb-1">Min: <span id="virtualMemoryMin" class="text-success">0%</span></div>
                              <div class="small text-muted mb-1">Max: <span id="virtualMemoryMax" class="text-danger">0%</span></div>
                              <div class="small text-muted">Avg: <span id="virtualMemoryAvg" class="text-info">0%</span></div>
                            </div>
                          </div>
                          <div class="col-md-10">
                            <canvas id="virtualMemoryChart" height="100"></canvas>
                          </div>
                        </div>
                        
                        <!-- Process Chart -->
                        <div class="row mb-3 align-items-center">
                          <div class="col-md-2">
                            <div class="stats-info">
                              <h6 class="mb-2 fw-bold">Process</h6>
                              <div class="small text-muted mb-1">Current: <span id="processCurrent" class="fw-bold text-primary">0</span></div>
                              <div class="small text-muted mb-1">Min: <span id="processMin" class="text-success">0</span></div>
                              <div class="small text-muted mb-1">Max: <span id="processMax" class="text-danger">0</span></div>
                              <div class="small text-muted">Avg: <span id="processAvg" class="text-info">0</span></div>
                            </div>
